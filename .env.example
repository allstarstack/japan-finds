# Mapbox GL JS public token for the /map and /places map views.
# Get token from https://account.mapbox.com/access-tokens/
# Use a token scoped to "URL: https://japan.allstarsteven.com" for production safety.
PUBLIC_MAPBOX_TOKEN=

# Google Places API key — used by scripts/enrich_with_places_api.py (cron + manual
# enrichment runs). Not needed at build time. Lives in .env.local locally.
GOOGLE_PLACES_API_KEY=
