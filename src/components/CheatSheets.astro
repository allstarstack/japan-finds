---
/* §04 Travel Cheat Sheets — homepage teaser.
   Headline + body + a single CTA to /cheat-sheets. The nine sheets
   themselves live on the /cheat-sheets index; the homepage does not
   replicate that list. */
import Eyebrow from "./Eyebrow.astro";
---

<section id="cheat-sheets" class="cs" aria-labelledby="cs-h2">
  <div class="cs__inner">
    <Eyebrow n={4} title="TRAVEL CHEAT SHEETS" />
    <h2 id="cs-h2" class="cs__h2">
      Japan logistics, <span class="hl">made less cursed.</span>
    </h2>
    <p class="cs__body">
      Arrival, Suica, eSIMs, luggage forwarding, JR Pass basics, and the tiny
      details that can ruin your day if nobody explains them.
    </p>
    <div class="cs__cta">
      <a class="btn btn--secondary btn--lg btn--responsive" href="/cheat-sheets">
        Open all cheat sheets&nbsp;→
      </a>
    </div>
  </div>
</section>

<style>
  .cs {
    padding: 32px 0;
    /* Section divider — separates Cheat Sheets from the map section
       above (the rule was lost when the Shopping Lists section was
       removed pre-launch). */
    border-top: var(--border-ink);
  }
  .cs__inner {
    padding: 0 var(--gutter-mobile);
  }

  .cs__h2 {
    margin-bottom: 12px;
    font-size: 30px;
    line-height: 1.02;
    letter-spacing: -0.02em;
  }
  .hl {
    display: inline-block;
    background: var(--color-matcha-green);
    color: #fff;
    padding: 0 8px;
    box-shadow: var(--shadow-sm);
    transform: rotate(-1deg);
  }
  .cs__body {
    margin-bottom: 20px;
    font-size: 14px;
    line-height: 1.55;
    max-width: 520px;
  }

  @media (min-width: 1024px) {
    .cs {
      padding: 72px 0;
    }
    .cs__inner {
      max-width: var(--content-max);
      margin: 0 auto;
      padding: 0 var(--gutter-desktop);
    }
    .cs__h2 {
      margin-bottom: 18px;
      font-size: 52px;
      line-height: 1;
      letter-spacing: -0.025em;
    }
    .hl {
      padding: 0 10px;
      box-shadow: var(--shadow-md);
    }
    .cs__body {
      margin-bottom: 24px;
      font-size: 16px;
      line-height: 1.6;
    }
  }
</style>
