---
/* Site header — wordmark lockup + primary nav.
   Mobile: wordmark + hamburger (opens a full-screen menu).
   Desktop: wordmark + centered links + red CTA. */
import SavePin from "./SavePin.astro";
import { JAPAN_MAP_URL } from "../data/site.js";

/* Root-relative anchors so the nav works from any page, not just home. */
const navLinks = [
  { label: "Map", href: "/places" },
  { label: "Finds", href: "/products" },
  { label: "Cheat Sheets", href: "/#cheat-sheets" },
  { label: "Shop Waitlist", href: "/#shop" },
  { label: "Partner", href: "/#partner" },
];
---

<header class="hdr">
  <div class="hdr__inner">
    <a class="brand" href="/" aria-label="Japan Finds — home">
      <SavePin class="brand__pin" />
      <span class="brand__text">
        <span class="brand__name">Japan Finds</span>
        <span class="brand__tag">BY ALLSTARSTEVEN</span>
      </span>
    </a>

    <nav class="hdr__nav" aria-label="Primary">
      <ul class="hdr__links">
        {navLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <a
      class="btn btn--primary btn--sm hdr__cta"
      href={JAPAN_MAP_URL}
      target="_blank"
      rel="noopener"
    >Get the Japan Map&nbsp;→</a>

    <button
      class="hamburger"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span><span></span>
    </button>
  </div>

  <div id="mobile-menu" class="m-menu" hidden>
    <div class="m-menu__bar">
      <button class="hamburger m-menu__close" type="button" aria-label="Close menu">
        <span></span><span></span>
      </button>
    </div>
    <nav class="m-menu__nav" aria-label="Mobile">
      <ul>
        {navLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>
    <a
      class="btn btn--primary btn--lg m-menu__cta"
      href={JAPAN_MAP_URL}
      target="_blank"
      rel="noopener"
    >Get the Japan Map&nbsp;→</a>
  </div>
</header>

<style>
  .hdr {
    border-bottom: var(--border-ink);
    background: var(--color-rice-white);
  }
  .hdr__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 20px 14px;
  }

  /* Brand lockup */
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }
  .brand__pin {
    --save-pin-size: 36px;
  }
  .brand__text {
    line-height: 1;
  }
  .brand__name {
    display: block;
    font-family: var(--font-head);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .brand__tag {
    display: block;
    margin-top: 3px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: rgba(21, 21, 21, 0.75);
  }

  /* Desktop nav — hidden on mobile */
  .hdr__nav {
    display: none;
  }
  .hdr__links {
    display: flex;
    justify-content: center;
    gap: 32px;
  }
  .hdr__links a {
    font-family: var(--font-head);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-ink-black);
  }
  .hdr__links a:hover {
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 4px;
  }
  .hdr__cta {
    display: none;
  }

  /* Hamburger */
  .hamburger {
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    border: var(--border-ink);
    border-radius: 50%;
    background: #fff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3.5px;
  }
  .hamburger span {
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--color-ink-black);
  }

  /* Mobile menu overlay */
  .m-menu {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: var(--color-rice-white);
    display: flex;
    flex-direction: column;
    padding: 8px 20px 36px;
  }
  .m-menu[hidden] {
    display: none;
  }
  .m-menu__bar {
    display: flex;
    justify-content: flex-end;
    padding-bottom: 8px;
  }
  .m-menu__nav {
    flex: 1;
    display: flex;
    align-items: center;
  }
  .m-menu__nav ul {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .m-menu__nav a {
    display: block;
    padding: 10px 0;
    font-family: var(--font-head);
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-decoration: none;
    color: var(--color-ink-black);
  }
  .m-menu__cta {
    width: 100%;
  }

  @media (min-width: 1024px) {
    .hdr__inner {
      max-width: var(--content-max);
      margin: 0 auto;
      width: 100%;
      height: 80px;
      padding: 0 var(--gutter-desktop);
    }
    .brand__pin {
      --save-pin-size: 40px;
    }
    .brand__name {
      font-size: 20px;
    }
    .brand__tag {
      margin-top: 4px;
    }
    .hdr__nav {
      display: block;
      flex: 1;
    }
    .hdr__cta {
      display: inline-flex;
    }
    .hamburger,
    .m-menu {
      display: none;
    }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>(".hamburger:not(.m-menu__close)");
  const menu = document.getElementById("mobile-menu");
  const closeBtn = menu?.querySelector<HTMLButtonElement>(".m-menu__close");

  if (btn && menu && closeBtn) {
    const open = () => {
      menu.hidden = false;
      btn.setAttribute("aria-expanded", "true");
      document.documentElement.style.overflow = "hidden";
      closeBtn.focus();
    };
    const close = () => {
      menu.hidden = true;
      btn.setAttribute("aria-expanded", "false");
      document.documentElement.style.overflow = "";
      btn.focus();
    };
    btn.addEventListener("click", open);
    closeBtn.addEventListener("click", close);
    menu.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !menu.hidden) close();
    });
  }
</script>
