---
/* /eat filter rail (BUILD_SPEC §3-4). 13 cuisine chips — single-select.
   Horizontal scroll with an edge fade on mobile; wrap on desktop.

   Filtering is client-side and in place. Chip state mirrors to the URL
   (?cuisine=) for shareable links. The "Showing N of 282" count, the
   empty state and the "Clear filters" control live on /eat; this
   component's script drives them by data-attribute.

   The planning-flag chips (walk-in / reservation / casual / splurge)
   were removed: source data assigns reservation_required and price_tier
   per cuisine, so the chips double-encoded the cuisine selection and
   collapsed most combos to 0. The card still surfaces both values
   (badge + meta line); only the filter UI is gone. */
import { CUISINE_CHIPS, CUISINE_COLOR } from "../../data/eat-chips.js";

interface Props {
  cuisineCounts: Record<string, number>; // cuisine slug -> count
}
const { cuisineCounts } = Astro.props;
---

<div class="ec-rail" data-eat-rail>
  <div class="ec-inner">
    <div class="ec-cuisine" role="group" aria-label="Filter restaurants by cuisine">
      {
        CUISINE_CHIPS.map((c) => (
          <button
            type="button"
            class="ec-chip"
            data-cuisine-chip={c.slug}
            data-color={CUISINE_COLOR[c.value]}
            aria-pressed="false"
          >
            {c.label}
            <span class="ec-n">{cuisineCounts[c.slug] ?? 0}</span>
          </button>
        ))
      }
    </div>
    <p class="ec-rail-hint" aria-hidden="true">{CUISINE_CHIPS.length} cuisines · scroll →</p>
  </div>
</div>

<style>
  /* Phase D D6: sticky + bottom ink border moved up to the .rail-sticky
     wrapper in /eat so the location row and this row stick as a unit. */
  .ec-rail {
    background: var(--color-white);
  }
  .ec-inner {
    max-width: var(--content-max);
    margin: 0 auto;
  }

  /* Cuisine chips — horizontal-scroll on mobile, no visible scrollbar, with
     an edge fade so a clipped chip reads as "more this way". */
  .ec-cuisine {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    padding: 12px var(--gutter-mobile) 8px;
    scroll-padding-inline: var(--gutter-mobile);
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 16px,
      #000 calc(100% - 16px),
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 16px,
      #000 calc(100% - 16px),
      transparent
    );
  }
  .ec-cuisine::-webkit-scrollbar {
    display: none;
  }

  /* Mobile-only overflow hint — sits beneath the scrolling cuisine row so
     users see how many chips exist off-screen. Hidden on desktop, where all
     chips wrap into view. */
  .ec-rail-hint {
    margin: 0;
    padding: 0 var(--gutter-mobile) 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--color-ink-60);
  }

  .ec-chip {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 38px;
    padding: 8px 14px;
    background: transparent;
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--color-ink-black);
    transition: background-color 120ms ease-out, color 120ms ease-out;
  }
  /* Active chip fills with the cuisine's card colour, so the rail previews
     the block colour you will land on. Soba/Udon (gray) fill ink instead —
     concrete gray reads as inactive against the white rail. */
  .ec-chip[data-color="red"] {
    --c: var(--color-tokyo-red);
  }
  .ec-chip[data-color="red-deep"] {
    --c: #b93028;
  }
  .ec-chip[data-color="yellow"] {
    --c: var(--color-egg-yellow);
  }
  .ec-chip[data-color="ink"] {
    --c: var(--color-ink-black);
  }
  .ec-chip[data-color="blue"] {
    --c: var(--color-konbini-blue);
  }
  .ec-chip[data-color="green"] {
    --c: var(--color-matcha-green);
  }
  .ec-chip[data-color="gray"] {
    --c: var(--color-ink-black);
  }
  .ec-chip.is-active {
    background: var(--c);
    border-color: var(--c);
    color: #fff;
  }
  .ec-chip[data-color="yellow"].is-active {
    color: var(--color-ink-black);
  }

  .ec-n {
    font-weight: 700;
  }

  @media (min-width: 1024px) {
    /* All 13 cuisine chips visible — wrap, no scroll, no edge fade. */
    .ec-cuisine {
      flex-wrap: wrap;
      overflow-x: visible;
      padding: 16px var(--gutter-desktop) 10px;
      -webkit-mask-image: none;
      mask-image: none;
    }
    .ec-rail-hint {
      display: none;
    }
  }
</style>

<script>
  const rail = document.querySelector("[data-eat-rail]");
  if (rail) {
    const cuisineBtns = [
      ...rail.querySelectorAll<HTMLButtonElement>("[data-cuisine-chip]"),
    ];
    /* Phase D D6 — location chips live in a sibling LocationChipRow inside
       the shared .rail-sticky wrapper, not in [data-eat-rail], so we query
       at document level. The data-location-chip="" button is the "All
       Japan" default; selecting it clears the location filter. */
    const locationBtns = [
      ...document.querySelectorAll<HTMLButtonElement>(
        "[data-location-row] [data-location-chip]",
      ),
    ];
    const cards = [
      ...document.querySelectorAll<HTMLElement>("[data-grid] .rc"),
    ];
    const grid = document.querySelector<HTMLElement>("[data-grid]");
    const countEl = document.querySelector("[data-count]");
    const emptyEl = document.querySelector<HTMLElement>("[data-empty]");
    const clearEl = document.querySelector<HTMLElement>("[data-clear]");
    const searchInput = document.querySelector<HTMLInputElement>("[data-search-input]");
    const TOTAL = cards.length;

    const validLocations = new Set(
      locationBtns
        .map((b) => b.dataset.locationChip || "")
        .filter(Boolean),
    );
    const validCuisines = new Set(
      cuisineBtns.map((b) => b.dataset.cuisineChip),
    );

    let activeLocation: string | null = null;
    const activeCuisines = new Set<string>();
    let query = "";

    /* replaceState (not pushState) matches the rest of this rail's
       convention — selecting filter chips updates the URL in place rather
       than spawning history entries the user has to back through. The
       shareable-URL criterion still holds (read on init + popstate). */
    const syncURL = () => {
      const p = new URLSearchParams();
      if (activeLocation) p.set("where", activeLocation);
      if (activeCuisines.size) p.set("cuisine", [...activeCuisines].join(","));
      const qs = p.toString();
      history.replaceState(null, "", qs ? "?" + qs : location.pathname);
    };

    const apply = () => {
      // Token-AND substring search over each card's data-search blob.
      // Mirrors /places + /stay: search ANDs with chip filters in the
      // same predicate.
      const tokens = query.split(/\s+/).filter(Boolean);
      let n = 0;
      for (const card of cards) {
        // Location, cuisine, search all AND together. Cuisine and location
        // are single-select.
        const okLocation =
          !activeLocation || card.dataset.city === activeLocation;
        const okCuisine =
          activeCuisines.size === 0 ||
          activeCuisines.has(card.dataset.cuisine || "");
        const okSearch = tokens.every((t) =>
          (card.dataset.search || "").includes(t),
        );
        const show = okLocation && okCuisine && okSearch;
        card.hidden = !show;
        if (show) n++;
      }
      for (const b of locationBtns) {
        const v = b.dataset.locationChip || "";
        const on = v === (activeLocation ?? "");
        b.setAttribute("aria-pressed", String(on));
        b.classList.toggle("is-active", on);
      }
      for (const b of cuisineBtns) {
        const on = activeCuisines.has(b.dataset.cuisineChip || "");
        b.setAttribute("aria-pressed", String(on));
        b.classList.toggle("is-active", on);
      }
      if (countEl) countEl.textContent = `Showing ${n} of ${TOTAL}`;
      if (emptyEl) emptyEl.hidden = n !== 0;
      if (grid) grid.hidden = n === 0;
      if (clearEl)
        clearEl.hidden =
          !activeLocation &&
          activeCuisines.size === 0 &&
          query === "";

      /* Phase B: broadcast visible restaurant slugs for a sibling
         MapView (when /eat is in map-view). Late-attaching listeners
         recover by querying [data-grid] [data-slug]:not([hidden]) on
         their own init. */
      const visibleSlugs = new Set();
      for (const card of cards) {
        if (!card.hidden) {
          const slug = card.dataset.slug;
          if (slug) visibleSlugs.add(slug);
        }
      }
      document.dispatchEvent(
        new CustomEvent("eat:filter-changed", {
          detail: { visibleSlugs },
        }),
      );
    };

    /* Sync filter state from the URL. Called on initial load and on
       popstate (browser back/forward) so URL changes from any source
       re-apply. Unknown slugs are silently ignored — no console warning.
       Legacy ?flag= params from the removed planning-flag chips are
       dropped on sync (syncURL never writes them back). */
    const readURL = () => {
      activeLocation = null;
      activeCuisines.clear();
      const params = new URLSearchParams(location.search);
      const where = params.get("where");
      if (where && validLocations.has(where)) activeLocation = where;
      for (const c of (params.get("cuisine") || "").split(",").filter(Boolean)) {
        if (validCuisines.has(c)) { activeCuisines.add(c); break; } // single-select
      }
    };

    locationBtns.forEach((b) =>
      b.addEventListener("click", () => {
        const v = b.dataset.locationChip || "";
        // Single-select. Re-tapping the active chip clears it; tapping
        // the All Japan chip (slug "") explicitly does the same.
        activeLocation = v && v !== activeLocation ? v : null;
        apply();
        syncURL();
        b.scrollIntoView({ inline: "center", block: "nearest" });
      }),
    );
    cuisineBtns.forEach((b) =>
      b.addEventListener("click", () => {
        const v = b.dataset.cuisineChip || "";
        if (activeCuisines.has(v)) {
          activeCuisines.delete(v); // re-click clears
        } else {
          activeCuisines.clear(); // single-select — replace any existing pick
          activeCuisines.add(v);
        }
        apply();
        syncURL();
        b.scrollIntoView({ inline: "center", block: "nearest" });
      }),
    );
    if (clearEl)
      clearEl.addEventListener("click", () => {
        activeLocation = null;
        activeCuisines.clear();
        query = "";
        if (searchInput) searchInput.value = "";
        apply();
        syncURL();
      });

    if (searchInput) {
      searchInput.addEventListener("input", () => {
        query = searchInput.value.trim().toLowerCase();
        apply();
      });
    }

    /* Re-apply filter state when the URL changes via browser navigation
       (back/forward) — keeps the rail and the URL coherent. */
    window.addEventListener("popstate", () => {
      readURL();
      apply();
    });

    readURL();
    apply();
  }
</script>
