---
/* /eat filter rail (BUILD_SPEC §3-4). Two tiers, mirroring PlaceFilterRail:
   - 13 cuisine chips — single-select. Horizontal scroll with an
     edge fade on mobile; wrap on desktop.
   - 4 planning-flag chips in two single-select dimensions (reservation
     status, price). Within a dimension the two chips are radio-style and
     mutually exclusive — picking one unpicks the other, since AND-ing
     e.g. Walk-in OK + Reservation needed could never match. The
     dimensions combine with each other and with the cuisine filter. A
     hairline divider separates the two tiers.

   Filtering is client-side and in place. Chip state mirrors to the URL
   (?cuisine=&flag=) for shareable links; ?flag= holds at most one value
   per dimension. The "Showing N of 282" count, the empty state and the
   "Clear filters" control live on /eat; this component's script drives
   them by data-attribute. */
import { CUISINE_CHIPS, FLAG_CHIPS, CUISINE_COLOR } from "../../data/eat-chips.js";

interface Props {
  cuisineCounts: Record<string, number>; // cuisine slug -> count
  flagCounts: Record<string, number>; // flag slug -> count
}
const { cuisineCounts, flagCounts } = Astro.props;

/* The two flag dimensions, each rendered as its own radio group. */
const FLAG_DIMS = [
  { id: "reservation", aria: "Filter by reservation status" },
  { id: "price", aria: "Filter by price" },
];
---

<div class="ec-rail" data-eat-rail>
  <div class="ec-inner">
    <div class="ec-cuisine" role="group" aria-label="Filter restaurants by cuisine">
      {
        CUISINE_CHIPS.map((c) => (
          <button
            type="button"
            class="ec-chip"
            data-cuisine-chip={c.slug}
            data-color={CUISINE_COLOR[c.value]}
            aria-pressed="false"
          >
            {c.label}
            <span class="ec-n">{cuisineCounts[c.slug] ?? 0}</span>
          </button>
        ))
      }
    </div>

    <div class="ec-flags">
      {
        FLAG_DIMS.map((d) => (
          <div class="ec-flag-group" role="group" aria-label={d.aria}>
            {FLAG_CHIPS.filter((f) => f.dim === d.id).map((f) => (
              <button
                type="button"
                class="ec-flag"
                data-flag-chip={f.slug}
                data-flag-dim={f.dim}
                aria-pressed="false"
              >
                {f.label}
                <span class="ec-n">{flagCounts[f.slug] ?? 0}</span>
              </button>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  /* Phase D D6: sticky + bottom ink border moved up to the .rail-sticky
     wrapper in /eat so the location row and this row stick as a unit. */
  .ec-rail {
    background: var(--color-white);
  }
  .ec-inner {
    max-width: var(--content-max);
    margin: 0 auto;
  }

  /* Cuisine chips — horizontal-scroll on mobile, no visible scrollbar, with
     an edge fade so a clipped chip reads as "more this way". */
  .ec-cuisine {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    padding: 12px var(--gutter-mobile) 8px;
    scroll-padding-inline: var(--gutter-mobile);
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 16px,
      #000 calc(100% - 16px),
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 16px,
      #000 calc(100% - 16px),
      transparent
    );
  }
  .ec-cuisine::-webkit-scrollbar {
    display: none;
  }

  .ec-chip {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 38px;
    padding: 8px 14px;
    background: transparent;
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--color-ink-black);
    transition: background-color 120ms ease-out, color 120ms ease-out;
  }
  /* Active chip fills with the cuisine's card colour, so the rail previews
     the block colour you will land on. Soba/Udon (gray) fill ink instead —
     concrete gray reads as inactive against the white rail. */
  .ec-chip[data-color="red"] {
    --c: var(--color-tokyo-red);
  }
  .ec-chip[data-color="red-deep"] {
    --c: #b93028;
  }
  .ec-chip[data-color="yellow"] {
    --c: var(--color-egg-yellow);
  }
  .ec-chip[data-color="ink"] {
    --c: var(--color-ink-black);
  }
  .ec-chip[data-color="blue"] {
    --c: var(--color-konbini-blue);
  }
  .ec-chip[data-color="green"] {
    --c: var(--color-matcha-green);
  }
  .ec-chip[data-color="gray"] {
    --c: var(--color-ink-black);
  }
  .ec-chip.is-active {
    background: var(--c);
    border-color: var(--c);
    color: #fff;
  }
  .ec-chip[data-color="yellow"].is-active {
    color: var(--color-ink-black);
  }

  /* Planning-flag chips — wrap, always visible, divided from the cuisine
     row by a hairline. Uniform ink fill when active. */
  .ec-flags {
    display: flex;
    flex-direction: column;
    /* Stack the two flag dimensions on their own rows so the radio-style
       grouping reads visually (mobile). Desktop overrides to row layout
       below with a wider column gap. */
    gap: 10px;
    padding: 10px var(--gutter-mobile) 12px;
    border-top: 1px solid var(--color-ink-15);
  }
  .ec-flag-group {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .ec-flag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 32px;
    padding: 6px 12px;
    background: transparent;
    border: 1.5px solid var(--color-ink-30);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    transition: background-color 120ms ease-out, color 120ms ease-out;
  }
  .ec-flag.is-active {
    background: var(--color-ink-black);
    border-color: var(--color-ink-black);
    color: #fff;
  }

  .ec-n {
    font-weight: 700;
  }

  @media (min-width: 1024px) {
    /* All 13 cuisine chips visible — wrap, no scroll, no edge fade. */
    .ec-cuisine {
      flex-wrap: wrap;
      overflow-x: visible;
      padding: 16px var(--gutter-desktop) 10px;
      -webkit-mask-image: none;
      mask-image: none;
    }
    .ec-flags {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 8px 20px;
      padding: 12px var(--gutter-desktop) 16px;
    }
  }
</style>

<script>
  const rail = document.querySelector("[data-eat-rail]");
  if (rail) {
    const cuisineBtns = [
      ...rail.querySelectorAll<HTMLButtonElement>("[data-cuisine-chip]"),
    ];
    const flagBtns = [
      ...rail.querySelectorAll<HTMLButtonElement>("[data-flag-chip]"),
    ];
    /* Phase D D6 — location chips live in a sibling LocationChipRow inside
       the shared .rail-sticky wrapper, not in [data-eat-rail], so we query
       at document level. The data-location-chip="" button is the "All
       Japan" default; selecting it clears the location filter. */
    const locationBtns = [
      ...document.querySelectorAll<HTMLButtonElement>(
        "[data-location-row] [data-location-chip]",
      ),
    ];
    const cards = [
      ...document.querySelectorAll<HTMLElement>("[data-grid] .rc"),
    ];
    const grid = document.querySelector<HTMLElement>("[data-grid]");
    const countEl = document.querySelector("[data-count]");
    const emptyEl = document.querySelector<HTMLElement>("[data-empty]");
    const clearEl = document.querySelector<HTMLElement>("[data-clear]");
    const TOTAL = cards.length;

    const validLocations = new Set(
      locationBtns
        .map((b) => b.dataset.locationChip || "")
        .filter(Boolean),
    );
    const validCuisines = new Set(
      cuisineBtns.map((b) => b.dataset.cuisineChip),
    );
    const flagDim = new Map(
      flagBtns.map((b) => [b.dataset.flagChip, b.dataset.flagDim]),
    );

    let activeLocation: string | null = null;
    const activeCuisines = new Set<string>();
    const activeFlags = new Set<string>();

    const cardFlags = (card: HTMLElement) =>
      (card.dataset.flags || "").split(" ").filter(Boolean);

    /* replaceState (not pushState) matches the rest of this rail's
       convention — selecting filter chips updates the URL in place rather
       than spawning history entries the user has to back through. The
       shareable-URL criterion still holds (read on init + popstate). */
    const syncURL = () => {
      const p = new URLSearchParams();
      if (activeLocation) p.set("where", activeLocation);
      if (activeCuisines.size) p.set("cuisine", [...activeCuisines].join(","));
      if (activeFlags.size) p.set("flag", [...activeFlags].join(","));
      const qs = p.toString();
      history.replaceState(null, "", qs ? "?" + qs : location.pathname);
    };

    const apply = () => {
      let n = 0;
      for (const card of cards) {
        // Location, cuisine, flags all AND together. Cuisine and location
        // are single-select; flags AND within themselves (radio per dim).
        const okLocation =
          !activeLocation || card.dataset.city === activeLocation;
        const okCuisine =
          activeCuisines.size === 0 ||
          activeCuisines.has(card.dataset.cuisine || "");
        const fl = cardFlags(card);
        const okFlags = [...activeFlags].every((f) => fl.includes(f));
        const show = okLocation && okCuisine && okFlags;
        card.hidden = !show;
        if (show) n++;
      }
      for (const b of locationBtns) {
        const v = b.dataset.locationChip || "";
        const on = v === (activeLocation ?? "");
        b.setAttribute("aria-pressed", String(on));
        b.classList.toggle("is-active", on);
      }
      for (const b of cuisineBtns) {
        const on = activeCuisines.has(b.dataset.cuisineChip || "");
        b.setAttribute("aria-pressed", String(on));
        b.classList.toggle("is-active", on);
      }
      for (const b of flagBtns) {
        const on = activeFlags.has(b.dataset.flagChip || "");
        b.setAttribute("aria-pressed", String(on));
        b.classList.toggle("is-active", on);
      }
      if (countEl) countEl.textContent = `Showing ${n} of ${TOTAL}`;
      if (emptyEl) emptyEl.hidden = n !== 0;
      if (grid) grid.hidden = n === 0;
      if (clearEl)
        clearEl.hidden =
          !activeLocation &&
          activeCuisines.size === 0 &&
          activeFlags.size === 0;
    };

    /* Sync filter state from the URL. Called on initial load and on
       popstate (browser back/forward) so URL changes from any source
       re-apply. Unknown slugs are silently ignored — no console warning. */
    const readURL = () => {
      activeLocation = null;
      activeCuisines.clear();
      activeFlags.clear();
      const params = new URLSearchParams(location.search);
      const where = params.get("where");
      if (where && validLocations.has(where)) activeLocation = where;
      for (const c of (params.get("cuisine") || "").split(",").filter(Boolean)) {
        if (validCuisines.has(c)) { activeCuisines.add(c); break; } // single-select
      }
      const usedDims = new Set<string>();
      for (const f of (params.get("flag") || "").split(",").filter(Boolean)) {
        const dim = flagDim.get(f);
        // Skip unknown slugs and any second value from a dimension already
        // filled — keeps the URL state radio-compatible.
        if (!dim || usedDims.has(dim)) continue;
        usedDims.add(dim);
        activeFlags.add(f);
      }
    };

    locationBtns.forEach((b) =>
      b.addEventListener("click", () => {
        const v = b.dataset.locationChip || "";
        // Single-select. Re-tapping the active chip clears it; tapping
        // the All Japan chip (slug "") explicitly does the same.
        activeLocation = v && v !== activeLocation ? v : null;
        apply();
        syncURL();
        b.scrollIntoView({ inline: "center", block: "nearest" });
      }),
    );
    cuisineBtns.forEach((b) =>
      b.addEventListener("click", () => {
        const v = b.dataset.cuisineChip || "";
        if (activeCuisines.has(v)) {
          activeCuisines.delete(v); // re-click clears
        } else {
          activeCuisines.clear(); // single-select — replace any existing pick
          activeCuisines.add(v);
        }
        apply();
        syncURL();
        b.scrollIntoView({ inline: "center", block: "nearest" });
      }),
    );
    flagBtns.forEach((b) =>
      b.addEventListener("click", () => {
        const v = b.dataset.flagChip || "";
        const dim = b.dataset.flagDim || "";
        if (activeFlags.has(v)) {
          activeFlags.delete(v); // re-click clears the dimension
        } else {
          // Single-select within a dimension — unpick the sibling first so
          // two mutually exclusive flags can never both be active.
          for (const sib of flagBtns)
            if (sib.dataset.flagDim === dim)
              activeFlags.delete(sib.dataset.flagChip || "");
          activeFlags.add(v);
        }
        apply();
        syncURL();
      }),
    );
    if (clearEl)
      clearEl.addEventListener("click", () => {
        activeLocation = null;
        activeCuisines.clear();
        activeFlags.clear();
        apply();
        syncURL();
      });

    /* Re-apply filter state when the URL changes via browser navigation
       (back/forward) — keeps the rail and the URL coherent. */
    window.addEventListener("popstate", () => {
      readURL();
      apply();
    });

    readURL();
    apply();
  }
</script>
