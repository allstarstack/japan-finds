---
/* /eat restaurant card (BUILD_SPEC §5; Phase D D1 photos + open-now).
   Mobile-first, text-forward. The card leads with a Google hero photo
   (Phase D D1); the ~1 row with no photo falls back to a solid
   colour-block placeholder keyed to cuisine_chip — not faked or AI
   imagery (brand.md).

   The price tier + list badges sit absolutely over the top-right of the
   media. data-cuisine / data-flags drive the client-side filter in
   ChipRow; they are precomputed here so the filter ships no taxonomy. */
import {
  CUISINE_COLOR,
  cuisineSlug,
  restaurantCity,
  restaurantFlags,
} from "../../data/eat-chips.js";
import OpenNowBadge from "../OpenNowBadge.astro";

interface Props {
  restaurant: Record<string, any>;
}

const { restaurant: r } = Astro.props;

const color = CUISINE_COLOR[r.cuisine_chip] ?? "gray";
const cuisine = cuisineSlug(r.cuisine_chip);
const city = restaurantCity(r);
const flags = restaurantFlags(r);

/* Shokudo picks come from the Shokudo Hyakumeiten, a separate list — the
   badge says so (BUILD_SPEC §5). */
const listBadge = `${r.is_shokudo ? "Shokudo Hyakumeiten" : "Hyakumeiten"} ${r.list_year}`;
const meta = `${r.genre} · #${r.rank_in_city} in ${r.city} · ${r.neighborhood}`;
const resLine = `${r.reservation_required} · ${r.notes}`;

/* Phase D D1 — link straight to the matched business via place_id; the
   old name-search URL is the fallback for any row that matched nothing. */
const mapsUrl = r.place_id
  ? `https://www.google.com/maps/place/?q=place_id:${r.place_id}`
  : r.maps_search;
---

<article class="rc" data-cuisine={cuisine} data-city={city} data-flags={flags.join(" ")}>
  <div class="rc-media">
    {
      r.hero_image ? (
        <img
          class="rc-img"
          src={r.hero_image}
          alt=""
          loading="lazy"
          width="900"
          height="600"
        />
      ) : (
        <div class:list={["rc-block", `rc-block--${color}`]} aria-hidden="true" />
      )
    }
    {r.hero_attribution && <span class="rc-attr">{r.hero_attribution}</span>}
  </div>
  <div class="rc-badges">
    <span class="rc-price">{r.price_tier}</span>
    <span class="rc-list">{listBadge}</span>
  </div>

  <div class="rc-body">
    <h3 class="rc-name">{r.name_en}</h3>
    <p class="rc-jp">{r.name_jp}</p>
    <p class="rc-meta">{meta}</p>
    <p class="rc-res">{resLine}</p>
    <OpenNowBadge hours={r.hours} />
    <div class="rc-links">
      <a
        class="rc-link"
        href={mapsUrl}
        target="_blank"
        rel="noopener"
        aria-label={`${r.name_en} — Google Maps`}
      >Google Maps&nbsp;→</a>
      <a
        class="rc-link"
        href={r.list_url}
        target="_blank"
        rel="noopener"
        aria-label={`${r.name_en} — Tabelog list`}
      >Tabelog list&nbsp;→</a>
    </div>
  </div>
</article>

{/* TODO(cross-link, deferred — BUILD_SPEC "Cross-linking to /places"):
    add a "Places near here" link → /places?neighborhood={r.neighborhood};
    /places gets the reciprocal link back to /eat. Skipped in this build. */}

<style>
  .rc {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-concrete-gray);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: border-color 120ms ease-out;
  }
  /* ChipRow toggles cards via the `hidden` attribute; an author `display`
     declaration outranks the UA [hidden] rule, so restore it. */
  .rc[hidden] {
    display: none;
  }
  /* Hover: border emphasis only — no shadow gimmicks, matches PlaceCard. */
  .rc:hover,
  .rc:focus-within {
    border-color: var(--color-ink-black);
  }

  /* Hero media — a 3:2 Google photo, or the colour-block fallback.
     position: relative anchors the attribution overlay. overflow: hidden
     locks the box to 3:2 regardless of the source photo's dimensions —
     without it a tall/wide image's intrinsic size expands the box. */
  .rc-media {
    position: relative;
    aspect-ratio: 3 / 2;
    width: 100%;
    overflow: hidden;
  }
  .rc-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Photo credit — overlaid bottom-right on a near-white chip so the
     ink-60 caption clears against any photo (Phase D D1). */
  .rc-attr {
    position: absolute;
    right: 6px;
    bottom: 6px;
    padding: 1px 5px;
    background: rgba(255, 255, 255, 0.9);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 11px;
    line-height: 1.3;
    color: var(--color-ink-60);
    pointer-events: none;
  }

  /* Colour-block placeholder — keyed to cuisine_chip (BUILD_SPEC §5).
     Fills the 3:2 media box when no hero photo exists. */
  .rc-block {
    width: 100%;
    height: 100%;
  }
  .rc-block--red {
    background: var(--color-tokyo-red);
  }
  /* Tokyo Signal Red darkened ~30% toward ink so Sukiyaki reads distinct
     from the Ramen/Sushi red (BUILD_SPEC §5 "darker tint at 0.7"). */
  .rc-block--red-deep {
    background: #b93028;
  }
  .rc-block--yellow {
    background: var(--color-egg-yellow);
  }
  .rc-block--ink {
    background: var(--color-ink-black);
  }
  .rc-block--blue {
    background: var(--color-konbini-blue);
  }
  .rc-block--green {
    background: var(--color-matcha-green);
  }
  .rc-block--gray {
    background: var(--color-concrete-gray);
  }

  /* Price + list badges — white label chips over the top-right of the
     block. The backing surface is required, not decorative: bare text on
     the green Izakaya/Shokudo block clears AA in neither ink (4.47:1) nor
     white (4.08:1). Ink-on-white is ~17:1 on every block colour. */
  .rc-badges {
    position: absolute;
    top: 8px;
    right: 8px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 3px;
    text-align: right;
    pointer-events: none;
  }
  .rc-price,
  .rc-list {
    background: #fff;
    color: var(--color-ink-black);
    font-family: var(--font-mono);
    font-weight: 500;
    border: 1px solid var(--color-hair);
    border-radius: var(--radius-sm);
  }
  .rc-price {
    padding: 1px 6px;
    font-size: 12px;
    letter-spacing: 0.01em;
  }
  .rc-list {
    padding: 1px 5px;
    font-size: 9px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .rc-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
    padding: 12px;
  }
  .rc-name {
    margin: 0;
    font-family: var(--font-head);
    font-size: 15px;
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.01em;
  }
  .rc-jp {
    margin: 0;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.4;
    color: var(--color-ink-60);
  }
  .rc-meta {
    margin: 2px 0 0;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.4;
    color: var(--color-ink-60);
  }
  .rc-res {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1.45;
    letter-spacing: 0.01em;
    color: var(--color-ink-60);
  }

  /* Links pinned to the card bottom so wrapped names stay aligned. */
  .rc-links {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    margin: auto 0 0;
    padding-top: 8px;
  }
  /* inline-flex + min-height keeps each link a ≥24px tap target
     (Lighthouse target-size / WCAG 2.2). */
  .rc-link {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ink-black);
    text-decoration: none;
  }
  .rc-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (min-width: 1024px) {
    .rc-body {
      padding: 14px;
    }
    .rc-name {
      font-size: 16px;
    }
  }
</style>
