---
/* Cheat-sheets icon library (V4 style).

   Functional line-art only: 1.5px ink stroke, 24×24 viewBox,
   round caps/joins. No travel-mood iconography (no torii / Fuji /
   blossoms / shrines / neon — see brand.md "Banned imagery").

   Six icons (calendar, onigiri, iccard, ticket, yen, pill) are
   ports of the V4 source's icon library — see
   docs/build/CheatSheets_v4_source.jsx for the originals.

   Four icons (sunrise, phone, suitcase, family) are new, drawn for
   the four cheat sheets the V4 source didn't cover. */
interface Props {
  kind: string;
  size?: number;
}
const { kind, size = 28 } = Astro.props;
---

{kind === "calendar" && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <rect x="3.5" y="5" width="17" height="15" rx="1.5" />
    <line x1="3.5" y1="9.5" x2="20.5" y2="9.5" />
    <line x1="8" y1="3" x2="8" y2="6.5" />
    <line x1="16" y1="3" x2="16" y2="6.5" />
    <rect x="7" y="12.5" width="2.4" height="2.4" rx="0.4" fill="currentColor" stroke="none" />
    <rect x="11" y="12.5" width="2.4" height="2.4" rx="0.4" />
    <rect x="15" y="12.5" width="2.4" height="2.4" rx="0.4" />
    <rect x="7" y="16.5" width="2.4" height="2.4" rx="0.4" />
    <rect x="11" y="16.5" width="2.4" height="2.4" rx="0.4" />
  </svg>
)}

{kind === "onigiri" && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M12 4 L20 19 L4 19 Z" />
    <rect x="7" y="15.5" width="10" height="3.5" />
    <line x1="7" y1="15.5" x2="17" y2="15.5" />
  </svg>
)}

{kind === "iccard" && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <rect x="3" y="5" width="18" height="14" rx="2" />
    <path d="M8 14 Q10 11 13 14" />
    <path d="M7 16 Q10 11 15 16" />
    <circle cx="17.5" cy="9" r="0.5" fill="currentColor" stroke="none" />
  </svg>
)}

{kind === "ticket" && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M3 9 Q3 8 4 8 L20 8 Q21 8 21 9 L21 11 Q19.5 11 19.5 12 Q19.5 13 21 13 L21 15 Q21 16 20 16 L4 16 Q3 16 3 15 L3 13 Q4.5 13 4.5 12 Q4.5 11 3 11 Z" />
    <line x1="9" y1="11" x2="9" y2="13" />
    <line x1="15" y1="11" x2="15" y2="13" />
  </svg>
)}

{kind === "yen" && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="12" cy="12" r="8.5" />
    <path d="M8.5 7.5 L12 12.5 L15.5 7.5" />
    <line x1="12" y1="12.5" x2="12" y2="17" />
    <line x1="8.5" y1="13.5" x2="15.5" y2="13.5" />
    <line x1="8.5" y1="15.5" x2="15.5" y2="15.5" />
  </svg>
)}

{kind === "pill" && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <rect x="3" y="9" width="18" height="6" rx="3" transform="rotate(-30 12 12)" />
    <line x1="9.5" y1="6.5" x2="14.5" y2="17.5" />
  </svg>
)}
