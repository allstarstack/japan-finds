---
/* §02 "Going to Japan?" — homepage cheat-sheet preview (V4-aligned 2026-05-28).
   Earlier pass surfaced a bordered "Updated <date>" chip on each card; the
   six featured sheets all share the same last_verified, so the six identical
   chips carried no information. This pass ports the /cheat-sheets V4
   evergreen-card vocabulary (iconwell + category chip topline) so the
   preview matches the index it links to. Card meta on the homepage is the
   numeral + category — no per-card date, no redundant tail numeral.

   Featured slug list stays hardcoded — editorial order on the homepage is
   intentionally different from the /cheat-sheets index. Per-slug icon +
   category mirror the SHEET_META on the cheat-sheets index; the icon set
   (CSIcon) is the single source of truth for both surfaces. */
import { getCollection } from "astro:content";
import { extractLede } from "../data/cheat-sheets.js";
import Eyebrow from "./Eyebrow.astro";
import CSIcon from "./CSIcon.astro";

const FEATURED_SLUGS = [
  "first-24-hours",
  "phone-setup",
  "ic-cards",
  "jr-pass",
  "cash-cards-atms",
  "luggage-forwarding",
];

/* Mirrors SHEET_META in /cheat-sheets/index.astro for the same six slugs.
   Kept here (not re-exported from the index page) so the homepage component
   has no cross-page import — the icon library (CSIcon) is the shared piece. */
const SHEET_META: Record<string, { icon: string; category: string }> = {
  "first-24-hours":      { icon: "sunrise",  category: "Orientation" },
  "phone-setup":         { icon: "phone",    category: "Connectivity" },
  "ic-cards":            { icon: "iccard",   category: "Transit" },
  "jr-pass":             { icon: "ticket",   category: "Transit" },
  "cash-cards-atms":     { icon: "yen",      category: "Money" },
  "luggage-forwarding":  { icon: "suitcase", category: "Logistics" },
};

const byId = new Map(
  (await getCollection("cheat-sheets")).map((e) => [e.id, e]),
);

const items = FEATURED_SLUGS.map((slug, i) => {
  const entry = byId.get(slug);
  if (!entry) {
    throw new Error(`GoingToJapan: no source file for "${slug}.md"`);
  }
  const meta = SHEET_META[slug];
  if (!meta) {
    throw new Error(`GoingToJapan: SHEET_META missing for "${slug}"`);
  }
  return {
    n: String(i + 1).padStart(2, "0"),
    slug,
    title: entry.data.title,
    tagline: extractLede(entry.body),
    icon: meta.icon,
    category: meta.category,
    href: `/cheat-sheets/${slug}`,
  };
});
---

<section id="going-to-japan" class="gtj" aria-labelledby="gtj-h2">
  <div class="gtj__inner">
    <Eyebrow n={2} title="GOING TO JAPAN" after="BEFORE YOU FLY" />
    <header class="gtj__head">
      <div class="gtj__head-text">
        <h2 id="gtj-h2" class="gtj__title">Going to Japan?</h2>
        <p class="gtj__sub">Sort these before you fly.</p>
      </div>
    </header>

    <ul class="gtj__grid">
      {items.map((it) => (
        <li class="gtj__grid-item">
          <a class="gtj__card" href={it.href}>
            <div class="gtj__card-top">
              <div class="gtj__iconwell">
                <CSIcon kind={it.icon} size={26} />
              </div>
              <span class="gtj__cat">{it.category}</span>
            </div>
            <span class="gtj__card-num" aria-hidden="true">{it.n}</span>
            <h3 class="gtj__name">{it.title}</h3>
            <p class="gtj__detail">{it.tagline}</p>
            <div class="gtj__card-foot">
              <span class="gtj__cta">
                Read the guide <span aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <a class="gtj__viewall" href="/cheat-sheets">
      View all cheat sheets <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  .gtj {
    padding: 32px 0;
    border-top: var(--border-ink);
  }
  .gtj__inner {
    padding: 0 var(--gutter-mobile);
  }

  /* ---- Head ---- */

  .gtj__head {
    margin-bottom: 22px;
  }
  .gtj__title {
    margin: 0;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 36px;
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--color-ink-black);
  }
  .gtj__sub {
    margin: 10px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.4;
    color: var(--color-ink-60);
  }

  /* ---- Card grid (mobile 1-col, desktop 3-col) ---- */

  .gtj__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  .gtj__grid-item {
    display: flex;
  }

  .gtj__card {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 20px;
    background: var(--color-rice-white);
    border: 1px solid var(--color-concrete-gray);
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    transition: border-color 120ms ease, transform 120ms ease;
  }
  .gtj__card:hover {
    transform: translateY(-2px);
    border-color: var(--color-ink-black);
  }
  .gtj__card:focus-visible {
    outline: 2px solid var(--color-ink-black);
    outline-offset: 3px;
  }

  /* ---- Topline: iconwell + category chip (V4 evergreen) ---- */

  .gtj__card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 16px;
  }
  .gtj__iconwell {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-ink-15);
    border: 1px solid var(--color-concrete-gray);
    border-radius: 4px;
    color: var(--color-ink-black);
  }
  .gtj__cat {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    padding: 4px 8px;
    border: 1px solid var(--color-ink-black);
    border-radius: 2px;
  }

  /* ---- Single numeral — small mono label between topline and title ---- */

  .gtj__card-num {
    display: block;
    margin: 0 0 4px;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--color-ink-60);
  }

  /* ---- Title + lede ---- */

  .gtj__name {
    margin: 0 0 7px;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 19px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink-black);
  }
  .gtj__detail {
    margin: 0 0 16px;
    flex: 1;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-ink-black);
  }

  /* ---- Footer ---- */

  .gtj__card-foot {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-top: 12px;
    border-top: 1px solid var(--color-concrete-gray);
  }
  .gtj__cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 13px;
    padding-bottom: 1px;
    border-bottom: 1.5px solid var(--color-ink-black);
    color: var(--color-ink-black);
  }

  /* Touch devices: drop hover lift, swap for press state. */
  @media (hover: none) {
    .gtj__card:hover {
      transform: none;
    }
    .gtj__card:active {
      transform: translateY(1px);
      border-color: var(--color-ink-black);
    }
  }

  /* ---- View all footer link ---- */

  .gtj__viewall {
    display: inline-block;
    margin-top: 24px;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    text-decoration: none;
    border-bottom: 1px solid var(--color-concrete-gray);
    padding-bottom: 2px;
  }
  .gtj__viewall:hover,
  .gtj__viewall:focus-visible {
    border-bottom-color: var(--color-ink-black);
  }

  @media (min-width: 1024px) {
    .gtj {
      padding: 72px 0;
    }
    .gtj__inner {
      max-width: var(--content-max);
      margin: 0 auto;
      padding: 0 var(--gutter-desktop);
    }

    .gtj__head {
      margin-bottom: 36px;
    }
    .gtj__title {
      font-size: 64px;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .gtj__sub {
      margin-top: 16px;
      font-size: 19px;
    }

    .gtj__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .gtj__card {
      padding: 22px;
      min-height: 220px;
    }
    .gtj__name {
      font-size: 20px;
    }

    .gtj__viewall {
      margin-top: 32px;
      font-size: 12px;
    }
  }
</style>
