---
/* "Going to Japan?" — pre-trip section (V2: ordered by lead time).
   Implements docs/build/HANDOFF_going-to-japan.md against the V2 source
   in docs/build/Going_to_Japan_variants_v3.html. Lives on the homepage
   below the hero and on /cheat-sheets (via fluid prop).

   The component owns the order, copy, and lead-time labels — the items
   are hardcoded in V2_ORDERED so the 01–06 numerals carry real meaning
   (longest pre-trip window first, on-arrival last). DO NOT reorder.

   Affiliate URLs are looked up by id from src/data/affiliates.ts so
   that approving a partner is a single-field edit there with no
   component change. Empty URLs render with href="#" and no target/rel —
   the visual placeholder is fine for v1 per the HANDOFF.

   Brand tokens: only --color-rice-white, --color-ink-black,
   --color-concrete-gray, --color-ink-60 from tokens.css. Type stack:
   Space Grotesk 700 (head), Inter 400/700 (body/name), IBM Plex Mono
   500 (numerals, brand, lead chip, CTA). Inter 700 on the item name
   follows the V2 JSX, which the HANDOFF names as visual source of
   truth (the spec's token line lists Inter 400 only; the JSX uses 700
   for the name — resolved in favour of the JSX). */
import { affiliates } from "../data/affiliates";

interface Props {
  /* false (default): self-contained section — content-max width, page
     gutters, top divider — matching other homepage sections.
     true: fills the parent's content box, no divider — for use inside an
     already-constrained column (e.g. the /cheat-sheets index .wrap). */
  fluid?: boolean;
}

const { fluid = false } = Astro.props;

/* Lead-time ordered. DO NOT REORDER — the 01–06 numerals encode the
   real pre-trip chronology. */
const V2_ORDERED = [
  {
    n: "01",
    brand: "SafetyWing",
    name: "Travel insurance",
    detail: "Active before non-refundable bookings.",
    lead: "Before booking",
    affiliateId: "safetywing",
  },
  {
    n: "02",
    brand: "Wise",
    name: "Multi-currency card",
    detail: "Order, receive, activate.",
    lead: "2 weeks ahead",
    affiliateId: "wise",
  },
  {
    n: "03",
    brand: "JRPass.com",
    name: "JR Pass (nationwide)",
    detail: "Buy online, voucher arrives by mail.",
    lead: "1 week ahead",
    affiliateId: "jrpass-nationwide",
  },
  {
    n: "04",
    brand: "Ninja WiFi",
    name: "Pocket WiFi rental",
    detail: "Reserve airport-counter pickup.",
    lead: "3 days ahead",
    affiliateId: "ninja-wifi",
  },
  {
    n: "05",
    brand: "Airalo",
    name: "eSIM for Japan",
    detail: "Install now, activates on landing.",
    lead: "Day before",
    affiliateId: "airalo",
  },
  {
    n: "06",
    brand: "Welcome Suica",
    name: "IC card for tourists",
    detail: "Grab from an airport kiosk.",
    lead: "On arrival",
    affiliateId: "welcome-suica",
  },
];

const urlById = Object.fromEntries(affiliates.map((a) => [a.id, a.url]));
const items = V2_ORDERED.map((it) => ({
  ...it,
  url: urlById[it.affiliateId] || "",
}));
---

<section
  class:list={["gtj", { "gtj--fluid": fluid }]}
  aria-labelledby="gtj-h2"
>
  <div class="gtj__inner">
    <header class="gtj__head">
      <div class="gtj__head-text">
        <h2 id="gtj-h2" class="gtj__title">Going to Japan?</h2>
        <p class="gtj__sub">Sort these before you fly.</p>
      </div>
      <span class="gtj__head-tag" aria-hidden="true">6 items · pre-trip</span>
    </header>

    <p class="gtj__eyebrow" aria-hidden="true">
      Earliest first · ordered by lead time
    </p>

    <ul class="gtj__list">
      {items.map((it) => (
        <li class="gtj__list-item">
          <a
            class="gtj__row"
            href={it.url || "#"}
            target={it.url ? "_blank" : undefined}
            rel={it.url ? "noopener nofollow sponsored" : undefined}
          >
            <span class="gtj__row-num">{it.n}</span>
            <div class="gtj__row-body">
              <div class="gtj__row-meta">
                <span class="gtj__lead">{it.lead}</span>
                <span class="gtj__brand">{it.brand}</span>
              </div>
              <h3 class="gtj__name">{it.name}</h3>
              <p class="gtj__detail">{it.detail}</p>
            </div>
            <span class="gtj__cta">
              Open <span aria-hidden="true">→</span>
            </span>
          </a>
        </li>
      ))}
    </ul>

    <ul class="gtj__grid">
      {items.map((it) => (
        <li class="gtj__grid-item">
          <a
            class="gtj__card"
            href={it.url || "#"}
            target={it.url ? "_blank" : undefined}
            rel={it.url ? "noopener nofollow sponsored" : undefined}
          >
            <div class="gtj__card-head">
              <span class="gtj__num">{it.n}</span>
              <span class="gtj__brand">{it.brand}</span>
            </div>
            <span class="gtj__lead">{it.lead}</span>
            <h3 class="gtj__name">{it.name}</h3>
            <p class="gtj__detail">{it.detail}</p>
            <div class="gtj__card-foot">
              <span class="gtj__cta">
                Open <span aria-hidden="true">→</span>
              </span>
              <span class="gtj__num gtj__num--tail" aria-hidden="true">
                {it.n}
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* Section rhythm + full-bleed top divider mirror the other homepage
     sections (StartHere / CheatSheets): padding 32/72, border-top ink. */
  .gtj {
    padding: 32px 0;
    border-top: var(--border-ink);
  }
  .gtj__inner {
    padding: 0 var(--gutter-mobile);
  }

  /* Fluid: no own width container or divider — the parent column governs
     width. Vertical margin matches the /cheat-sheets list rhythm. */
  .gtj--fluid {
    padding: 0;
    border-top: 0;
    margin: 32px 0 0;
  }
  .gtj--fluid .gtj__inner {
    padding: 0;
  }

  /* ---- Head ---- */

  .gtj__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
  }
  .gtj__head-tag {
    display: none; /* desktop-only per V2 source */
  }
  .gtj__title {
    margin: 0;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 36px;
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: var(--color-ink-black);
  }
  .gtj__sub {
    margin: 10px 0 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 15px;
    line-height: 1.4;
    color: var(--color-ink-60);
  }

  /* ---- Eyebrow above the list ---- */

  .gtj__eyebrow {
    margin: 18px 0 14px;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }

  /* ---- Mobile timeline rows (default) ---- */

  .gtj__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--color-concrete-gray);
    border-bottom: none;
    background: var(--color-rice-white);
  }
  .gtj__list-item {
    border-bottom: 1px solid var(--color-concrete-gray);
  }
  .gtj__row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-areas: "num body cta";
    align-items: center;
    gap: 14px;
    padding: 14px 16px;
    text-decoration: none;
    color: inherit;
  }
  .gtj__row-num {
    grid-area: num;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 14px;
    letter-spacing: 0.06em;
    color: var(--color-ink-black);
  }
  .gtj__row-body {
    grid-area: body;
    min-width: 0;
  }
  .gtj__row-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 5px;
    flex-wrap: wrap;
  }
  .gtj__row .gtj__cta {
    grid-area: cta;
    padding-left: 8px;
    font-size: 11px;
  }

  /* ---- Lead chip — bordered concrete pill, mono uppercase ---- */

  .gtj__lead {
    display: inline-block;
    padding: 2px 7px;
    border: 1px solid var(--color-concrete-gray);
    background: var(--color-rice-white);
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-black);
  }

  /* ---- Brand label — mono uppercase, ink-60 ---- */

  .gtj__brand {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }

  /* ---- Item name — Inter 700 (spec component line + V2 JSX) ---- */

  .gtj__name {
    margin: 0 0 2px;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    line-height: 1.2;
    color: var(--color-ink-black);
  }
  .gtj__detail {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 12px;
    line-height: 1.35;
    color: var(--color-ink-60);
  }

  /* ---- CTA — mono uppercase, single verb across all six ---- */

  .gtj__cta {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    white-space: nowrap;
  }

  /* ---- Numeral (desktop card head + tail) ---- */

  .gtj__num {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--color-ink-60);
  }

  /* ---- Desktop grid (hidden on mobile) ---- */

  .gtj__grid {
    display: none;
  }

  /* ---- Border-emphasis hover/focus (mirrors .plc pattern site-wide) ---- */

  .gtj__row:hover,
  .gtj__row:focus-visible,
  .gtj__card:hover,
  .gtj__card:focus-visible {
    outline: none;
  }
  .gtj__list-item:has(.gtj__row:hover),
  .gtj__list-item:has(.gtj__row:focus-visible) {
    background: color-mix(in srgb, var(--color-concrete-gray) 30%, transparent);
  }

  @media (min-width: 1024px) {
    .gtj {
      padding: 72px 0;
    }
    .gtj__inner {
      max-width: var(--content-max);
      margin: 0 auto;
      padding: 0 var(--gutter-desktop);
    }
    .gtj--fluid {
      padding: 0;
      margin: 40px 0 0;
    }
    .gtj--fluid .gtj__inner {
      max-width: none;
      margin: 0;
      padding: 0;
    }

    .gtj__title {
      font-size: 64px;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .gtj__sub {
      margin-top: 16px;
      font-size: 19px;
    }
    .gtj__head-tag {
      display: inline-block;
      flex-shrink: 0;
      font-family: var(--font-mono);
      font-weight: 500;
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-ink-60);
    }
    .gtj__eyebrow {
      margin: 28px 0 18px;
      font-size: 11px;
    }

    /* Hide mobile timeline, show desktop grid. */
    .gtj__list {
      display: none;
    }
    .gtj__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .gtj__grid-item {
      display: flex;
    }

    /* ---- Desktop card ---- */
    .gtj__card {
      display: flex;
      flex-direction: column;
      flex: 1;
      padding: 14px 16px 16px;
      background: var(--color-rice-white);
      border: 1px solid var(--color-concrete-gray);
      text-decoration: none;
      color: inherit;
      transition: border-color 120ms ease-out;
    }
    .gtj__card:hover,
    .gtj__card:focus-visible {
      border-color: var(--color-ink-black);
    }
    .gtj__card-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
    }
    .gtj__card .gtj__brand {
      font-size: 10px;
      letter-spacing: 0.08em;
    }
    .gtj__card .gtj__lead {
      align-self: flex-start;
      margin-top: 14px;
      padding: 3px 8px;
      font-size: 10px;
    }
    .gtj__card .gtj__name {
      margin-top: 10px;
      font-size: 16px;
    }
    .gtj__card .gtj__detail {
      margin-top: 4px;
      font-size: 13px;
      line-height: 1.4;
    }
    .gtj__card-foot {
      margin-top: 16px;
      padding-top: 12px;
      border-top: 1px solid var(--color-concrete-gray);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .gtj__num--tail {
      color: var(--color-ink-60);
    }
  }
</style>
