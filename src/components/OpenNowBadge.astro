---
/* Phase D D1 — open-now badge (BUILD_SPEC_d1_places_api.md).
   Server-renders a neutral skeleton (a faint dot on a reserved line); a
   single delegated client script — Astro hoists and dedupes this module
   script, so it ships once per page no matter how many cards use it —
   derives "Open now / Closed — opens HH:MM / Closed today" from the
   cached Google hours against the current time in Japan.

   The badge renders nothing without hours data (the ~10 /eat rows and
   the one /places row that matched no Google Place degrade silently).
   Brand voice: a flat verdict, no "usually open" hedging. */

interface Props {
  /* 7-day map of [open, close] pairs; an empty day means closed. */
  hours?: Record<string, (string | number)[][]> | null;
}

const { hours } = Astro.props;

/* Normalise to "HH:MM" strings so the client never has to. The YAML
   stores bare HH:MM scalars (read as strings); the number branch only
   guards against a future refresh writing minutes-of-day. */
function toHM(v: string | number): string {
  if (typeof v === "number") {
    const m = ((v % 1440) + 1440) % 1440;
    return (
      String(Math.floor(m / 60)).padStart(2, "0") +
      ":" +
      String(m % 60).padStart(2, "0")
    );
  }
  return v;
}

let normalised: Record<string, string[][]> | null = null;
if (hours && typeof hours === "object") {
  normalised = {};
  for (const [day, intervals] of Object.entries(hours)) {
    normalised[day] = Array.isArray(intervals)
      ? intervals.map((iv) => (Array.isArray(iv) ? iv.map(toHM) : []))
      : [];
  }
}
const hasHours = normalised && Object.keys(normalised).length > 0;
---

{
  hasHours && (
    <span class="onb" data-hours={JSON.stringify(normalised)}>
      <span class="onb-dot" aria-hidden="true" />
      <span class="onb-text" aria-live="polite" />
    </span>
  )
}

<script>
  /* One delegated script for every OpenNowBadge on the page. */
  const DAYS = [
    "sunday",
    "monday",
    "tuesday",
    "wednesday",
    "thursday",
    "friday",
    "saturday",
  ];

  function toMin(s: string): number {
    const i = s.indexOf(":");
    return +s.slice(0, i) * 60 + +s.slice(i + 1);
  }

  function fmt(min: number): string {
    const m = ((min % 1440) + 1440) % 1440;
    return (
      String(Math.floor(m / 60)).padStart(2, "0") +
      ":" +
      String(m % 60).padStart(2, "0")
    );
  }

  /* Current weekday + minutes-past-midnight in Japan, regardless of the
     visitor's own timezone. */
  function jstNow() {
    const parts = new Intl.DateTimeFormat("en-US", {
      timeZone: "Asia/Tokyo",
      weekday: "long",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    }).formatToParts(new Date());
    const get = (t: string) => parts.find((p) => p.type === t)!.value;
    let hour = +get("hour");
    if (hour === 24) hour = 0; // some engines emit "24" at midnight
    return {
      day: get("weekday").toLowerCase(),
      min: hour * 60 + +get("minute"),
    };
  }

  type Verdict =
    | { state: "open" }
    | { state: "closed"; opensAt?: number }
    | null;

  function verdict(
    hours: Record<string, string[][]>,
    day: string,
    nowMin: number,
  ): Verdict {
    const idx = DAYS.indexOf(day);
    /* A session that opened yesterday and runs past midnight. */
    const yesterday = hours[DAYS[(idx + 6) % 7]];
    if (Array.isArray(yesterday)) {
      for (const iv of yesterday) {
        const open = toMin(iv[0]);
        const close = toMin(iv[1]);
        if (close <= open && nowMin < close) return { state: "open" };
      }
    }
    const today = hours[day];
    if (!Array.isArray(today)) return null; // no data → hide the badge
    let nextOpen = Infinity;
    for (const iv of today) {
      const open = toMin(iv[0]);
      let close = toMin(iv[1]);
      if (close <= open) close += 1440; // closes after midnight
      if (nowMin >= open && nowMin < close) return { state: "open" };
      if (open > nowMin && open < nextOpen) nextOpen = open;
    }
    if (nextOpen !== Infinity) return { state: "closed", opensAt: nextOpen };
    return { state: "closed" }; // closed all day, or done for today
  }

  const badges: { el: HTMLElement; text: HTMLElement; hours: any }[] = [];
  for (const el of document.querySelectorAll<HTMLElement>(
    ".onb[data-hours]",
  )) {
    let parsed: any = null;
    try {
      parsed = JSON.parse(el.dataset.hours!);
    } catch {
      /* unparseable — drop it */
    }
    const text = el.querySelector<HTMLElement>(".onb-text");
    if (!parsed || !text) {
      el.remove();
      continue;
    }
    badges.push({ el, text, hours: parsed });
  }

  function render() {
    const { day, min } = jstNow();
    for (const b of badges) {
      const v = verdict(b.hours, day, min);
      if (!v) {
        b.el.hidden = true;
        continue;
      }
      b.el.hidden = false;
      b.el.classList.toggle("onb--open", v.state === "open");
      b.el.classList.toggle("onb--closed", v.state === "closed");
      b.text.textContent =
        v.state === "open"
          ? "Open now"
          : v.opensAt != null
            ? "Closed — opens " + fmt(v.opensAt)
            : "Closed today";
    }
  }

  render();
  /* Keep long-lived pages honest as the day rolls over. */
  setInterval(render, 60000);
</script>

<style>
  .onb {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    min-height: 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1.3;
    color: var(--color-ink-60);
  }
  .onb-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex: none;
    /* Skeleton state — barely-there until the script resolves it. */
    background: var(--color-hair);
  }
  /* Open: green dot, full-ink text — the affirmative state reads loudest. */
  .onb--open {
    color: var(--color-ink-black);
  }
  .onb--open .onb-dot {
    background: var(--color-matcha-green);
  }
  .onb--closed .onb-dot {
    background: var(--color-concrete-gray);
  }
</style>
