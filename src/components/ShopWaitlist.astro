---
/* §04 Shop Waitlist — Kit (ConvertKit) inline form embed.
   The Kit <form>/<script>/<style> are verbatim from the dashboard embed.
   The card chrome (banner, helper) is ours; Kit's form is restyled to match
   the comp via the scoped override sheet below — markup is not modified. */
import Eyebrow from "./Eyebrow.astro";
---

<section id="shop" class="wl" aria-labelledby="wl-h2">
  <div class="wl__inner">
    <div class="wl__text">
      <Eyebrow n={4} title="SHOP" />
      <h2 id="wl-h2" class="wl__h2">Japan Finds Shop —<br />Coming Soon.</h2>
      <p class="wl__body">
        I'm putting together Japanese snacks, tools, design finds, travel items,
        and weirdly useful things people keep asking about.
      </p>
      <p class="wl__body wl__body--dim">
        Some of it is genius. Some of it is ridiculous. That's usually the sweet
        spot.
      </p>
    </div>

    <div class="wl__card">
      <p class="wl__banner">*** WAITLIST · JAPAN FINDS SHOP ***</p>

      <!-- Kit inline form embed — markup verbatim from the Kit dashboard.
           ck.5.js is loaded on first interaction so the third-party request
           (and its cookie) stays off the initial page load. -->
      <script is:inline>
        (function () {
          var done = false;
          var evts = ["pointerdown", "keydown", "touchstart", "focusin"];
          function load() {
            if (done) return;
            done = true;
            evts.forEach(function (e) { window.removeEventListener(e, load); });
            var s = document.createElement("script");
            s.src = "https://f.convertkit.com/ckjs/ck.5.js";
            document.head.appendChild(s);
          }
          evts.forEach(function (e) {
            window.addEventListener(e, load, { once: true, passive: true });
          });
        })();
      </script>
      <form action="https://app.kit.com/forms/9161817/subscriptions" class="seva-form formkit-form" method="post" data-sv-form="9161817" data-uid="0c7863c4c1" data-format="inline" data-version="5" data-options="{&quot;settings&quot;:{&quot;after_subscribe&quot;:{&quot;action&quot;:&quot;message&quot;,&quot;success_message&quot;:&quot;You're subscribed&quot;,&quot;redirect_url&quot;:&quot;&quot;},&quot;analytics&quot;:{&quot;google&quot;:null,&quot;fathom&quot;:null,&quot;facebook&quot;:null,&quot;segment&quot;:null,&quot;pinterest&quot;:null,&quot;sparkloop&quot;:null,&quot;googletagmanager&quot;:null},&quot;modal&quot;:{&quot;trigger&quot;:&quot;timer&quot;,&quot;scroll_percentage&quot;:null,&quot;timer&quot;:5,&quot;devices&quot;:&quot;all&quot;,&quot;show_once_every&quot;:15},&quot;powered_by&quot;:{&quot;show&quot;:true,&quot;url&quot;:&quot;https://kit.com/features/forms?utm_campaign=poweredby&amp;utm_content=form&amp;utm_medium=referral&amp;utm_source=dynamic&quot;},&quot;recaptcha&quot;:{&quot;enabled&quot;:false},&quot;return_visitor&quot;:{&quot;action&quot;:&quot;show&quot;,&quot;custom_content&quot;:&quot;&quot;},&quot;slide_in&quot;:{&quot;display_in&quot;:&quot;bottom_right&quot;,&quot;trigger&quot;:&quot;timer&quot;,&quot;scroll_percentage&quot;:null,&quot;timer&quot;:5,&quot;devices&quot;:&quot;all&quot;,&quot;show_once_every&quot;:15},&quot;sticky_bar&quot;:{&quot;display_in&quot;:&quot;top&quot;,&quot;trigger&quot;:&quot;timer&quot;,&quot;scroll_percentage&quot;:null,&quot;timer&quot;:5,&quot;devices&quot;:&quot;all&quot;,&quot;show_once_every&quot;:15}},&quot;version&quot;:&quot;5&quot;}" min-width="400 500 600 700 800"><div data-style="clean"><ul class="formkit-alert formkit-alert-error" data-element="errors" data-group="alert"></ul><div data-element="fields" data-stacked="false" class="seva-fields formkit-fields"><div class="formkit-field"><input class="formkit-input" name="email_address" aria-label="Email Address" placeholder="Email Address" required="" type="email" style="color: rgb(0, 0, 0); border-color: rgb(227, 227, 227); border-radius: 4px; font-weight: 400;"></div><button data-element="submit" class="formkit-submit formkit-submit" style="color: rgb(255, 255, 255); background-color: rgb(22, 119, 190); border-radius: 4px; font-weight: 400;"><div class="formkit-spinner"><div></div><div></div><div></div></div><span class="">Subscribe</span></button></div><div class="formkit-powered-by-convertkit-container"><a href="https://kit.com/features/forms?utm_campaign=poweredby&amp;utm_content=form&amp;utm_medium=referral&amp;utm_source=dynamic" data-element="powered-by" class="formkit-powered-by-convertkit" data-variant="dark" target="_blank" rel="nofollow noopener">Built with Kit</a></div></div></form>
      <!-- Restyle the Kit form to the §04 comp. Loaded after Kit's sheet;
           !important overrides Kit's inline styles. Embed markup untouched. -->
      <style is:inline>
        .formkit-form[data-uid="0c7863c4c1"] { max-width: none; }
        .formkit-form[data-uid="0c7863c4c1"] .formkit-input {
          background: #f7f3ea !important;
          border: 1.5px solid #151515 !important;
          border-radius: 6px !important;
          color: #151515 !important;
          font-family: "Inter", system-ui, sans-serif !important;
        }
        .formkit-form[data-uid="0c7863c4c1"] .formkit-input:focus {
          border-color: #151515 !important;
        }
        .formkit-form[data-uid="0c7863c4c1"] .formkit-input:focus-visible {
          outline: 2px solid #ff3b30 !important;
          outline-offset: 2px !important;
        }
        .formkit-form[data-uid="0c7863c4c1"] .formkit-submit {
          background-color: #151515 !important;
          border-radius: 6px !important;
          font-family: "Space Grotesk", system-ui, sans-serif !important;
          font-weight: 700 !important;
        }
        .formkit-form[data-uid="0c7863c4c1"] .formkit-submit:focus-visible {
          outline: 2px solid #ff3b30 !important;
          outline-offset: 2px !important;
        }
        .formkit-form[data-uid="0c7863c4c1"] .formkit-submit > span::after {
          content: " \2192";
        }
        .formkit-form[data-uid="0c7863c4c1"] .formkit-field,
        .formkit-form[data-uid="0c7863c4c1"] .formkit-submit {
          margin-bottom: 12px !important;
        }
        .formkit-form[data-uid="0c7863c4c1"] .formkit-powered-by-convertkit-container {
          margin: 4px 0 0 !important;
        }
      </style>

      <p class="wl__helper">Useful Japan finds and launch updates. No spam.</p>
    </div>
  </div>
</section>

<style>
  .wl {
    padding: 32px 20px 36px;
    background: var(--color-concrete-gray);
  }
  .wl__inner {
    display: flex;
    flex-direction: column;
  }

  .wl__h2 {
    margin-bottom: 12px;
    font-size: 30px;
    line-height: 1.02;
    letter-spacing: -0.02em;
  }
  .wl__body {
    font-size: 14px;
    line-height: 1.55;
  }
  .wl__body + .wl__body {
    margin-top: 14px;
  }
  .wl__body--dim {
    color: var(--color-ink-60);
  }

  .wl__card {
    margin-top: 22px;
    background: #fff;
    border: var(--border-ink);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-md);
    padding: 16px;
  }
  .wl__banner {
    padding-bottom: 10px;
    margin-bottom: 14px;
    border-bottom: var(--border-dash);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
  }
  .wl__helper {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1.5;
    letter-spacing: 0.04em;
    color: var(--color-ink-60);
    text-align: center;
  }

  @media (min-width: 1024px) {
    .wl {
      padding: 72px 0;
    }
    .wl__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
      max-width: var(--content-max);
      margin: 0 auto;
      padding: 0 var(--gutter-desktop);
    }
    .wl__h2 {
      margin-bottom: 18px;
      font-size: 52px;
      line-height: 1;
      letter-spacing: -0.025em;
    }
    .wl__body {
      font-size: 16px;
      line-height: 1.6;
      max-width: 520px;
    }
    .wl__card {
      margin-top: 0;
      padding: 24px;
    }
    .wl__banner {
      padding-bottom: 12px;
      margin-bottom: 18px;
      font-size: 11px;
    }
    .wl__helper {
      margin-top: 6px;
    }
  }
</style>
