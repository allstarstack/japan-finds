---
/* Phase B-1 launch product card with D5b enrichment.
   Mobile-first, text-forward. Adds: enriched description and a hero
   image when one was downloaded (193 of 455 launch products).

   Conservative display (Decision #2 / Yawataya-bug guard):
     display_strategy: show_all                      -> name_en, name_jp, brand
     display_strategy: hide_jp_and_brand_until_enriched -> name_en only
   Creator-fill YAMLs already have name_jp/brand stripped, so this gate is
   defence-in-depth.

   Renders nothing unless status === "ready". Does NOT render
   safety_flags (raw enums violate brand voice — defer until human-readable
   labels exist) or enrichment_confidence/source_url (editorial metadata).

   data-* attributes drive the client-side filter in FilterRail. */
import type { CollectionEntry } from "astro:content";
import { CHIP_LABEL, CHIP_COLOR } from "../../data/launch-chips.js";

interface Props {
  entry: CollectionEntry<"products">;
}

const { entry } = Astro.props;
const d = entry.data;
const visible = d.status === "ready" && !!d.launch_category;

const showAll = d.display_strategy === "show_all";
const meta = showAll
  ? [d.name_jp, d.brand].filter(Boolean).join(" · ")
  : "";
const where = d.where_found?.join(" · ") ?? "";
const cat = d.launch_category;
const label = cat ? CHIP_LABEL[cat] : "";
const color = cat ? CHIP_COLOR[cat] : "white";

const imageUrl = d.image || null;
const description = d.description || d.what_it_is || null;
---

{
  visible && (
    <article
      class="pc"
      data-category={cat}
      data-sub={d.sub_chip ?? ""}
      data-fill={d.fill_type}
    >
      <span class:list={["chip", `chip--${color}`]}>{label}</span>
      {imageUrl && (
        <img src={imageUrl} alt={d.name_en} class="pc-image" loading="lazy" />
      )}
      <h3 class="pc-name">{d.name_en}</h3>
      {meta && <p class="pc-meta">{meta}</p>}
      {description && <p class="pc-description">{description}</p>}
      {where && (
        <p class="pc-where">
          <span class="pc-where-label">Where to buy</span>
          <span class="pc-where-val">{where}</span>
        </p>
      )}
    </article>
  )
}

<style>
  /* Standard launch-card treatment (BUILD_SPEC §Step 3):
     Rice White surface, Ink Black text, Concrete Gray border. */
  .pc {
    display: flex;
    flex-direction: column;
    gap: 8px;
    height: 100%;
    padding: 14px;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-concrete-gray);
    border-radius: var(--radius-card);
  }
  /* The filter rail hides non-matching cards via the `hidden` attribute.
     An author `display` declaration outranks the UA `[hidden]` rule, so
     this must restore `display: none` explicitly or hidden cards stay
     visible (the chip state would update but the grid would not). */
  .pc[hidden] {
    display: none;
  }

  .pc .chip {
    align-self: flex-start;
  }

  /* Hero image bleeds to the card edges (negates padding). Sits between
     the chip and the name. 4:3 keeps thumbnails predictable regardless of
     source aspect — most enrichment images are product shots. */
  .pc-image {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background: var(--color-concrete-gray);
    margin: 0 -14px;
    width: calc(100% + 28px);
  }

  .pc-name {
    margin: 0;
    font-family: var(--font-head);
    font-size: 15px;
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.01em;
  }

  .pc-meta {
    margin: -2px 0 0;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.4;
    color: var(--color-ink-60);
  }

  .pc-description {
    margin: 0;
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-ink-black);
  }

  /* where-to-buy pinned to the card bottom so wrapped names stay aligned */
  .pc-where {
    margin: auto 0 0;
    padding-top: 10px;
    border-top: var(--border-row);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .pc-where-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }
  .pc-where-val {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.4;
  }

  @media (min-width: 1024px) {
    .pc {
      padding: 16px;
    }
    .pc-image {
      margin: 0 -16px 0 -16px;
      width: calc(100% + 32px);
    }
    .pc-name {
      font-size: 16px;
    }
    .pc-description {
      font-size: 14px;
    }
  }
</style>
