---
/* Phase B-2 places filter rail (BUILD_SPEC Step 4).
   - 12 primary chips, single-select, horizontal-scroll, sticky-on-scroll.
   - 3 planning chips (Rainy Day / With Kids / By Train), multi-select,
     always visible below the primary rail; they combine with any chip.
   - "Stay bases" toggle — base-tier places are excluded from the default
     browse and from every chip; this reveals the 23 stay-base entries.

   Filtering is client-side and in place. Chip state mirrors to the URL
   (?chip=&flags=&base=) for shareable links. Counts and the empty state
   live on /places; this component drives them by data-attribute. */
import { PRIMARY_CHIPS, SECONDARY_CHIPS } from "../../data/place-chips.js";

interface Props {
  counts: Record<string, number>; // public_label -> standard-tier count
  flagCounts: Record<string, number>; // planning flag -> count
  baseCount: number;
}
const { counts, flagCounts, baseCount } = Astro.props;
---

<div class="prail" data-place-rail>
  <div class="prail-inner">
    <div class="prail-track" role="group" aria-label="Filter places by type">
      {
        PRIMARY_CHIPS.map((c) => (
          <button
            type="button"
            class="pchip"
            data-chip={c.value}
            data-color={c.color}
            aria-pressed="false"
          >
            {c.label}
            <span class="pchip-n">{counts[c.value] ?? 0}</span>
          </button>
        ))
      }
    </div>
    <p class="prail-hint" data-rail-hint aria-hidden="true">{PRIMARY_CHIPS.length} categories · scroll →</p>

    <div class="psec" role="group" aria-label="Filter by planning need">
      {
        SECONDARY_CHIPS.map((c) => (
          <button
            type="button"
            class="pflag"
            data-flag={c.value}
            aria-pressed="false"
          >
            {c.label}
            <span class="pflag-n">{flagCounts[c.value] ?? 0}</span>
          </button>
        ))
      }
      {
        baseCount > 0 && (
          <button
            type="button"
            class="pflag pflag--base"
            data-base-toggle
            aria-pressed="false"
          >
            Stay bases
            <span class="pflag-n">{baseCount}</span>
          </button>
        )
      }
    </div>
  </div>
</div>

<style>
  /* Phase D D6: sticky + bottom ink border moved up to the .rail-sticky
     wrapper in /places so the location row and this row stick as a unit. */
  .prail {
    background: var(--color-white);
  }
  .prail-inner {
    max-width: var(--content-max);
    margin: 0 auto;
  }

  /* Primary chips — horizontal-scroll on mobile, no visible scrollbar. */
  .prail-track {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    padding: 12px var(--gutter-mobile) 8px;
    scroll-padding-inline: var(--gutter-mobile);
  }
  .prail-track::-webkit-scrollbar {
    display: none;
  }

  /* Mobile-only overflow hint — sits beneath the scrolling primary chip
     row so users see how many categories exist off-screen. Hidden on
     desktop, where all chips wrap into view. */
  .prail-hint {
    margin: 0;
    padding: 0 var(--gutter-mobile) 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--color-ink-60);
  }

  .pchip {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 38px;
    padding: 8px 14px;
    background: transparent;
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--color-ink-black);
    transition: background-color 120ms ease-out, color 120ms ease-out;
  }
  .pchip[data-color="red"] {
    --c: var(--color-tokyo-red);
  }
  .pchip[data-color="blue"] {
    --c: var(--color-konbini-blue);
  }
  .pchip[data-color="green"] {
    --c: var(--color-matcha-green);
  }
  .pchip[data-color="yellow"] {
    --c: var(--color-egg-yellow);
  }
  .pchip-n {
    font-weight: 700;
  }
  /* The script hides zero-count pills via the `hidden` attribute; the
     base `display` rules above outrank the UA [hidden] rule, so restore
     it (same pattern as .plc[hidden] in PlaceCard). */
  .pchip[hidden],
  .pflag[hidden] {
    display: none;
  }
  .pchip.is-active {
    background: var(--c);
    border-color: var(--c);
    color: #fff;
  }
  .pchip[data-color="yellow"].is-active {
    color: var(--color-ink-black);
  }

  /* Planning chips + base toggle — wrap, always visible. */
  .psec {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0 var(--gutter-mobile) 12px;
  }
  .pflag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 32px;
    padding: 6px 12px;
    background: transparent;
    border: 1.5px solid var(--color-ink-30);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    transition: background-color 120ms ease-out, color 120ms ease-out;
  }
  .pflag-n {
    font-weight: 700;
  }
  .pflag.is-active {
    background: var(--color-ink-black);
    border-color: var(--color-ink-black);
    color: #fff;
  }
  /* Base toggle reads as a distinct affordance — dashed until active. */
  .pflag--base {
    margin-left: auto;
    border-style: dashed;
    border-color: var(--color-ink-black);
  }

  @media (min-width: 1024px) {
    .prail-track {
      flex-wrap: wrap;
      overflow-x: visible;
      padding: 16px var(--gutter-desktop) 10px;
    }
    .prail-hint {
      display: none;
    }
    .psec {
      padding: 0 var(--gutter-desktop) 16px;
    }
  }
</style>

<script>
  const rail = document.querySelector("[data-place-rail]");
  if (rail) {
    const chips = [...rail.querySelectorAll(".pchip")];
    const flags = [...rail.querySelectorAll(".pflag[data-flag]")];
    const baseBtn = rail.querySelector("[data-base-toggle]");
    const railHint = rail.querySelector("[data-rail-hint]");
    /* Phase D D6 — location chips live in a sibling LocationChipRow inside
       the shared .rail-sticky wrapper, not in [data-place-rail], so we
       query at document level. The data-location-chip="" button is the
       "All Japan" default; selecting it clears the location filter. */
    const locationBtns = [
      ...document.querySelectorAll(
        "[data-location-row] [data-location-chip]",
      ),
    ];
    const cards = [...document.querySelectorAll("[data-grid] .plc")];
    const grid = document.querySelector("[data-grid]");
    const countEl = document.querySelector("[data-count]");
    const emptyEl = document.querySelector("[data-empty]");
    // "Six to start with" strip — hidden while a filter is active so the
    // page unambiguously reflects the filter (the strip never filters).
    const featuredEl = document.querySelector("[data-featured]");
    const searchInput = document.querySelector("[data-search-input]");

    const validLocations = new Set(
      locationBtns.map((b) => b.dataset.locationChip || "").filter(Boolean),
    );

    let activeLocation = null;
    let activeChip = null;
    const activeFlags = new Set();
    let showBase = false;
    let query = "";

    const splitFlags = (s) =>
      (s || "")
        .split(";")
        .map((x) => x.trim())
        .filter(Boolean);

    /* One descriptor per card so the grid-visibility pass and every
       per-pill count read the same precomputed fields. */
    const cardData = cards.map((el) => ({
      el,
      isBase: el.dataset.tier === "base",
      chip: el.dataset.chip || "",
      region: el.dataset.region || "",
      flags: splitFlags(el.dataset.flags),
      search: el.dataset.search || "",
    }));

    /* Single matching predicate — drives both the visible grid and every
       facet count, so a pill's number always equals the rows you get after
       clicking it (no label-vs-result drift). Mirrors the chip / base /
       flag / location / search rules exactly. */
    const matches = (c, { location, chip, flagSet, base, tokens }) => {
      if (!tokens.every((t) => c.search.includes(t))) return false;
      const okFlags = [...flagSet].every((f) => c.flags.includes(f));
      const okLocation = !location || c.region === location;
      if (c.isBase)
        return (base || tokens.length > 0) && !chip && okFlags && okLocation;
      return (!chip || c.chip === chip) && okFlags && okLocation;
    };

    /* replaceState (not pushState) matches the rest of this rail's
       convention — selecting filter chips updates the URL in place rather
       than spawning history entries the user has to back through. The
       shareable-URL criterion still holds (read on init + popstate). */
    const syncURL = () => {
      const p = new URLSearchParams();
      if (activeLocation) p.set("region", activeLocation);
      if (activeChip) p.set("chip", activeChip);
      if (activeFlags.size) p.set("flags", [...activeFlags].join(","));
      if (showBase) p.set("base", "1");
      const qs = p.toString();
      history.replaceState(null, "", qs ? "?" + qs : location.pathname);
    };

    const apply = () => {
      // Token-AND substring search over each card's data-search blob. An
      // active query also reveals base-tier cards — otherwise searching a
      // stay-base by name would silently miss it, and "Search 333 places"
      // would overstate what's findable.
      const tokens = query.split(/\s+/).filter(Boolean);
      const state = {
        location: activeLocation,
        chip: activeChip,
        flagSet: activeFlags,
        base: showBase,
        tokens,
      };

      // Grid visibility + result count.
      let n = 0;
      for (const c of cardData) {
        const show = matches(c, state);
        c.el.hidden = !show;
        if (show) n++;
      }

      // Location (region) chips keep their static build-time counts — only
      // their pressed state updates here.
      for (const b of locationBtns) {
        const v = b.dataset.locationChip || "";
        const on = v === (activeLocation ?? "");
        b.setAttribute("aria-pressed", String(on));
        b.classList.toggle("is-active", on);
      }

      // Category chips — region-scoped counts. Each chip's number is "how
      // many rows if THIS chip were the active category" under the current
      // region / flags / search. Single-select, so we swap this chip in
      // rather than add it. A zero-count chip is hidden so no click can
      // land on an empty result; the active chip stays visible so it can be
      // toggled off even at zero.
      let visibleChips = 0;
      for (const chip of chips) {
        const v = chip.dataset.chip;
        const count = cardData.reduce(
          (a, c) => a + (matches(c, { ...state, chip: v }) ? 1 : 0),
          0,
        );
        const nEl = chip.querySelector(".pchip-n");
        if (nEl) nEl.textContent = String(count);
        const on = v === activeChip;
        const hide = count === 0 && !on;
        chip.hidden = hide;
        if (!hide) visibleChips++;
        chip.setAttribute("aria-pressed", String(on));
        chip.classList.toggle("is-active", on);
      }
      if (railHint)
        railHint.textContent = visibleChips + " categories · scroll →";

      // Planning flags — multi-select, so a flag's count is "how many rows
      // if this flag were ALSO on" (union with the active flags) under the
      // current region / chip / search. Same hide-on-zero rule.
      for (const f of flags) {
        const v = f.dataset.flag;
        const count = cardData.reduce(
          (a, c) =>
            a +
            (matches(c, { ...state, flagSet: new Set([...activeFlags, v]) })
              ? 1
              : 0),
          0,
        );
        const nEl = f.querySelector(".pflag-n");
        if (nEl) nEl.textContent = String(count);
        const on = activeFlags.has(v);
        f.hidden = count === 0 && !on;
        f.setAttribute("aria-pressed", String(on));
        f.classList.toggle("is-active", on);
      }

      // Stay-bases toggle — count is the base-tier rows in the current
      // region / flags / search. Clicking it clears any active chip, so the
      // chip is ignored when counting. Hidden at zero unless already on.
      if (baseBtn) {
        const count = cardData.reduce(
          (a, c) =>
            a +
            (c.isBase && matches(c, { ...state, chip: null, base: true })
              ? 1
              : 0),
          0,
        );
        const nEl = baseBtn.querySelector(".pflag-n");
        if (nEl) nEl.textContent = String(count);
        baseBtn.hidden = count === 0 && !showBase;
        baseBtn.setAttribute("aria-pressed", String(showBase));
        baseBtn.classList.toggle("is-active", showBase);
      }

      if (countEl) countEl.textContent = n + (n === 1 ? " place" : " places");
      if (emptyEl) emptyEl.hidden = n !== 0;
      if (grid) grid.hidden = n === 0;
      const filtering =
        !!activeLocation ||
        !!activeChip ||
        activeFlags.size > 0 ||
        showBase ||
        tokens.length > 0;
      if (featuredEl) featuredEl.hidden = filtering;
    };

    /* Sync filter state from the URL. Called on initial load and on
       popstate (browser back/forward) so URL changes from any source
       re-apply. Unknown slugs are silently ignored — no console warning. */
    const readURL = () => {
      activeLocation = null;
      activeChip = null;
      activeFlags.clear();
      showBase = false;
      const params = new URLSearchParams(location.search);
      const region = params.get("region");
      if (region && validLocations.has(region)) activeLocation = region;
      const chip0 = params.get("chip");
      if (chip0 && chips.some((c) => c.dataset.chip === chip0))
        activeChip = chip0;
      for (const f of (params.get("flags") || "").split(",").filter(Boolean))
        if (flags.some((x) => x.dataset.flag === f)) activeFlags.add(f);
      if (params.get("base") === "1" && !activeChip) showBase = true;
    };

    // Search is ephemeral (not mirrored to the URL like the chips) — it
    // filters the in-page grid as you type.
    if (searchInput) {
      searchInput.addEventListener("input", () => {
        query = searchInput.value.trim().toLowerCase();
        apply();
      });
    }

    locationBtns.forEach((b) =>
      b.addEventListener("click", () => {
        const v = b.dataset.locationChip || "";
        // Single-select. Re-tapping the active chip clears it; tapping
        // the All Japan chip (slug "") explicitly does the same.
        activeLocation = v && v !== activeLocation ? v : null;
        apply();
        syncURL();
        b.scrollIntoView({ inline: "center", block: "nearest" });
      }),
    );
    chips.forEach((c) =>
      c.addEventListener("click", () => {
        activeChip = activeChip === c.dataset.chip ? null : c.dataset.chip;
        if (activeChip) showBase = false; // a chip and bases are exclusive
        apply();
        syncURL();
        c.scrollIntoView({ inline: "center", block: "nearest" });
      }),
    );
    flags.forEach((f) =>
      f.addEventListener("click", () => {
        const v = f.dataset.flag;
        activeFlags.has(v) ? activeFlags.delete(v) : activeFlags.add(v);
        apply();
        syncURL();
      }),
    );
    if (baseBtn)
      baseBtn.addEventListener("click", () => {
        showBase = !showBase;
        if (showBase) activeChip = null;
        apply();
        syncURL();
      });

    /* Re-apply filter state when the URL changes via browser navigation
       (back/forward) — keeps the rail and the URL coherent. */
    window.addEventListener("popstate", () => {
      readURL();
      apply();
    });

    readURL();
    apply();
  }
</script>
