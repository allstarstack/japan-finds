---
/* Phase B-2 place card (Phase D D1 photos; live "open now" removed 2026-05-24).
   Mobile-first, text-forward. The card leads with a Google hero photo
   (Phase D D1); the 4 rows with no photo fall back to a solid
   colour-block placeholder keyed to primary_category — not faked or
   AI imagery (brand.md).

   Renders nothing unless status === "ready" && public_render.
   Does NOT render planning_flags or any internal field — those are
   filter-only (BUILD_SPEC Step 5). The exceptions are `local_favorite`
   and `viral`, which surface as small badges overlaying the hero media.
   Live "open now" status was dropped in the 2026-05-24 cost kill —
   cached hours go stale, and the Maps link below carries users to
   current hours (BUILD_SPEC_cost_kill.md).

   data-* attributes drive the client-side filter in PlaceFilterRail.
   `data-flags` synthesises planning_flags + local_favorite + viral into
   one semicolon-separated string so the rail's existing multi-select
   filter handles all three sources uniformly. Base-tier cards render
   with `hidden` — they are excluded from the default browse and are
   reachable only by name search (the "Stay bases" toggle was removed). */
import type { CollectionEntry } from "astro:content";
import { CAT_COLOR, PRIMARY_CHIPS } from "../../data/place-chips.js";
import { prefectureToRegion } from "../../data/regions.js";

interface Props {
  entry: CollectionEntry<"places">;
}

const { entry } = Astro.props;
const d = entry.data;
const visible = d.status === "ready" && d.public_render !== false;

/* Split an embedded Japanese name out of the `name` field: a parenthetical
   containing CJK is the JP name; a romaji/descriptor parenthetical stays
   in the English name. */
function splitName(name) {
  // CJK ranges: hiragana, katakana, ideographs, half-width katakana.
  const m = name.match(
    /\(([^)]*[぀-ヿ㐀-鿿ｦ-ﾟ][^)]*)\)/,
  );
  if (!m) return { en: name, jp: "" };
  const en = name
    .replace(m[0], "")
    .replace(/\s{2,}/g, " ")
    .replace(/[\s–—-]+$/, "")
    .trim();
  return { en: en || name, jp: m[1].trim() };
}

const { en, jp } = splitName(d.name);
const cat = d.primary_category;
const color = CAT_COLOR[cat];
const isBase = d.launch_tier === "base";

/* Compose the filterable flag string. Synthesises planning_flags (the
   semicolon-separated string source) with the boolean badge fields so
   the rail filters all of them through one mechanism. */
const flagString = [
  d.planning_flags ?? "",
  d.local_favorite ? "local_favorite" : "",
  d.viral ? "viral" : "",
]
  .filter(Boolean)
  .join(";");

/* Phase D D6 — region derived at build time from prefecture via the JNTO
   lookup. Stamped as data-region for the LocationChipRow filter; an empty
   string means no mapping was found, and the orphan check in pre-launch
   hygiene guarantees that never happens on a `ready` row. */
const regionSlug = prefectureToRegion(d.prefecture) ?? "";

/* Badge label. Looks up the specific chip label from PRIMARY_CHIPS
   (single source of truth — same labels the filter rail uses), so a
   `cafes` place reads "Cafes" and a `food_markets` place reads "Food
   Markets" rather than both collapsing to a generic "Eat". Falls back
   to the bare primary_category for base-tier rows where public_label
   is "" (no chip in PRIMARY_CHIPS). */
const chipMeta = PRIMARY_CHIPS.find((c) => c.value === d.public_label);
const catLabel = chipMeta?.label ?? cat;

/* Phase D D1 — link straight to the matched place via place_id. The
   old name-search URL (which let Google's geocoder find an area-level
   pin) is the fallback for the one row that matched no Google Place. */
const mapsUrl = d.place_id
  ? `https://www.google.com/maps/place/?q=place_id:${d.place_id}`
  : "https://www.google.com/maps/search/?api=1&query=" +
    encodeURIComponent(`${en}, ${d.prefecture}`);

/* SEARCH_AND_SORT Phase B — searchable text blob the place filter script
   matches against: name (en + jp), category label, the experience chip,
   and location (prefecture / region / area) so "onsen", "Oita", "Kyushu"
   and a place name all resolve. planning_flags stay out — they're
   filter-only and never rendered. Lowercased once here. */
const searchText = [
  en,
  jp,
  catLabel,
  d.public_label,
  d.prefecture,
  regionSlug,
  d.address_or_area,
]
  .filter(Boolean)
  .join(" ")
  .toLowerCase();
---

{
  visible && (
    <article
      class="plc"
      data-slug={entry.id}
      data-chip={d.public_label ?? ""}
      data-flags={flagString}
      data-region={regionSlug}
      data-tier={d.launch_tier}
      data-search={searchText}
      hidden={isBase}
    >
      <div class="plc-media">
        {d.hero_image ? (
          <img
            class="plc-img"
            src={d.hero_image}
            alt=""
            loading="lazy"
            width="900"
            height="600"
          />
        ) : (
          <div class:list={["plc-block", `plc-block--${color}`]} aria-hidden="true" />
        )}
        {(d.local_favorite || d.viral) && (
          <div class="plc-badges">
            {d.local_favorite && (
              <span class="plc-badge plc-badge--local">Local</span>
            )}
            {d.viral && <span class="plc-badge plc-badge--viral">Viral</span>}
          </div>
        )}
        {d.hero_attribution && <span class="plc-attr">{d.hero_attribution}</span>}
      </div>
      <div class="plc-body">
        <span class:list={["chip", `chip--${color}`]}>{catLabel}</span>
        <h3 class="plc-name">{en}</h3>
        {jp && <p class="plc-jp">{jp}</p>}
        <p class="plc-area">{d.address_or_area}</p>
        <a class="plc-map" href={mapsUrl} target="_blank" rel="noopener">
          View on Google Maps&nbsp;→
        </a>
      </div>
    </article>
  )
}

<style>
  .plc {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-concrete-gray);
    border-radius: var(--radius-card);
    overflow: hidden;
    transition: border-color 120ms ease-out;
  }
  /* The filter rail toggles cards via the `hidden` attribute; an author
     `display` declaration outranks the UA [hidden] rule, so restore it. */
  .plc[hidden] {
    display: none;
  }
  /* Hover: border emphasis only — no shadow gimmicks (BUILD_SPEC Step 5). */
  .plc:hover,
  .plc:focus-within {
    border-color: var(--color-ink-black);
  }

  /* Hero media — a 3:2 Google photo, or the colour-block fallback.
     position: relative anchors the attribution overlay. overflow: hidden
     locks the box to 3:2 regardless of the source photo's dimensions —
     without it a tall/wide image's intrinsic size expands the box. */
  .plc-media {
    position: relative;
    aspect-ratio: 3 / 2;
    width: 100%;
    overflow: hidden;
  }
  .plc-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  /* Photo credit — overlaid bottom-right on a near-white chip so the
     ink-60 caption clears against any photo (Phase D D1). */
  .plc-attr {
    position: absolute;
    right: 6px;
    bottom: 6px;
    padding: 1px 5px;
    background: rgba(255, 255, 255, 0.9);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 11px;
    line-height: 1.3;
    color: var(--color-ink-60);
    pointer-events: none;
  }

  /* Local-favorite + Viral badges — overlay top-left of the hero media.
     Colour treatment mirrors the existing .chip--green / .chip--red
     pattern in global.css: darkened Matcha Green #3f7548 with white text
     (5.4:1) and Tokyo Red with ink-black text (5.59:1) — both AA. The
     raw --color-matcha-green token fails AA with either text colour. */
  .plc-badges {
    position: absolute;
    left: 6px;
    top: 6px;
    display: flex;
    gap: 4px;
    pointer-events: none;
  }
  .plc-badge {
    padding: 2px 6px;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: var(--radius-sm);
  }
  .plc-badge--local {
    background: #3f7548;
    color: #fff;
  }
  .plc-badge--viral {
    background: var(--color-tokyo-red);
    color: var(--color-ink-black);
  }

  /* Colour-block placeholder — keyed to primary_category. Fills the
     3:2 media box when no hero photo exists. */
  .plc-block {
    width: 100%;
    height: 100%;
  }
  .plc-block--green {
    background: var(--color-matcha-green);
  }
  .plc-block--red {
    background: var(--color-tokyo-red);
  }
  .plc-block--yellow {
    background: var(--color-egg-yellow);
  }
  .plc-block--blue {
    background: var(--color-konbini-blue);
  }

  .plc-body {
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex: 1;
    padding: 12px;
  }

  .plc .chip {
    align-self: flex-start;
  }

  .plc-name {
    margin: 3px 0 0;
    font-family: var(--font-head);
    font-size: 15px;
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.01em;
  }
  .plc-jp {
    margin: 0;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.4;
    color: var(--color-ink-60);
  }
  .plc-area {
    margin: 0;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.4;
    color: var(--color-ink-60);
  }

  /* Maps link pinned to the card bottom so wrapped names stay aligned. */
  .plc-map {
    margin: auto 0 0;
    padding-top: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ink-black);
    text-decoration: none;
  }
  .plc-map:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (min-width: 1024px) {
    .plc-body {
      padding: 14px;
    }
    .plc-name {
      font-size: 16px;
    }
  }
</style>
