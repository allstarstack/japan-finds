---
/* V2 RouteCard — Phase A scaffold.
   Unstyled inspection markup; Phase B replaces it with the comp design.
   Public render gate: renders nothing unless status === "ready". */
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"routes">;
}

const { entry } = Astro.props;
const d = entry.data;
const visible = d.status === "ready";

const rows: [string, string][] = [
  ["route type", d.route_type],
  ["stops", String(d.stops?.length ?? 0)],
];
const shown = d.duration_note
  ? [...rows, ["duration", d.duration_note] as [string, string]]
  : rows;
---

{
  visible && (
    <article class="v2-card">
      <h3>{d.name_en}</h3>
      <dl>
        {shown.map(([k, v]) => (
          <>
            <dt>{k}</dt>
            <dd>{v}</dd>
          </>
        ))}
      </dl>
    </article>
  )
}

<style>
  .v2-card {
    border: 1px solid var(--color-ink-black);
    padding: 12px 16px;
    margin-bottom: 8px;
    font-family: var(--font-body);
    font-size: 14px;
  }
  .v2-card h3 {
    margin: 0 0 8px;
    font-family: var(--font-head);
    font-size: 16px;
  }
  dl {
    margin: 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 2px 12px;
  }
  dt {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }
  dd {
    margin: 0;
  }
</style>
