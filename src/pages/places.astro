---
/* /places — Phase B-2 places import ("Where" in the nav).
   Hero, sticky filter rail, and the full place grid. Mirrors the other
   list pages (/eat, /stay, /products) for cross-page consistency: hero →
   search → chips → grid, no featured-six block. Sort: newest-first by
   `id` (jf-place-####), matching /products' newest-first behaviour
   (PLACES_ADD_SIGNAL_BUILD_SPEC). Baseline ids assigned via git
   first-add-date asc + filename asc, so a desc id sort = newest batch
   first within today's data. */
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";
import PlaceCard from "../components/v2/PlaceCard.astro";
import PlaceFilterRail from "../components/v2/PlaceFilterRail.astro";
import LocationChipRow from "../components/v2/LocationChipRow.astro";
import SearchBox from "../components/v2/SearchBox.astro";
import MapView from "../components/v2/MapView.astro";
import { prefectureToRegion, REGION_LABELS } from "../data/regions.js";

const places = (await getCollection("places")).filter(
  (p) => p.data.status === "ready" && p.data.public_render !== false,
);
/* Trailing-digit extractor keeps the comparator scheme-agnostic — works
   for jf-place-#### today, would survive an id-prefix rename. Alpha is a
   defensive tiebreak (ids are unique). */
const idNum = (e) =>
  parseInt(String(e.data.id).match(/(\d+)$/)?.[1] ?? "0", 10);
places.sort(
  (a, b) =>
    idNum(b) - idNum(a) ||
    a.data.name.toLowerCase().localeCompare(b.data.name.toLowerCase()),
);

/* Standard-tier places are the default browse; base-tier are reachable
   only by name search (the "Stay bases" toggle was removed). The
   launch_tier enum keeps "base" so base-tier rows can return without a
   schema change. */
const standard = places.filter((p) => p.data.launch_tier !== "base");
const total = standard.length;

/* Per-chip counts (standard tier) for the primary rail. */
const counts: Record<string, number> = {};
for (const p of standard) {
  const c = p.data.public_label;
  if (c) counts[c] = (counts[c] ?? 0) + 1;
}

/* Per-flag counts for the secondary rail. Mixes planning_flags (the
   semicolon-separated string source) with local_favorite + viral (the
   boolean badge fields) — both surface as filter chips, so the counts
   must include both. Mirrors the data-flags synthesis in PlaceCard. */
const flagCounts: Record<string, number> = {};
for (const p of standard) {
  const flags = [
    ...(p.data.planning_flags ?? "")
      .split(";")
      .map((s) => s.trim())
      .filter(Boolean),
    ...(p.data.local_favorite ? ["local_favorite"] : []),
    ...(p.data.viral ? ["viral"] : []),
  ];
  for (const f of flags) flagCounts[f] = (flagCounts[f] ?? 0) + 1;
}

/* Phase D D6 — per-region counts for the LocationChipRow. Derived from
   prefecture via the JNTO lookup; multi-prefecture rows credit only the
   first prefecture (matches the filter logic in PlaceCard's data-region).
   Counts are computed on `standard` only — base-tier places are excluded
   from the default browse, so they must also be excluded from the chip
   labels or the label-vs-visible-row count would drift. */
const regionCounts: Record<string, number> = {};
for (const p of standard) {
  const r = prefectureToRegion(p.data.prefecture);
  if (r) regionCounts[r] = (regionCounts[r] ?? 0) + 1;
}

const regionChips = Object.entries(REGION_LABELS)
  .map(([slug, label]) => ({ slug, label, count: regionCounts[slug] ?? 0 }))
  .filter((c) => c.count > 0);
---

<Base
  title="Where to go in Japan — Japan Finds"
  description="Hundreds of places to visit in Japan — nature, food markets, museums, onsen and more. Filter by what you want to see, then take the map with you."
>
  <Header />
  <main id="main">
    <section class="phero">
      <div class="wrap">
        <p class="eyebrow">JAPAN FINDS · WHERE TO GO</p>
        <h1>Where to actually go in Japan.</h1>
        <p class="phero-sub">
          {total} places, Hokkaido to Okinawa — nature, food markets, museums,
          onsen and more. Filter to what you want to see.
        </p>
      </div>
    </section>

    <div class="rail-sticky">
      <SearchBox placeholder="Search 333 places" />
      <LocationChipRow chips={regionChips} hintLabel="regions" />
      <PlaceFilterRail counts={counts} flagCounts={flagCounts} />
    </div>

    <section class="presults">
      <div class="wrap">
        <div class="presults-bar">
          <h2 class="results-count" data-count>{total} places</h2>
          <div
            class="view-toggle"
            role="group"
            aria-label="Toggle list or map view"
            data-view-toggle
          >
            <button type="button" data-view-btn="list" aria-pressed="true">List</button>
            <button type="button" data-view-btn="map" aria-pressed="false">Map</button>
          </div>
        </div>
        <p class="xlink">Looking for restaurants? <a href="/eat">See → /eat</a></p>
        <div data-list-section>
          <div class="grid" data-grid>
            {places.map((p) => <PlaceCard entry={p} />)}
          </div>
          <p class="results-empty" data-empty hidden>
            Nothing matches. Try a place name or region.
          </p>
        </div>
      </div>
    </section>

    <section class="presults-map" data-map-section hidden>
      <MapView
        containerId="places-map"
        sourceFilter="places"
        filterEventName="places:filter-changed"
        height="78vh"
        showLegend={true}
        legendKind="places"
      />
    </section>
  </main>
  <SiteFooter />
</Base>

<style>
  .wrap {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 var(--gutter-mobile);
  }

  /* Filter block wrapper — holds the view toggle, search, and the
     location + primary/planning chip rails as a single unit. Scrolls
     with the page (was previously sticky; the always-pinned footprint
     starved the card grid on mobile). The white surface + ink hairline
     remain as the visual separator between filters and the grid. */
  .rail-sticky {
    background: var(--color-white);
    border-bottom: var(--border-ink);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }

  /* Hero — rice-white, sits on the body background */
  .phero {
    padding: 30px 0 28px;
  }
  .phero h1 {
    margin: 10px 0 0;
    font-family: var(--font-head);
    font-size: 40px;
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.03em;
  }
  .phero-sub {
    margin: 14px 0 0;
    max-width: 36ch;
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-ink-60);
  }

  /* Japan Map CTA card */
  .pmap {
    padding: 0 0 28px;
  }
  .pmap-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 20px;
    background: var(--color-white);
    border: var(--border-ink);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-md);
  }
  .pmap-sub {
    margin: 8px 0 0;
    font-size: 15px;
    line-height: 1.5;
    max-width: 42ch;
  }
  .pmap-card .btn {
    align-self: flex-start;
  }

  /* Results sit on white so the rice-white cards read. Bottom padding
     lives on [data-list-section] (not the always-visible .presults wrap)
     so map view doesn't carry the grid's vertical reserve as a dead
     band between the controls row and the map.

     flow-root establishes a new block formatting context so the xlink's
     margin-bottom stays inside the white section. Without it, the margin
     collapses out the bottom (no padding/border to block it) and the
     body's rice-white shows through as a beige strip between the
     controls and the map in map view. */
  .presults {
    background: var(--color-white);
    padding: 20px 0 0;
    display: flow-root;
  }
  [data-list-section] {
    padding-bottom: 56px;
  }
  .results-count {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }
  /* Wayfinding aside — sits between the results count and the grid as a
     low-key cross-link to /eat. Sub-CTA weight, mono to read as inline
     copy rather than a button. */
  .xlink {
    margin: -4px 0 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-ink-60);
  }
  .xlink a {
    color: var(--color-ink-black);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .grid {
    display: grid;
    /* minmax(0, 1fr) strips the auto-minimum that otherwise lets each card's
       intrinsic min-content push the column wider than the viewport. */
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  /* Native lazy-render: the browser skips layout/paint for off-screen
     cards, so the whole grid stays in the DOM (instant filtering)
     without the cost of rendering every card up front. */
  .grid :global(.plc) {
    content-visibility: auto;
    contain-intrinsic-size: auto 320px;
  }
  .results-empty {
    padding: 48px 0;
    font-family: var(--font-head);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .wrap {
      padding: 0 var(--gutter-desktop);
    }
    .phero {
      padding: 56px 0 40px;
    }
    .phero h1 {
      font-size: 72px;
      letter-spacing: -0.035em;
    }
    .phero-sub {
      font-size: 19px;
    }
    .pmap {
      padding: 0 0 40px;
    }
    .pmap-card {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 32px;
      padding: 24px 28px;
    }
    .pmap-card .btn {
      align-self: auto;
      flex-shrink: 0;
    }
    .presults {
      padding: 24px 0 0;
    }
    [data-list-section] {
      padding-bottom: 72px;
    }
    .grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
  }

  /* Count + view-toggle bar. Count text left, segmented control right
     (pushed via margin-left: auto on .view-toggle). flex-wrap lets the
     toggle drop below the count if the column gets cramped on the
     narrowest mobile widths — keeps the row clean rather than letting
     the toggle squeeze the count text. */
  .presults-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px 14px;
    margin-bottom: 14px;
  }
  .presults-bar .view-toggle {
    margin-left: auto;
  }
  .view-toggle {
    display: inline-flex;
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-pill);
    overflow: hidden;
    background: var(--color-rice-white);
    box-shadow: var(--shadow-sm);
  }
  .view-toggle button {
    padding: 6px 14px;
    background: transparent;
    border: none;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    cursor: pointer;
  }
  .view-toggle button[aria-pressed="true"] {
    background: var(--color-ink-black);
    color: #fff;
  }
  /* Override the global red focus ring on toggle segments. The 2px red
     outline at +2px offset bled past the active button's right edge into
     the seam between List/Map, reading as a red divider. An inset ink
     hairline keeps the focus affordance neutral and stays inside the
     segment so adjacent buttons don't overlap it. */
  .view-toggle button:focus-visible {
    outline: 1.5px solid var(--color-ink-black);
    outline-offset: -1.5px;
  }
  .presults-map[hidden] { display: none; }
</style>

<script>
  /* View toggle (Phase B): swap between list grid and map view.
     URL ?view=map persists state; default is list. When switching to
     map view, dispatch "mapview:show" so MapView calls map.resize()
     since its container just gained dimensions. */
  const toggle = document.querySelector("[data-view-toggle]");
  const listSec = document.querySelector("[data-list-section]");
  const mapSec = document.querySelector("[data-map-section]");

  function setView(view, { writeURL = true } = {}) {
    const isMap = view === "map";
    if (listSec) listSec.hidden = isMap;
    if (mapSec) mapSec.hidden = !isMap;
    if (toggle) {
      for (const btn of toggle.querySelectorAll("[data-view-btn]")) {
        btn.setAttribute(
          "aria-pressed",
          String(btn.dataset.viewBtn === view),
        );
      }
    }
    if (writeURL) {
      const p = new URLSearchParams(window.location.search);
      if (isMap) p.set("view", "map");
      else p.delete("view");
      const qs = p.toString();
      history.replaceState(
        null,
        "",
        window.location.pathname + (qs ? "?" + qs : "") + window.location.hash,
      );
    }
    if (isMap) {
      window.dispatchEvent(new CustomEvent("mapview:show"));
    }
  }

  /* Initial state from URL. */
  const params = new URLSearchParams(window.location.search);
  setView(params.get("view") === "map" ? "map" : "list", { writeURL: false });

  /* Click handlers. */
  if (toggle) {
    for (const btn of toggle.querySelectorAll("[data-view-btn]")) {
      btn.addEventListener("click", () => {
        setView(btn.dataset.viewBtn);
      });
    }
  }

  /* popstate so browser back/forward keeps the toggle in sync. */
  window.addEventListener("popstate", () => {
    const params = new URLSearchParams(window.location.search);
    setView(params.get("view") === "map" ? "map" : "list", { writeURL: false });
  });

  /* Re-scroll to the hash target after layout settles. The cards use
     `content-visibility: auto` for perf — the browser's initial scroll
     can land on the placeholder's intrinsic size instead of the painted
     card's true position, which previously made popup-CTA deep links
     look like they had landed at the top of the page. Two RAFs let the
     filter rail's init pass and content-visibility activation finish,
     then we explicitly re-scroll with the card's scroll-margin honored. */
  if (window.location.hash) {
    const id = decodeURIComponent(window.location.hash.slice(1));
    if (id) {
      requestAnimationFrame(() => requestAnimationFrame(() => {
        const el = document.getElementById(id);
        if (el) el.scrollIntoView({ block: "start" });
      }));
    }
  }
</script>
