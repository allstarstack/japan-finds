---
/* /products — Phase B-1 catalog launch.
   Hero, sticky filter rail, and the full 384-product grid. Mirrors the
   other list pages (/eat, /stay, /places) for cross-page consistency:
   hero → search → chips → grid, no featured-six block. Sort: newest-first
   by id (descending) — viewers arriving from a recent video land on the
   most recently added product first (SEARCH_AND_SORT Phase A). */
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ProductCard from "../components/v2/ProductCard.astro";
import FilterRail from "../components/v2/FilterRail.astro";
import SearchBox from "../components/v2/SearchBox.astro";
import { SUB_CHIPS } from "../data/launch-chips.js";

const launch = (await getCollection("products")).filter(
  (p) => p.data.status === "ready" && p.data.launch_category,
);

/* Newest-first: product ids (JF-0001…JF-0463) are zero-padded, so a
   descending string compare orders them numerically — the highest JF
   number (most recently added) sits at the top of the grid. Filtering is
   attribute-based (data-category/sub/fill on each card) and unaffected by
   display order. Replaces the prior rail-order → verified-first → A→Z. */
launch.sort((a, b) => b.data.id.localeCompare(a.data.id));

const total = launch.length;

/* Per-category counts for the chips. */
const counts: Record<string, number> = {};
for (const p of launch)
  counts[p.data.launch_category!] = (counts[p.data.launch_category!] ?? 0) + 1;

/* Which sub-chips actually have items — empty sets are never rendered. */
const subAvail: Record<string, string[]> = {};
for (const p of launch) {
  const c = p.data.launch_category!;
  if (p.data.sub_chip && SUB_CHIPS[c as keyof typeof SUB_CHIPS])
    (subAvail[c] ??= []).push(p.data.sub_chip);
}
---

<Base
  title="What to buy in Japan — Japan Finds"
  description={`${total} Japan shopping picks — konbini, drugstores, Donki, 100-yen and more. Filter by what you're shopping for.`}
>
  <Header />
  <main id="main">
    <section class="phero">
      <div class="wrap">
        <p class="eyebrow">JAPAN FINDS · SHOPPING</p>
        <h1>What to actually buy in Japan.</h1>
        <p class="phero-sub">
          {total} picks across konbini, drugstores, Donki, 100-yen shops and
          more. Filter to what you're shopping for.
        </p>
      </div>
    </section>

    <div class="rail-sticky">
      <SearchBox placeholder={`Search ${total} products`} />
      <FilterRail counts={counts} subAvail={subAvail} />
    </div>

    <section class="presults">
      <div class="wrap">
        <h2 class="results-count" data-count>{total} finds</h2>
        <div class="grid" data-grid>
          {launch.map((p) => <ProductCard entry={p} />)}
        </div>
        <p class="results-empty" data-empty hidden>
          Nothing matches. Try a brand name or category.
        </p>
      </div>
    </section>
  </main>
  <SiteFooter />
</Base>

<style>
  .wrap {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 var(--gutter-mobile);
  }

  /* Filter block wrapper — holds the search box and category rail.
     Scrolls with the page (was previously sticky; the always-pinned
     footprint starved the card grid on mobile). The white surface +
     ink hairline remain as the visual separator between filters and
     the grid. */
  .rail-sticky {
    background: var(--color-white);
    border-bottom: var(--border-ink);
  }

  /* Shared mono eyebrow */
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }

  /* Hero — rice-white, sits on the body background */
  .phero {
    padding: 30px 0 28px;
  }
  .phero h1 {
    margin: 10px 0 0;
    font-family: var(--font-head);
    font-size: 40px;
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.03em;
  }
  .phero-sub {
    margin: 14px 0 0;
    max-width: 36ch;
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-ink-60);
  }

  /* Results sit on white so the rice-white cards read. */
  .presults {
    background: var(--color-white);
  }

  /* Results */
  .presults {
    padding: 20px 0 56px;
  }
  .results-count {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-60);
    margin-bottom: 14px;
  }
  .grid {
    display: grid;
    /* minmax(0, 1fr) strips the auto-minimum that otherwise lets each card's
       intrinsic min-content push the column wider than the viewport. */
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  /* Native lazy-render: the browser skips layout/paint for off-screen
     cards, so all 384 stay in the DOM (instant filtering) without the
     cost of rendering them all up front. */
  .grid :global(.pc) {
    content-visibility: auto;
    contain-intrinsic-size: auto 190px;
  }
  .results-empty {
    padding: 48px 0;
    font-family: var(--font-head);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .wrap {
      padding: 0 var(--gutter-desktop);
    }
    .phero {
      padding: 56px 0 40px;
    }
    .phero h1 {
      font-size: 72px;
      letter-spacing: -0.035em;
    }
    .phero-sub {
      font-size: 19px;
    }
    .presults {
      padding: 24px 0 72px;
    }
    .grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
  }
</style>
