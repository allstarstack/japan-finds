---
/* /stay — Stay list page.
   135-row collection (src/content/stays/) rendered with a chip rail and
   LIST/MAP toggle that mirrors /places: 9 category chips, region chips,
   search, grid, and a Mapbox map view. D7 enrichment populated lat/lng
   on all 135 stays, so the map source now renders the full cohort.
   Sort: newest-first by `id` (jf-stay-####), matching /products' and
   /places' newest-first behaviour. Comparator uses a trailing-digit
   extractor so the scheme-agnostic logic mirrors places.astro. */
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";
import StayCard from "../components/v2/StayCard.astro";
import StayFilterRail from "../components/v2/StayFilterRail.astro";
import LocationChipRow from "../components/v2/LocationChipRow.astro";
import SearchBox from "../components/v2/SearchBox.astro";
import MapView from "../components/v2/MapView.astro";
import { prefectureToRegion, REGION_LABELS } from "../data/regions.js";

const stays = await getCollection("stays");
/* Trailing-digit extractor keeps the comparator scheme-agnostic — works
   for jf-stay-#### today, would survive an id-prefix rename. Alpha is a
   defensive tiebreak (ids are unique). Mirrors places.astro. */
const idNum = (e) =>
  parseInt(String(e.data.id).match(/(\d+)$/)?.[1] ?? "0", 10);
stays.sort(
  (a, b) =>
    idNum(b) - idNum(a) ||
    a.data.name.toLowerCase().localeCompare(b.data.name.toLowerCase()),
);
const total = stays.length;

const counts: Record<string, number> = {};
for (const s of stays) {
  const c = s.data.primary_cat;
  if (c) counts[c] = (counts[c] ?? 0) + 1;
}

const regionCounts: Record<string, number> = {};
for (const s of stays) {
  const r = prefectureToRegion(s.data.prefecture);
  if (r) regionCounts[r] = (regionCounts[r] ?? 0) + 1;
}

const regionChips = Object.entries(REGION_LABELS)
  .map(([slug, label]) => ({ slug, label, count: regionCounts[slug] ?? 0 }))
  .filter((c) => c.count > 0);
---

<Base
  title="Where to stay in Japan — Japan Finds"
  description={`${total} distinctive Japanese stays — onsen ryokan, design hotels, machiya, glamping and more. Filter by category and region.`}
>
  <Header />
  <main id="main">
    <section class="shero">
      <div class="wrap">
        <p class="eyebrow">JAPAN FINDS · WHERE TO STAY</p>
        <h1>Where to actually stay in Japan.</h1>
        <p class="shero-sub">
          {total} distinctive stays — onsen ryokan, design hotels, machiya,
          glamping and more. Filter to what you want to book.
        </p>
      </div>
    </section>

    <div class="rail-sticky">
      <SearchBox placeholder={`Search ${total} stays`} />
      <LocationChipRow chips={regionChips} hintLabel="regions" />
      <StayFilterRail counts={counts} />
    </div>

    <section class="sresults">
      <div class="wrap">
        <div class="sresults-bar">
          <h2 class="results-count" data-count>{total} stays</h2>
          <div
            class="view-toggle"
            role="group"
            aria-label="Toggle list or map view"
            data-view-toggle
          >
            <button type="button" data-view-btn="list" aria-pressed="true">List</button>
            <button type="button" data-view-btn="map" aria-pressed="false">Map</button>
          </div>
        </div>
        <p class="xlink">Looking for places to visit? <a href="/places">See → /places</a></p>
        <div data-list-section>
          <div class="grid" data-grid>
            {stays.map((s) => <StayCard entry={s} />)}
          </div>
          <p class="results-empty" data-empty hidden>
            Nothing matches. Try a different category or region.
          </p>
        </div>
      </div>
    </section>

    <section class="sresults-map" data-map-section hidden>
      <MapView
        containerId="stay-map"
        sourceFilter="stay"
        filterEventName="stay:filter-changed"
        height="78vh"
        showLegend={true}
        legendKind="stay"
      />
    </section>
  </main>
  <SiteFooter />
</Base>

<style>
  .wrap {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 var(--gutter-mobile);
  }

  /* Filter block wrapper — holds the search, location row, and stay
     category rail. Scrolls with the page (was previously sticky; the
     always-pinned footprint starved the card grid on mobile). The
     white surface + ink hairline remain as the visual separator
     between filters and the grid. */
  .rail-sticky {
    background: var(--color-white);
    border-bottom: var(--border-ink);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }

  .shero {
    padding: 30px 0 28px;
  }
  .shero h1 {
    margin: 10px 0 0;
    font-family: var(--font-head);
    font-size: 40px;
    font-weight: 700;
    line-height: 0.98;
    letter-spacing: -0.03em;
  }
  .shero-sub {
    margin: 14px 0 0;
    max-width: 40ch;
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-ink-60);
  }

  /* Results sit on white so the rice-white cards read. Bottom padding
     lives on [data-list-section] (not the always-visible .sresults
     wrap) so map view doesn't carry the grid's vertical reserve as a
     dead band between the controls row and the map.

     flow-root establishes a new block formatting context so the xlink's
     margin-bottom stays inside the white section. Without it, the
     margin collapses out the bottom (no padding/border to block it) and
     the body's rice-white shows through as a beige strip between the
     controls and the map in map view. Both patterns mirror /places +
     /eat post-PR #47. */
  .sresults {
    background: var(--color-white);
    padding: 20px 0 0;
    display: flow-root;
  }
  [data-list-section] {
    padding-bottom: 56px;
  }
  /* Count + view-toggle bar. Count text left, segmented control right
     (pushed via margin-left: auto on .view-toggle). flex-wrap lets the
     toggle drop below the count if the column gets cramped on the
     narrowest mobile widths. Mirrors /places + /eat. */
  .sresults-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px 14px;
    margin-bottom: 14px;
  }
  .sresults-bar .view-toggle {
    margin-left: auto;
  }
  .results-count {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }
  .xlink {
    margin: -4px 0 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-ink-60);
  }
  .xlink a {
    color: var(--color-ink-black);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  /* Native lazy-render: skip layout/paint for off-screen cards so the
     whole grid stays in the DOM (instant filtering) without paying the
     up-front render cost. Matches /places. */
  .grid :global(.stc) {
    content-visibility: auto;
    contain-intrinsic-size: auto 420px;
  }
  .results-empty {
    padding: 48px 0;
    font-family: var(--font-head);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .wrap {
      padding: 0 var(--gutter-desktop);
    }
    .shero {
      padding: 56px 0 40px;
    }
    .shero h1 {
      font-size: 72px;
      letter-spacing: -0.035em;
    }
    .shero-sub {
      font-size: 19px;
    }
    .sresults {
      padding: 24px 0 0;
    }
    [data-list-section] {
      padding-bottom: 72px;
    }
    .grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
  }

  /* View toggle — segmented control. Lives on the .sresults-bar above;
     mirrors /places + /eat post-PR #47. */
  .view-toggle {
    display: inline-flex;
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-pill);
    overflow: hidden;
    background: var(--color-rice-white);
    box-shadow: var(--shadow-sm);
  }
  .view-toggle button {
    padding: 6px 14px;
    background: transparent;
    border: none;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    cursor: pointer;
  }
  .view-toggle button[aria-pressed="true"] {
    background: var(--color-ink-black);
    color: #fff;
  }
  /* Override the global red focus ring on toggle segments. The 2px red
     outline at +2px offset bled past the active button's right edge into
     the seam between List/Map, reading as a red divider. An inset ink
     hairline keeps the focus affordance neutral and stays inside the
     segment so adjacent buttons don't overlap it. */
  .view-toggle button:focus-visible {
    outline: 1.5px solid var(--color-ink-black);
    outline-offset: -1.5px;
  }
  .sresults-map[hidden] { display: none; }
</style>

<script>
  /* View toggle — same logic as /places.astro and /eat.astro. Swap
     between list grid and map view. URL ?view=map persists state;
     default is list. When switching to map view, dispatch
     "mapview:show" so MapView calls map.resize() (its container just
     gained dimensions). */
  const toggle = document.querySelector("[data-view-toggle]");
  const listSec = document.querySelector("[data-list-section]");
  const mapSec = document.querySelector("[data-map-section]");

  function setView(view, { writeURL = true } = {}) {
    const isMap = view === "map";
    if (listSec) listSec.hidden = isMap;
    if (mapSec) mapSec.hidden = !isMap;
    if (toggle) {
      for (const btn of toggle.querySelectorAll("[data-view-btn]")) {
        btn.setAttribute(
          "aria-pressed",
          String(btn.dataset.viewBtn === view),
        );
      }
    }
    if (writeURL) {
      const p = new URLSearchParams(window.location.search);
      if (isMap) p.set("view", "map");
      else p.delete("view");
      const qs = p.toString();
      history.replaceState(
        null,
        "",
        window.location.pathname + (qs ? "?" + qs : "") + window.location.hash,
      );
    }
    if (isMap) {
      window.dispatchEvent(new CustomEvent("mapview:show"));
    }
  }

  const params = new URLSearchParams(window.location.search);
  setView(params.get("view") === "map" ? "map" : "list", { writeURL: false });

  if (toggle) {
    for (const btn of toggle.querySelectorAll("[data-view-btn]")) {
      btn.addEventListener("click", () => {
        setView(btn.dataset.viewBtn);
      });
    }
  }

  window.addEventListener("popstate", () => {
    const params = new URLSearchParams(window.location.search);
    setView(params.get("view") === "map" ? "map" : "list", { writeURL: false });
  });
</script>
