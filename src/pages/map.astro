---
/* /map — standalone Mapbox view of every geocoded place.
   Phase A.8: sub-category pin coloring (13 distinct colors keyed off
   public_label) + bottom-left legend + click-to-include filter chips.

   Data: /places.geojson is generated at build time by
   scripts/generate-geojson.mjs. Filter state is layered:
     - Primary-category filter (4 click-to-include chips; URL ?categories=)
       Default: no chips active = show all pins. Click chip → adds to
       active set. Pins shown iff their primary_category is in the
       active set OR active set is empty.
     - Sub-category pin colour by public_label (independent of filter).
     - URL hash (#zoom/lat/lng) via Mapbox-native hash:true.
     - Lazy popup HTML built on click (not pre-rendered per pin).

   Sub-category palette is the single source of truth for the Mapbox
   paint expression AND the rendered legend — keep both in sync. */
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { existsSync, readFileSync } from "node:fs";
import {
  PLACES_LEGEND_ROWS,
  EAT_LEGEND_ROWS,
  STAY_LEGEND_ROWS,
  STAY_PIN_COLOR,
  EAT_CUISINE_TO_SLUG,
} from "../data/map-legends.js";

/* Legend rows are imported above. `slug` is the public_label /
   cuisine / primary_cat token used by URL params, the in-memory
   filter state, and the Mapbox paint expressions. Phase A.9 C3
   "top hits first" intent priority lives in map-legends.js so the
   ordering choice is preserved alongside its companion paint data. */
const PLACES_LEGEND = PLACES_LEGEND_ROWS;
const EAT_LEGEND = EAT_LEGEND_ROWS;
const STAY_LEGEND = STAY_LEGEND_ROWS;
const STAY_INDIGO = STAY_PIN_COLOR;

/* Phase A.9 C6 — empty-state for sources with zero placed markers.
   Read at build time from the prebuild-generated geojson. If a source
   has 0 features in the file, its legend section renders a brand-voice
   message above dimmed, non-interactive rows. Generalizable to any
   source — currently triggers only for stays (D7-style lat/lng
   enrichment is the followup workstream).
   countsAvailable: false in dev-server without prebuild → empty state
   is suppressed entirely (no false-positive on a fresh checkout). */
const GEOJSON_PATH = "public/places.geojson";
const PLACED_COUNTS: Record<string, number> = { places: 0, eat: 0, stay: 0 };
/* A.10 — per-cluster pin counts for legend rows + meta-row totals. Keyed
   by the same slug the legend row uses (public_label for places,
   cuisine→slug for eat, primary_cat for stay). Missing keys default to
   0 at render time, so empty geojson in dev-server (countsAvailable=false)
   shows every row as "0". */
const PLACES_CLUSTER_COUNTS: Record<string, number> = {};
const EAT_CLUSTER_COUNTS: Record<string, number> = {};
const STAY_CLUSTER_COUNTS: Record<string, number> = {};
let countsAvailable = false;
if (existsSync(GEOJSON_PATH)) {
  try {
    const geojson = JSON.parse(readFileSync(GEOJSON_PATH, "utf-8"));
    for (const f of geojson.features ?? []) {
      const props = f?.properties ?? {};
      const src = props.source;
      if (src && src in PLACED_COUNTS) PLACED_COUNTS[src]++;
      if (src === "places") {
        const slug = props.public_label || "_base";
        PLACES_CLUSTER_COUNTS[slug] = (PLACES_CLUSTER_COUNTS[slug] ?? 0) + 1;
      } else if (src === "eat") {
        const slug = EAT_CUISINE_TO_SLUG[props.cuisine];
        if (slug) EAT_CLUSTER_COUNTS[slug] = (EAT_CLUSTER_COUNTS[slug] ?? 0) + 1;
      } else if (src === "stay") {
        const slug = props.primary_cat;
        if (slug) STAY_CLUSTER_COUNTS[slug] = (STAY_CLUSTER_COUNTS[slug] ?? 0) + 1;
      }
    }
    countsAvailable = true;
  } catch (e) {
    console.warn("[/map] could not read", GEOJSON_PATH, e);
  }
}
const isSourceEmpty = (src: string) =>
  countsAvailable && PLACED_COUNTS[src] === 0;

/* Meta-row totals per mode, serialized onto the legend container so the
   client-side mode handler can update the count text without a re-fetch.
   `clusters` = row count for that mode (legend taxonomy size). `pins` =
   sum of features for that source. Default (mode=null) shows the
   combined totals — all three sections render in the body. */
const COUNTS_BY_MODE = {
  where: { clusters: PLACES_LEGEND_ROWS.length, pins: PLACED_COUNTS.places },
  eat: { clusters: EAT_LEGEND_ROWS.length, pins: PLACED_COUNTS.eat },
  stay: { clusters: STAY_LEGEND_ROWS.length, pins: PLACED_COUNTS.stay },
  all: {
    clusters:
      PLACES_LEGEND_ROWS.length + EAT_LEGEND_ROWS.length + STAY_LEGEND_ROWS.length,
    pins: PLACED_COUNTS.places + PLACED_COUNTS.eat + PLACED_COUNTS.stay,
  },
};

// Per-source empty-state copy. Row-count substitutes for the
// "<n> categories" part. Same shape across sources so a future zero-
// placed source picks the matching template without code changes; new
// sources just add an entry here. Brand voice: short, declarative,
// no apology — "curated" signals the work is done, "verified" signals
// what's pending.
const EMPTY_STATE_MESSAGE: Record<string, (n: number) => string> = {
  places: (n) => `${n} place categories curated. Locations being verified — pins appear soon.`,
  eat: (n) => `${n} cuisine categories curated. Locations being verified — pins appear soon.`,
  stay: (n) => `${n} stay categories curated. Locations being verified — pins appear soon.`,
};
// Row count excludes the _base sentinel for /places (Base towns isn't
// a category in the human sense — it's the catchall for unlabeled
// rows). Other sources count all rows.
const PLACES_ROW_COUNT = PLACES_LEGEND.filter((c) => c.slug !== "_base").length;
---

<Base
  title="Japan map — Japan Finds"
  description="Interactive map of every place on Japan Finds — nature, food markets, museums, onsen, theme parks, anime pilgrimage sites and more."
>
  <Header />
  <main id="main" class="map-main">
    {/* A.10 — top toolbar folded into the legend header. Mode-switch
        (GO / EAT / STAY) lives as a segmented control inside the
        legend card so there's one unified control surface in the
        bottom-left, not a toolbar-top / legend-bottom diagonal. The
        internal mode key for the GO bucket remains "where"
        (data-mode-btn="where", sourceFilter "places"); only the
        display label changed. */}
    <div id="japan-map" aria-label="Interactive map of Japan Finds places"></div>

    <p class="map-hint" hidden data-hint>Tap the map to enable zoom</p>

    <div class="map-loading" data-loading>
      <span class="map-loading-spinner" aria-hidden="true"></span>
      <span class="map-loading-text">Loading map…</span>
    </div>

    {/* A.10 — Variant A (trimmed) consolidated control surface.
        Structure: segmented mode header → meta row (count + caret) →
        divider → cluster body. data-mode on the body drives section
        visibility: "" = all three stacked (default), "where|eat|stay" =
        single section. Mobile: bottom sheet with peek default
        (aria-expanded=false renders header + first ~3 rows). */}
    <div
      class="map-legend"
      data-legend
      data-mode=""
      data-counts={JSON.stringify(COUNTS_BY_MODE)}
    >
      <div class="map-legend-handle" aria-hidden="true"></div>

      <div
        class="map-legend-segment"
        role="group"
        aria-label="Switch map mode"
      >
        <button
          type="button"
          class="map-legend-seg"
          data-mode-btn="where"
          aria-pressed="false"
        >GO</button>
        <button
          type="button"
          class="map-legend-seg"
          data-mode-btn="eat"
          aria-pressed="false"
        >EAT</button>
        <button
          type="button"
          class="map-legend-seg"
          data-mode-btn="stay"
          aria-pressed="false"
        >STAY</button>
      </div>

      <div class="map-legend-meta">
        <span class="map-legend-counts" data-counts-text>
          {COUNTS_BY_MODE.all.clusters} clusters · {COUNTS_BY_MODE.all.pins} pins
        </span>
        <button
          type="button"
          class="map-legend-caret"
          data-legend-toggle
          aria-expanded="true"
          aria-controls="map-legend-body"
          aria-label="Toggle legend"
        >
          <span class="map-legend-chev" aria-hidden="true">▾</span>
        </button>
      </div>

      <div id="map-legend-body" class="map-legend-body" data-legend-list>
        <div
          class="map-legend-section"
          data-legend-section="places"
          data-empty={isSourceEmpty("places") ? "true" : "false"}
        >
          <span class="map-legend-section-title">places</span>
          {isSourceEmpty("places") && (
            <p class="map-legend-empty">
              {EMPTY_STATE_MESSAGE.places(PLACES_ROW_COUNT)}
            </p>
          )}
          <ul class="map-legend-rows">
            {
              PLACES_LEGEND.map((c) => (
                <li
                  class="map-legend-row"
                  data-legend-row="places"
                  data-value={c.slug}
                  data-active="true"
                  role="button"
                  tabindex={isSourceEmpty("places") ? -1 : 0}
                  aria-pressed="false"
                  aria-disabled={isSourceEmpty("places") ? "true" : "false"}
                >
                  <span
                    class="map-legend-swatch"
                    style={`background:${c.color}`}
                    aria-hidden="true"
                  />
                  <span class="map-legend-label">{c.label}</span>
                  <span class="map-legend-count">
                    {PLACES_CLUSTER_COUNTS[c.slug] ?? 0}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>

        <div
          class="map-legend-section"
          data-legend-section="eat"
          data-empty={isSourceEmpty("eat") ? "true" : "false"}
        >
          <span class="map-legend-section-title">restaurants</span>
          {isSourceEmpty("eat") && (
            <p class="map-legend-empty">
              {EMPTY_STATE_MESSAGE.eat(EAT_LEGEND.length)}
            </p>
          )}
          <ul class="map-legend-rows">
            {
              EAT_LEGEND.map((c) => (
                <li
                  class="map-legend-row"
                  data-legend-row="eat"
                  data-value={c.slug}
                  data-active="true"
                  role="button"
                  tabindex={isSourceEmpty("eat") ? -1 : 0}
                  aria-pressed="false"
                  aria-disabled={isSourceEmpty("eat") ? "true" : "false"}
                >
                  <span
                    class="map-legend-swatch map-legend-swatch--ring"
                    aria-hidden="true"
                  />
                  <span class="map-legend-label">{c.label}</span>
                  <span class="map-legend-count">
                    {EAT_CLUSTER_COUNTS[c.slug] ?? 0}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>

        <div
          class="map-legend-section"
          data-legend-section="stay"
          data-empty={isSourceEmpty("stay") ? "true" : "false"}
        >
          <span class="map-legend-section-title">lodging</span>
          {isSourceEmpty("stay") && (
            <p class="map-legend-empty">
              {EMPTY_STATE_MESSAGE.stay(STAY_LEGEND.length)}
            </p>
          )}
          <ul class="map-legend-rows">
            {
              STAY_LEGEND.map((s) => (
                <li
                  class="map-legend-row"
                  data-legend-row="stay"
                  data-value={s.slug}
                  data-active="true"
                  role="button"
                  tabindex={isSourceEmpty("stay") ? -1 : 0}
                  aria-pressed="false"
                  aria-disabled={isSourceEmpty("stay") ? "true" : "false"}
                >
                  <span
                    class="map-legend-swatch"
                    style={`background:${STAY_INDIGO}`}
                    aria-hidden="true"
                  />
                  <span class="map-legend-label">{s.label}</span>
                  <span class="map-legend-count">
                    {STAY_CLUSTER_COUNTS[s.slug] ?? 0}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <div class="map-error" hidden data-error role="alert">
      <div class="map-error-card">
        <p class="map-error-text">Map unavailable — please refresh.</p>
        <button type="button" class="map-error-reload" data-reload>Reload page</button>
      </div>
    </div>
  </main>
  <SiteFooter />
</Base>

<style is:global>
  /* Popup overrides — Mapbox creates these dynamically, so global rules. */
  .mapboxgl-popup-content {
    padding: 0;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }
  .mapboxgl-popup-tip { display: none; }
  .mapboxgl-popup-close-button {
    color: var(--color-ink-black);
    font-size: 18px;
    padding: 2px 8px;
    line-height: 1;
  }
  .map-popup {
    display: flex;
    gap: 10px;
    padding: 10px;
    min-width: 220px;
    max-width: 280px;
  }
  .map-popup-img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    flex-shrink: 0;
    border-radius: var(--radius-sm);
    background: var(--color-concrete-gray);
  }
  .map-popup-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 3px;
    min-width: 0;
    flex: 1;
  }
  .map-popup-name {
    margin: 0;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 14px;
    line-height: 1.2;
    color: var(--color-ink-black);
  }
  .map-popup-area {
    margin: 0;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 11px;
    color: var(--color-ink-60);
    letter-spacing: 0.02em;
  }
  .map-popup-jp {
    margin-left: 4px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-ink-60);
  }
  .map-popup-link {
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ink-black);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Geolocate control — brand-style the default Mapbox button. */
  .mapboxgl-ctrl-group {
    background: var(--color-rice-white) !important;
    border: 1.5px solid var(--color-ink-black) !important;
    border-radius: var(--radius-sm) !important;
    box-shadow: var(--shadow-sm) !important;
  }
  .mapboxgl-ctrl-group button {
    width: 36px !important;
    height: 36px !important;
  }
  .mapboxgl-ctrl-group button:not(:disabled):hover {
    background: var(--color-rice-tint) !important;
  }
  .mapboxgl-ctrl-attrib {
    background: rgba(247, 243, 234, 0.85) !important;
  }
  /* Mapbox vendor logo defaults to 21px tall, which trips Lighthouse
     a11y "tap targets are sized appropriately" (WCAG 2.2 target-size,
     ≥24×24 CSS px). Bumping the height clears the audit without
     altering the wordmark's aspect ratio — the background-image still
     centers, and the wider element is incidentally easier to hit. */
  .mapboxgl-ctrl-logo {
    height: 24px !important;
    background-size: contain !important;
  }
</style>

<style>
  .map-main {
    position: relative;
    padding: 0;
  }
  #japan-map {
    width: 100%;
    height: 95vh;
    background: var(--color-concrete-gray);
  }

  /* A.10 — top toolbar removed. Mode-switch lives inside the legend
     card's segmented header. Tap-to-zoom hint moved up to the top now
     that the toolbar isn't occupying that band. */

  /* Mobile tap-to-activate hint (revealed by JS on coarse-pointer). */
  .map-hint {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    padding: 6px 14px;
    background: var(--color-ink-black);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: var(--radius-pill);
    z-index: 11;
    pointer-events: none;
    box-shadow: var(--shadow-sm);
  }

  /* Loading state: visible before Mapbox 'load' event fires. The
     `[hidden]` override is required because the explicit `display:
     inline-flex` rule below outranks the UA `[hidden] { display: none }`
     in CSS specificity — same gotcha as .plc[hidden] / .pchip[hidden]
     elsewhere in the codebase. Without this, setting loading.hidden=true
     in JS sets the attribute but the overlay stays visible. */
  .map-loading {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    z-index: 13;
  }
  .map-loading[hidden] { display: none; }
  .map-loading-spinner {
    width: 14px;
    height: 14px;
    border: 2px solid var(--color-concrete-gray);
    border-top-color: var(--color-ink-black);
    border-radius: 50%;
    animation: map-spin 0.7s linear infinite;
  }
  @keyframes map-spin {
    to { transform: rotate(360deg); }
  }

  /* A.10 — Variant A (trimmed) consolidated control surface.
     Bottom-left anchor preserved from the old legend so muscle memory
     carries forward. The card now holds both the mode-switch (segmented
     header) AND the cluster filter (body), removing the toolbar-top /
     legend-bottom diagonal eye-jump. */
  .map-legend {
    position: absolute;
    bottom: 24px;
    left: 12px;
    z-index: 11;
    width: 300px;
    max-width: calc(100vw - 24px);
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    font-family: var(--font-mono);
    font-weight: 500;
    color: var(--color-ink-black);
  }

  /* Drag handle — visual cue only on mobile; hidden on desktop where the
     card has a fixed anchor and no draggability. */
  .map-legend-handle {
    display: none;
  }

  /* Segmented mode header — full-width 3-up pill inside the card.
     Active segment = ink fill + rice text; inactive = transparent +
     ink text. 1.5px ink dividers between segments (achieved with
     border-left on segments 2/3, since the outer border lives on the
     wrapper). */
  .map-legend-segment {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    margin: 10px;
    border: 1.5px solid var(--color-ink-black);
    border-radius: 999px;
    overflow: hidden;
    background: var(--color-rice-white);
  }
  .map-legend-seg {
    appearance: none;
    background: transparent;
    color: var(--color-ink-black);
    border: 0;
    padding: 7px 10px;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.02em;
    text-align: center;
    cursor: pointer;
    transition: background 120ms ease-out, color 120ms ease-out;
  }
  .map-legend-seg + .map-legend-seg {
    border-left: 1.5px solid var(--color-ink-black);
  }
  .map-legend-seg:hover:not([aria-pressed="true"]) {
    background: var(--color-rice-tint);
  }
  .map-legend-seg:focus-visible {
    outline: 2px solid var(--color-ink-black);
    outline-offset: -3px;
  }
  .map-legend-seg[aria-pressed="true"] {
    background: var(--color-ink-black);
    color: var(--color-rice-white);
  }

  /* Meta row — single line: count (left) + collapse caret (right).
     Divider under the row separates header from body; the divider is
     removed when the body is fully collapsed on desktop (handled below
     via the [hidden] body selector). */
  .map-legend-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 12px 8px;
  }
  .map-legend-counts {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }
  .map-legend-caret {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 2px 4px;
    margin: -2px -4px;
    color: var(--color-ink-black);
    font-family: var(--font-mono);
    font-size: 12px;
    cursor: pointer;
    line-height: 1;
  }
  .map-legend-caret:focus-visible {
    outline: 2px solid var(--color-ink-black);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }
  .map-legend-chev {
    display: inline-block;
    transition: transform 120ms ease-out;
  }
  .map-legend-caret[aria-expanded="false"] .map-legend-chev {
    transform: rotate(-90deg);
  }

  /* Body — scrollable cluster list under a 1.5px ink divider.
     Divider lives on the body's top edge so it disappears with the body
     when collapsed (no orphan rule below the meta row). */
  .map-legend-body {
    margin: 0;
    padding: 10px 12px 12px;
    border-top: 1.5px solid var(--color-ink-black);
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-height: 300px;
    overflow-y: auto;
  }
  .map-legend-body[hidden] { display: none; }

  /* Mode-driven section visibility — empty data-mode shows all three
     sections stacked; a set mode shows only the matching section. */
  .map-legend[data-mode="where"] .map-legend-section:not([data-legend-section="places"]),
  .map-legend[data-mode="eat"] .map-legend-section:not([data-legend-section="eat"]),
  .map-legend[data-mode="stay"] .map-legend-section:not([data-legend-section="stay"]) {
    display: none;
  }

  /* Group header — mode-word label (places / restaurants / lodging).
     Muted, mono, non-interactive — purely a signpost for what the rows
     below describe. Never a filter. */
  .map-legend-section-title {
    display: block;
    width: 100%;
    margin: 0 0 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }

  .map-legend-rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  /* Row — pin swatch + label + count.
     Single-select within mode: selected row gets a 2px ink left rule
     and a 5%-ink background tint. Unselected rows reserve the same
     left-border slot via transparent border so selection causes zero
     layout shift. Per-mode swatch treatment lives below. */
  .map-legend-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 6px;
    border-left: 2px solid transparent;
    border-radius: var(--radius-sm);
    cursor: pointer;
    user-select: none;
    line-height: 1.3;
    transition: background 100ms ease-out;
  }
  .map-legend-row:hover { background: var(--color-rice-tint); }
  .map-legend-row:focus-visible {
    outline: 2px solid var(--color-ink-black);
    outline-offset: 1px;
  }
  .map-legend-row[aria-pressed="true"] {
    border-left-color: var(--color-ink-black);
    background: rgba(21, 21, 21, 0.05);
  }
  .map-legend-row[aria-pressed="true"] .map-legend-label {
    font-weight: 600;
  }
  .map-legend-label {
    flex: 1;
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-ink-black);
  }
  .map-legend-count {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    color: var(--color-ink-60);
    font-variant-numeric: tabular-nums;
  }

  /* Pin swatches — must equal the rendered Mapbox pin for the mode.
     GO: filled disc, per-cluster colour (inline style from
     PLACES_LEGEND_ROWS.color). EAT: hollow ring matching the /map
     mixed-source pin (white fill + Tokyo Red stroke). STAY: filled
     Aizome Indigo disc. Disc border 1.5px rgba(21,21,21,0.18). */
  .map-legend-swatch {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1.5px solid rgba(21, 21, 21, 0.18);
    flex-shrink: 0;
  }
  .map-legend-swatch--ring {
    background: #ffffff;
    border-color: #ff3b30;
    border-width: 2.5px;
  }

  /* Empty-state — preserved from C6. Inline brand-voice message above
     dimmed, non-interactive rows when a source has zero placed pins. */
  .map-legend-empty {
    margin: 0 0 6px;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    font-style: italic;
    line-height: 1.4;
    color: var(--color-ink-60);
  }
  .map-legend-section[data-empty="true"] .map-legend-row {
    opacity: 0.4;
    pointer-events: none;
    cursor: default;
  }
  .map-legend-section[data-empty="true"] .map-legend-row .map-legend-label {
    color: var(--color-ink-60);
  }
  .map-legend-section[data-empty="true"] .map-legend-row:hover {
    background: transparent;
  }

  /* Error overlay — auth/network failure. Replaces the silent blank gray. */
  .map-error {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 14;
  }
  .map-error-card {
    padding: 16px 20px;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-tokyo-red);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-md);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
  }
  .map-error-text {
    margin: 0;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 15px;
    color: var(--color-ink-black);
  }
  .map-error-reload {
    padding: 6px 14px;
    background: var(--color-ink-black);
    color: #fff;
    border: none;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
  }

  /* Inline toast (geolocation denied, etc.) — auto-dismisses in 3s. */
  :global(.map-toast) {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 14px;
    background: var(--color-ink-black);
    color: #fff;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    z-index: 15;
    box-shadow: var(--shadow-sm);
  }

  /* Mobile — legend becomes a bottom sheet.
     Drag handle (visual cue, tap-to-toggle hit area routes to caret),
     full-width with 12px margins, peeking by default so the legend is
     visible without a tap. Peek state = aria-expanded=false on caret:
     [hidden] body is rendered (overriding the desktop display:none),
     constrained to ~140px so roughly the segmented header + 3 cluster
     rows show. Expanded state = caret tapped, body grows to ~380px
     max with scroll. */
  @media (max-width: 640px) {
    .map-legend {
      left: 12px;
      right: 12px;
      bottom: 12px;
      width: auto;
      max-width: none;
    }
    .map-legend-handle {
      display: block;
      width: 32px;
      height: 3px;
      margin: 6px auto 4px;
      background: var(--color-ink-30);
      border-radius: 2px;
    }
    .map-legend-segment { margin: 6px 10px 8px; }
    .map-legend-body { max-height: 380px; }
    /* Peek state — body kept in flow (overrides the desktop
       display:none on [hidden]) but clipped to ~3 rows. Overflow
       hidden in peek keeps the scrollbar from flashing while the
       user is just glancing at the top of the list. */
    .map-legend-body[hidden] {
      display: flex;
      max-height: 140px;
      overflow: hidden;
    }
  }
</style>

<script>
  import mapboxgl from "mapbox-gl";
  import "mapbox-gl/dist/mapbox-gl.css";
  import {
    MAP_INIT,
    PLACES_LEGEND_SLUGS,
    EAT_LEGEND_SLUGS,
    STAY_LEGEND_SLUGS,
    EAT_SLUG_TO_CUISINE,
    EAT_CUISINE_TO_SLUG,
    PLACES_PAINT_COLOR,
    EAT_RING_FILL,
    EAT_RING_STROKE,
    STAY_PIN_COLOR,
    STAY_SLUG_TO_LABEL,
  } from "../data/map-legends.js";

  // Inlined at build time. On Vercel = real production token; localhost
  // with the .env placeholder will 401-fail (caught by the error overlay).
  mapboxgl.accessToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;

  /* Phase A.9 C5 — mode + cluster two-axis filter state.
       mode: null | "where" | "eat" | "stay"
         null  = default trip-planner view; all sources visible, all
                 three legend sections rendered.
         set   = mode-switched view; only that source's markers visible
                 AND only that section's legend rows rendered.
       cluster: null | <slug>
         null  = no sub-cluster focus within the active mode.
         set   = single legend row focused inside the active section;
                 only matching features visible. Meaningful only when
                 mode is also set (mode=null + cluster=X is ignored).
     URL: ?mode=where&cluster=anime. Default omits both. */
  const ALL_MODES = ["where", "eat", "stay"];
  const MODE_TO_SOURCE = { where: "places", eat: "eat", stay: "stay" };
  let mode = null;
  let cluster = null;
  let allFeatures = null; // fetched once; filter rebuilds source.data
  let map;
  let mapErrored = false;

  /* Per-mode slug Sets for URL ?cluster= validation. Keys are the
     data-legend-section attribute (the source name, not the mode
     name) so the legend markup is unchanged. Slug sets and the
     EAT slug↔cuisine maps are imported from map-legends.js. */
  const LEGEND_SLUG_SETS = {
    places: PLACES_LEGEND_SLUGS,
    eat: EAT_LEGEND_SLUGS,
    stay: STAY_LEGEND_SLUGS,
  };

  /* ---------- URL state — single ?mode= + optional ?cluster= ----------
     Phase A.9 C5: trade C3/C4's three-param scheme for one mode param.
     Migration from older link formats (C3 csv-per-source, C4 single-
     slug-per-source, A.8 ?categories=) is best-effort: pick the first
     valid source token and rewrite the URL on init so the user lands
     in the new scheme without an extra page reload. */
  function readModeFromURL() {
    const p = new URLSearchParams(window.location.search);

    // 1. New-scheme ?mode= (preferred).
    let m = (p.get("mode") || "").trim().toLowerCase();
    let c = (p.get("cluster") || "").trim().toLowerCase();

    // 2. Legacy C4 single-slug-per-source: ?places=, ?eat=, ?stay=.
    //    First matching one wins. cluster value picked from that param.
    if (!m) {
      for (const [src, modeName] of [["places", "where"], ["eat", "eat"], ["stay", "stay"]]) {
        const raw = (p.get(src) || "").trim().toLowerCase();
        if (raw) {
          m = modeName;
          c = raw.split(",")[0]; // C3 csv → take first token
          break;
        }
      }
    }

    // 3. Legacy A.8/C4 ?categories= toolbar-only param. tabelog → eat.
    if (!m) {
      const raw = (p.get("categories") || "").trim().toLowerCase();
      if (raw) {
        const first = raw.split(",")[0];
        if (first === "tabelog" || first === "eat") m = "eat";
        else if (first === "stay") m = "stay";
        else if (first === "see" || first === "do") m = "where";
      }
    }

    if (!ALL_MODES.includes(m)) {
      mode = null;
      cluster = null;
      return;
    }
    mode = m;
    const src = MODE_TO_SOURCE[m];
    cluster = c && LEGEND_SLUG_SETS[src].has(c) ? c : null;
  }

  function syncURL() {
    const p = new URLSearchParams(window.location.search);
    // Strip legacy params on every sync so migrated links self-clean.
    for (const k of ["places", "eat", "stay", "categories"]) p.delete(k);
    if (mode) p.set("mode", mode);
    else p.delete("mode");
    if (mode && cluster) p.set("cluster", cluster);
    else p.delete("cluster");
    const qs = p.toString();
    const newURL =
      window.location.pathname +
      (qs ? "?" + qs : "") +
      window.location.hash;
    history.replaceState(null, "", newURL);
  }

  /* ---------- UI state sync ----------
     A.10 — segmented mode buttons live in the legend header.
     aria-pressed reflects the active mode (zero or one of three).
     The legend container's data-mode drives section-visibility CSS.
     Meta-row count text reflects the active mode (or the combined
     total when no mode is set).
     COUNTS_BY_MODE is serialized onto the legend container at build
     time so this handler doesn't need a network round-trip. */
  const legendEl = document.querySelector("[data-legend]");
  const COUNTS_BY_MODE = legendEl
    ? JSON.parse(legendEl.dataset.counts || "{}")
    : {};
  function updateButtonStates() {
    document.querySelectorAll("[data-mode-btn]").forEach((btn) => {
      btn.setAttribute(
        "aria-pressed",
        String(mode !== null && btn.dataset.modeBtn === mode),
      );
    });
    if (legendEl) legendEl.dataset.mode = mode || "";
    const countsText = document.querySelector("[data-counts-text]");
    if (countsText) {
      const c = COUNTS_BY_MODE[mode || "all"] || { clusters: 0, pins: 0 };
      countsText.textContent = `${c.clusters} clusters · ${c.pins} pins`;
    }
  }

  /* ---------- Map filtering ----------
     Two-axis filter from the C5 model:
       1. Mode (null | "where" | "eat" | "stay") gates the source.
          null = all sources visible (trip-planner default).
       2. Cluster (null | slug) gates within the active mode's source.
          Meaningful only when mode is also set.
     Features pass iff both axes admit them. */
  function passesFilter(f) {
    const src = f.properties.source;
    if (mode !== null && MODE_TO_SOURCE[mode] !== src) return false;
    if (cluster === null) return true;
    if (mode === "where" && src === "places") {
      return (f.properties.public_label || "_base") === cluster;
    }
    if (mode === "eat" && src === "eat") {
      return EAT_CUISINE_TO_SLUG[f.properties.cuisine] === cluster;
    }
    if (mode === "stay" && src === "stay") {
      return f.properties.primary_cat === cluster;
    }
    return true;
  }
  function applyCategoryFilter() {
    if (!allFeatures || !map || !map.getSource("places")) return;
    const filtered = allFeatures.filter(passesFilter);
    // Re-setting the data triggers Mapbox to re-cluster from scratch, so
    // cluster counts update to reflect the new filter set.
    map.getSource("places").setData({
      type: "FeatureCollection",
      features: filtered,
    });
  }

  /* ---------- Segmented mode wiring ----------
     A.10 — three buttons in the legend header. Click a segment → enter
     that mode and clear any prior cluster focus (the old mode's cluster
     slug doesn't belong to the new mode's taxonomy). Re-click the
     active segment → exit back to the default null mode (all sources
     visible, all three sections rendered). */
  function setupSegmentedMode() {
    document.querySelectorAll("[data-mode-btn]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.dataset.modeBtn;
        if (mode === target) {
          mode = null;
          cluster = null;
        } else {
          mode = target;
          cluster = null;
        }
        updateButtonStates();
        paintLegendFromState();
        syncURL();
        applyCategoryFilter();
      });
    });
    const reload = document.querySelector("[data-reload]");
    if (reload) reload.addEventListener("click", () => window.location.reload());
  }

  /* ---------- Toast helper for transient errors ---------- */
  function showToast(text) {
    let toast = document.querySelector(".map-toast");
    if (!toast) {
      toast = document.createElement("div");
      toast.className = "map-toast";
      document.querySelector(".map-main").appendChild(toast);
    }
    toast.textContent = text;
    toast.hidden = false;
    clearTimeout(toast._dismissTimer);
    toast._dismissTimer = setTimeout(() => {
      toast.hidden = true;
    }, 3000);
  }

  function showErrorOverlay() {
    const err = document.querySelector("[data-error]");
    if (err) err.hidden = false;
    const loading = document.querySelector("[data-loading]");
    if (loading) loading.hidden = true;
  }

  /* ---------- Legend caret ----------
     A.10 — caret toggles the body. Two-state semantics:
       Desktop: aria-expanded=true (open) ↔ false (body removed entirely).
       Mobile:  aria-expanded=true (full body, ~380px max + scroll) ↔
                aria-expanded=false (peek, ~140px of body visible,
                ≈ first 3 cluster rows). Mobile default = peek so the
                legend is visible without a tap. Both states are driven
                by the same `body.hidden` attribute — the mobile media
                query overrides display:none to render the peek slice. */
  function setupLegend() {
    const toggle = document.querySelector("[data-legend-toggle]");
    const body = document.querySelector("[data-legend-list]");
    if (!toggle || !body) return;
    if (window.matchMedia("(pointer: coarse)").matches) {
      toggle.setAttribute("aria-expanded", "false");
      body.hidden = true;
    }
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      body.hidden = expanded;
    });
  }

  /* ---------- Legend row focus (Phase A.9 C5) ----------
     Click-to-focus, single-select within the active mode's section.
     Clicking a row in a section whose source doesn't match the active
     mode auto-enters that mode (so clicking "Ramen" inside Eat while
     in Where-mode flips to Eat-mode and focuses Ramen). This keeps
     the row-click as a single-tap action even when the user hasn't
     pre-selected a mode chip — friendlier than ignoring the click.
     Row visual contract: data-active="true" = visible/normal style;
     data-active="false" = dimmed (used when a peer in the same section
     IS focused). aria-pressed mirrors "this row is the current focus". */
  function paintLegendFromState() {
    document.querySelectorAll("[data-legend-row]").forEach((row) => {
      const src = row.dataset.legendRow;
      const slug = row.dataset.value;
      // Cluster is only meaningful when its source matches the mode.
      const sectionHasFocus =
        cluster !== null && mode !== null && MODE_TO_SOURCE[mode] === src;
      const on = sectionHasFocus ? cluster === slug : true;
      row.dataset.active = String(on);
      row.setAttribute("aria-pressed", String(sectionHasFocus && cluster === slug));
    });
  }

  function setupLegendRows() {
    function activate(row) {
      // C6: rows in empty sections are decorative only — pointer-events
      // already blocks clicks, but keyboard activation also gates here.
      if (row.getAttribute("aria-disabled") === "true") return;
      const src = row.dataset.legendRow;
      const slug = row.dataset.value;
      const targetMode = Object.entries(MODE_TO_SOURCE)
        .find(([, s]) => s === src)[0];
      if (mode === targetMode && cluster === slug) {
        // Clicking the focused row in the active mode clears the cluster
        // but stays in the mode — consistent with chip behaviour where
        // re-clicking exits one layer at a time.
        cluster = null;
      } else {
        mode = targetMode;
        cluster = slug;
      }
      updateButtonStates();
      paintLegendFromState();
      syncURL();
      applyCategoryFilter();
    }
    document.querySelectorAll("[data-legend-row]").forEach((row) => {
      row.addEventListener("click", () => activate(row));
      row.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          activate(row);
        }
      });
    });
  }

  /* ---------- Init ---------- */
  readModeFromURL();
  setupSegmentedMode();
  setupLegend();
  setupLegendRows();
  updateButtonStates();
  paintLegendFromState();
  // Self-clean any legacy ?places=/?eat=/?stay=/?categories= params
  // that readModeFromURL migrated into mode/cluster.
  syncURL();

  // MAP_INIT centralizes style/center/zoom/hash so MapView.astro on
  // /places-map and /eat-map opens at the same viewport. Mapbox-native
  // hash sync (#zoom/lat/lng) lives there too.
  map = new mapboxgl.Map({
    container: "japan-map",
    ...MAP_INIT,
  });

  // Mapbox auth/network errors → show the error overlay instead of
  // silent blank-gray. Dedupe so repeated tile failures don't bounce.
  map.on("error", (e) => {
    if (mapErrored) return;
    const err = e && e.error ? e.error : {};
    const status = err.status;
    const msg = err.message || "";
    if (status === 401 || status === 403 || /unauthorized|forbidden|access token/i.test(msg)) {
      mapErrored = true;
      showErrorOverlay();
    }
  });

  // Geolocate control — brand-styled via global CSS overrides above.
  const geolocate = new mapboxgl.GeolocateControl({
    positionOptions: { enableHighAccuracy: true, timeout: 6000 },
    trackUserLocation: false,
    showAccuracyCircle: false,
    showUserLocation: true,
    fitBoundsOptions: { maxZoom: 12 },
  });
  map.addControl(geolocate, "bottom-right");
  geolocate.on("error", () => showToast("Location unavailable"));

  /* Loading-overlay dismiss strategy — three layers of safety so the
     overlay never gets stuck visible:
       1. Primary: 'load' event (fires when the style + initial tiles
          are loaded). This is the canonical trigger.
       2. Backup: 'idle' event (fires whenever the map reaches a stable
          rendered state). 'idle' fires repeatedly, so even if a late
          listener attaches after 'load', the first idle dismisses.
       3. Hard fallback: 5-second timeout. If both events miss for any
          reason, the overlay self-dismisses. The error overlay (see
          map.on('error')) still surfaces auth/tile failures separately. */
  function dismissLoadingOverlay() {
    const loading = document.querySelector("[data-loading]");
    if (loading) loading.hidden = true;
  }
  setTimeout(dismissLoadingOverlay, 5000);
  map.once("idle", dismissLoadingOverlay);

  map.on("load", () => {
    dismissLoadingOverlay();

    fetch("/places.geojson")
      .then((r) => {
        if (!r.ok) throw new Error("geojson fetch failed: " + r.status);
        return r.json();
      })
      .then((data) => {
        allFeatures = data.features;
        initLayers();
      })
      .catch((err) => {
        console.error("places.geojson load failed", err);
        showErrorOverlay();
      });
  });

  /* ---------- Add source + layers (after geojson loads) ---------- */
  function initLayers() {
    const filtered = allFeatures.filter(passesFilter);
    map.addSource("places", {
      type: "geojson",
      data: { type: "FeatureCollection", features: filtered },
      cluster: true,
      clusterMaxZoom: 14,
      clusterRadius: 50,
    });

    // Plain numbered cluster bubbles: Rice White fill, Concrete Gray
    // border, max radius 50. (Donut clusters considered + rejected as
    // over-engineered for an editorial site — category buttons solve
    // cluster-ambiguity better than visual donuts.)
    map.addLayer({
      id: "clusters",
      type: "circle",
      source: "places",
      filter: ["has", "point_count"],
      paint: {
        "circle-color": "#F7F3EA",
        "circle-stroke-color": "#E6E1D8",
        "circle-stroke-width": 1.5,
        "circle-radius": [
          "step",
          ["get", "point_count"],
          20,
          25, 30,
          100, 40,
          250, 50,
        ],
      },
    });
    map.addLayer({
      id: "cluster-count",
      type: "symbol",
      source: "places",
      filter: ["has", "point_count"],
      layout: {
        "text-field": ["get", "point_count_abbreviated"],
        "text-font": ["Open Sans Bold", "Arial Unicode MS Bold"],
        "text-size": 11,
      },
      paint: { "text-color": "#151515" },
    });

    // /places pins: coloured by public_label (sub-category). 13 distinct
    // colours give at-a-glance regional scan-ability ("this area is mostly
    // culture", "lots of workshops here") that the old My Maps had and the
    // primary_category-only colouring lost. Empty public_label (base-tier
    // rows: ~22 places like base towns / stay bases) falls through to
    // Concrete Gray. Paint expression imported from map-legends.js — it's
    // built from the same dict the legend swatches read, so colour →
    // category drift across the two is structurally impossible.
    map.addLayer({
      id: "unclustered-places",
      type: "circle",
      source: "places",
      filter: [
        "all",
        ["!", ["has", "point_count"]],
        ["==", ["get", "source"], "places"],
      ],
      paint: {
        "circle-color": PLACES_PAINT_COLOR,
        "circle-radius": 6,
        "circle-stroke-width": 1.5,
        "circle-stroke-color": "#151515",
      },
    });

    // /eat (Tabelog) pins: open-ring style — white fill + thick Tokyo Red
    // stroke. Reads as a "ring" at small map scale, clearly distinct from
    // the solid /places pins. The Tokyo Red echoes the Tabelog filter
    // button's accent so the legend↔pin connection is immediate.
    map.addLayer({
      id: "unclustered-eat",
      type: "circle",
      source: "places",
      filter: [
        "all",
        ["!", ["has", "point_count"]],
        ["==", ["get", "source"], "eat"],
      ],
      paint: {
        "circle-color": EAT_RING_FILL,
        "circle-radius": 6,
        "circle-stroke-width": 2.5,
        "circle-stroke-color": EAT_RING_STROKE,
      },
    });

    // Phase A.9 stay pins: solid Aizome Indigo fill, ink stroke. Distinct
    // from /places (different hue, not in the 13-cluster palette) and from
    // /eat (solid fill, not the open ring). The 9 sub-cats share one fill —
    // legend rows are the filter axis (wired in C3), colour stays per-source.
    // The seed currently has no lat/lng, so this layer renders zero markers
    // until the D7-style enrichment pass populates coordinates.
    map.addLayer({
      id: "unclustered-stays",
      type: "circle",
      source: "places",
      filter: [
        "all",
        ["!", ["has", "point_count"]],
        ["==", ["get", "source"], "stay"],
      ],
      paint: {
        "circle-color": STAY_PIN_COLOR,
        "circle-radius": 6,
        "circle-stroke-width": 1.5,
        "circle-stroke-color": "#151515",
      },
    });

    // Cluster click: expand the cluster (zoom in until it bursts).
    map.on("click", "clusters", (e) => {
      const f = map.queryRenderedFeatures(e.point, { layers: ["clusters"] })[0];
      const id = f.properties.cluster_id;
      map.getSource("places").getClusterExpansionZoom(id, (err, zoom) => {
        if (err) return;
        map.easeTo({ center: f.geometry.coordinates, zoom });
      });
    });

    // Popup builder — branches on source. Built lazily on click, no
    // pre-rendering of popup templates or eager hero-image fetches.
    function buildPopupHTML(p) {
      const img = p.hero_image
        ? `<img src="${p.hero_image}" alt="" loading="lazy" class="map-popup-img" />`
        : `<div class="map-popup-img" aria-hidden="true"></div>`;
      if (p.source === "eat") {
        const meta = [];
        if (p.cuisine) meta.push(p.cuisine);
        if (p.price_tier) meta.push(p.price_tier);
        const metaLine = meta.join(" · ");
        const provenance = p.list_year
          ? `${p.list_year} Tabelog Hyakumeiten${
              p.is_shokudo ? " (Shokudo)" : ""
            }${p.rank_in_city ? ` · #${p.rank_in_city} in ${p.city || ""}` : ""}`
          : "";
        const nameHTML = p.name_jp
          ? `${p.name} <span class="map-popup-jp">${p.name_jp}</span>`
          : p.name;
        // Anchor-link CTA: /eat#<slug> lands on the matching card, which
        // self-highlights for 2s via the :target rule in RestaurantCard.
        const href = p.slug ? `/eat#${p.slug}` : "/eat";
        return `
          <div class="map-popup">
            ${img}
            <div class="map-popup-text">
              <h3 class="map-popup-name">${nameHTML}</h3>
              ${metaLine ? `<p class="map-popup-area">${metaLine}</p>` : ""}
              ${provenance ? `<p class="map-popup-area">${provenance}</p>` : ""}
              <a class="map-popup-link" href="${href}">More about this restaurant →</a>
            </div>
          </div>
        `;
      }
      if (p.source === "stay") {
        // CTA: external hotel site (no /stay detail route this phase).
        // STAY_SLUG_TO_LABEL imported from map-legends.js — same data
        // the legend renders, so popup labels can't drift from legend.
        const where = [p.city, p.prefecture].filter(Boolean).join(", ");
        const meta = [STAY_SLUG_TO_LABEL[p.primary_cat] || p.primary_cat, p.price_tier]
          .filter(Boolean)
          .join(" · ");
        const nameHTML = p.name_jp
          ? `${p.name} <span class="map-popup-jp">${p.name_jp}</span>`
          : p.name;
        const externalLink = p.source_url
          ? `<a class="map-popup-link" href="${p.source_url}" target="_blank" rel="noopener">Visit hotel site →</a>`
          : "";
        return `
          <div class="map-popup">
            ${img}
            <div class="map-popup-text">
              <h3 class="map-popup-name">${nameHTML}</h3>
              ${where ? `<p class="map-popup-area">${where}</p>` : ""}
              ${meta ? `<p class="map-popup-area">${meta}</p>` : ""}
              ${externalLink}
            </div>
          </div>
        `;
      }
      // /places branch
      const area = p.address_or_area || "";
      // Anchor-link CTA: /places#<slug> lands on the matching card,
      // which self-highlights for 2s via the :target rule in PlaceCard.
      const href = p.slug ? `/places#${p.slug}` : "/places";
      return `
        <div class="map-popup">
          ${img}
          <div class="map-popup-text">
            <h3 class="map-popup-name">${p.name || ""}</h3>
            ${area ? `<p class="map-popup-area">${area}</p>` : ""}
            <a class="map-popup-link" href="${href}">More about this place →</a>
          </div>
        </div>
      `;
    }

    for (const layer of ["unclustered-places", "unclustered-eat", "unclustered-stays"]) {
      map.on("click", layer, (e) => {
        const f = e.features[0];
        const coords = f.geometry.coordinates.slice();
        new mapboxgl.Popup({ offset: 8 })
          .setLngLat(coords)
          .setHTML(buildPopupHTML(f.properties))
          .addTo(map);
      });
    }

    for (const layer of [
      "clusters",
      "unclustered-places",
      "unclustered-eat",
      "unclustered-stays",
    ]) {
      map.on("mouseenter", layer, () => {
        map.getCanvas().style.cursor = "pointer";
      });
      map.on("mouseleave", layer, () => {
        map.getCanvas().style.cursor = "";
      });
    }
  }

  /* ---------- Mobile scroll-zoom gating ---------- */
  if (window.matchMedia("(pointer: coarse)").matches) {
    map.scrollZoom.disable();
    map.touchZoomRotate.disable();
    const hint = document.querySelector("[data-hint]");
    if (hint) hint.hidden = false;
    const activate = () => {
      map.scrollZoom.enable();
      map.touchZoomRotate.enable();
      if (hint) hint.hidden = true;
    };
    map.once("click", activate);
  }
</script>
