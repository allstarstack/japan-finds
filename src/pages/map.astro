---
/* /map — standalone Mapbox view of every geocoded place.
   Phase A.8: sub-category pin coloring (13 distinct colors keyed off
   public_label) + bottom-left legend + click-to-include filter chips.

   Data: /places.geojson is generated at build time by
   scripts/generate-geojson.mjs. Filter state is layered:
     - Primary-category filter (4 click-to-include chips; URL ?categories=)
       Default: no chips active = show all pins. Click chip → adds to
       active set. Pins shown iff their primary_category is in the
       active set OR active set is empty.
     - Sub-category pin colour by public_label (independent of filter).
     - URL hash (#zoom/lat/lng) via Mapbox-native hash:true.
     - Lazy popup HTML built on click (not pre-rendered per pin).

   Sub-category palette is the single source of truth for the Mapbox
   paint expression AND the rendered legend — keep both in sync. */
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";

const SUBCAT_LEGEND = [
  { value: "nature_water",     label: "Nature & Water",     color: "#176BFF" },
  { value: "culture_history",  label: "Culture & History",  color: "#FF3B30" },
  { value: "animals",          label: "Animals",            color: "#4D8B57" },
  { value: "quirky_museums",   label: "Quirky Museums",     color: "#7B3FA0" },
  { value: "anime",            label: "Anime",              color: "#E91E63" },
  { value: "onsen_ryokan",     label: "Onsen & Ryokan",     color: "#9B7EBD" },
  { value: "photo_spots",      label: "Photo Spots",        color: "#FF6B6B" },
  { value: "scenic_transport", label: "Scenic Transport",   color: "#FF9800" },
  { value: "theme_parks",      label: "Theme Parks",        color: "#FFD84D" },
  { value: "parks",            label: "Parks",              color: "#A4C49C" },
  { value: "workshops_crafts", label: "Workshops & Crafts", color: "#8B5A2B" },
  { value: "food_markets",     label: "Food Markets",       color: "#D4A017" },
  { value: "cafes",            label: "Cafes",              color: "#D2B48C" },
];
---

<Base
  title="Japan map — Japan Finds"
  description="Interactive map of every place on Japan Finds — nature, food markets, museums, onsen, theme parks, anime pilgrimage sites and more."
>
  <Header />
  <main id="main" class="map-main">
    <div class="map-toolbar">
      <div
        class="map-cat-filters"
        role="group"
        aria-label="Filter map by category"
      >
        <button type="button" class="map-cat map-cat--see" data-cat-btn="See" aria-pressed="true">See</button>
        <button type="button" class="map-cat map-cat--do" data-cat-btn="Do" aria-pressed="true">Do</button>
        <button type="button" class="map-cat map-cat--eat" data-cat-btn="Eat" aria-pressed="true">Eat</button>
        <button type="button" class="map-cat map-cat--stay" data-cat-btn="Stay" aria-pressed="true">Stay</button>
      </div>
      <button type="button" class="map-reset" data-reset hidden>Reset</button>
    </div>

    <div id="japan-map" aria-label="Interactive map of Japan Finds places"></div>

    <p class="map-hint" hidden data-hint>Tap the map to enable zoom</p>

    <div class="map-loading" data-loading>
      <span class="map-loading-spinner" aria-hidden="true"></span>
      <span class="map-loading-text">Loading map…</span>
    </div>

    <div class="map-legend" data-legend>
      <button
        type="button"
        class="map-legend-toggle"
        data-legend-toggle
        aria-expanded="true"
        aria-controls="map-legend-list"
      >
        <span class="map-legend-toggle-text">Legend</span>
        <span class="map-legend-chev" aria-hidden="true">▾</span>
      </button>
      <ul id="map-legend-list" class="map-legend-list" data-legend-list>
        {
          SUBCAT_LEGEND.map((c) => (
            <li>
              <span
                class="map-legend-swatch"
                style={`background:${c.color}`}
                aria-hidden="true"
              />
              <span>{c.label}</span>
            </li>
          ))
        }
        <li>
          <span class="map-legend-swatch map-legend-swatch--ring" aria-hidden="true" />
          <span>Tabelog restaurants</span>
        </li>
        <li>
          <span
            class="map-legend-swatch"
            style="background:#999999"
            aria-hidden="true"
          />
          <span>Base towns</span>
        </li>
      </ul>
    </div>

    <div class="map-error" hidden data-error role="alert">
      <div class="map-error-card">
        <p class="map-error-text">Map unavailable — please refresh.</p>
        <button type="button" class="map-error-reload" data-reload>Reload page</button>
      </div>
    </div>
  </main>
  <SiteFooter />
</Base>

<style is:global>
  /* Popup overrides — Mapbox creates these dynamically, so global rules. */
  .mapboxgl-popup-content {
    padding: 0;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }
  .mapboxgl-popup-tip { display: none; }
  .mapboxgl-popup-close-button {
    color: var(--color-ink-black);
    font-size: 18px;
    padding: 2px 8px;
    line-height: 1;
  }
  .map-popup {
    display: flex;
    gap: 10px;
    padding: 10px;
    min-width: 220px;
    max-width: 280px;
  }
  .map-popup-img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    flex-shrink: 0;
    border-radius: var(--radius-sm);
    background: var(--color-concrete-gray);
  }
  .map-popup-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 3px;
    min-width: 0;
    flex: 1;
  }
  .map-popup-name {
    margin: 0;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 14px;
    line-height: 1.2;
    color: var(--color-ink-black);
  }
  .map-popup-area {
    margin: 0;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 11px;
    color: var(--color-ink-60);
    letter-spacing: 0.02em;
  }
  .map-popup-jp {
    margin-left: 4px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-ink-60);
  }
  .map-popup-link {
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ink-black);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Geolocate control — brand-style the default Mapbox button. */
  .mapboxgl-ctrl-group {
    background: var(--color-rice-white) !important;
    border: 1.5px solid var(--color-ink-black) !important;
    border-radius: var(--radius-sm) !important;
    box-shadow: var(--shadow-sm) !important;
  }
  .mapboxgl-ctrl-group button {
    width: 36px !important;
    height: 36px !important;
  }
  .mapboxgl-ctrl-group button:not(:disabled):hover {
    background: var(--color-rice-tint) !important;
  }
  .mapboxgl-ctrl-attrib {
    background: rgba(247, 243, 234, 0.85) !important;
  }
</style>

<style>
  .map-main {
    position: relative;
    padding: 0;
  }
  #japan-map {
    width: 100%;
    height: 95vh;
    background: var(--color-concrete-gray);
  }

  /* Toolbar floats absolutely so the map keeps its full 95vh. */
  .map-toolbar {
    position: absolute;
    top: 12px;
    left: 12px;
    right: 12px;
    z-index: 12;
    display: flex;
    align-items: center;
    gap: 10px;
    pointer-events: none; /* let the map receive drags through gaps */
  }
  .map-cat-filters {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    pointer-events: auto;
  }
  .map-reset {
    pointer-events: auto;
    padding: 6px 10px;
    background: transparent;
    border: none;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
  }
  .map-reset:hover { color: var(--color-tokyo-red); }

  /* Category filter buttons. Active state shows a 2px inset accent ring
     in the category colour. Inactive state dims via opacity. */
  .map-cat {
    padding: 6px 12px;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    cursor: pointer;
    transition:
      box-shadow 120ms ease-out,
      opacity 120ms ease-out;
    box-shadow: var(--shadow-sm);
  }
  /* Click-to-include filter chips (Phase A.8): chips default INACTIVE
     (outline only, no colored ring, no opacity dim). Click → adds to
     filter set; the colored inset ring marks the active state. Empty
     active set = no filter = show all pins (the default). Ring width
     3px (vs 2px) for stronger colour legibility at button size. */
  .map-cat[aria-pressed="true"].map-cat--see { box-shadow: inset 0 0 0 3px #176bff, var(--shadow-sm); }
  .map-cat[aria-pressed="true"].map-cat--do { box-shadow: inset 0 0 0 3px #ff3b30, var(--shadow-sm); }
  .map-cat[aria-pressed="true"].map-cat--eat { box-shadow: inset 0 0 0 3px #ffd84d, var(--shadow-sm); }
  .map-cat[aria-pressed="true"].map-cat--stay { box-shadow: inset 0 0 0 3px #3f7548, var(--shadow-sm); }

  /* Mobile tap-to-activate hint (revealed by JS on coarse-pointer). */
  .map-hint {
    position: absolute;
    top: 60px;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    padding: 6px 14px;
    background: var(--color-ink-black);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: var(--radius-pill);
    z-index: 11;
    pointer-events: none;
    box-shadow: var(--shadow-sm);
  }

  /* Loading state: visible before Mapbox 'load' event fires. The
     `[hidden]` override is required because the explicit `display:
     inline-flex` rule below outranks the UA `[hidden] { display: none }`
     in CSS specificity — same gotcha as .plc[hidden] / .pchip[hidden]
     elsewhere in the codebase. Without this, setting loading.hidden=true
     in JS sets the attribute but the overlay stays visible. */
  .map-loading {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    z-index: 13;
  }
  .map-loading[hidden] { display: none; }
  .map-loading-spinner {
    width: 14px;
    height: 14px;
    border: 2px solid var(--color-concrete-gray);
    border-top-color: var(--color-ink-black);
    border-radius: 50%;
    animation: map-spin 0.7s linear infinite;
  }
  @keyframes map-spin {
    to { transform: rotate(360deg); }
  }

  /* Legend panel — bottom-left, brand-styled. Desktop default open;
     mobile default collapsed (JS sets aria-expanded=false + list[hidden]
     on coarse-pointer devices). */
  .map-legend {
    position: absolute;
    bottom: 24px;
    left: 12px;
    z-index: 11;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-concrete-gray);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-sm);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ink-black);
    max-width: 220px;
  }
  .map-legend-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: transparent;
    border: none;
    font: inherit;
    color: inherit;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    width: 100%;
    text-align: left;
  }
  .map-legend-toggle-text { flex: 1; }
  .map-legend-chev {
    transition: transform 120ms ease-out;
  }
  .map-legend-toggle[aria-expanded="false"] .map-legend-chev {
    transform: rotate(-90deg);
  }
  .map-legend-list {
    list-style: none;
    margin: 0;
    padding: 0 12px 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .map-legend-list[hidden] { display: none; }
  .map-legend-list li {
    display: flex;
    align-items: center;
    gap: 8px;
    line-height: 1.3;
    text-transform: none;
    letter-spacing: 0;
  }
  .map-legend-swatch {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1.5px solid var(--color-ink-black);
    flex-shrink: 0;
  }
  /* Tabelog swatch mirrors the /eat pin styling — white fill, thick red ring. */
  .map-legend-swatch--ring {
    background: #ffffff;
    border-color: #ff3b30;
    border-width: 2.5px;
  }

  /* Error overlay — auth/network failure. Replaces the silent blank gray. */
  .map-error {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 14;
  }
  .map-error-card {
    padding: 16px 20px;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-tokyo-red);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-md);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
  }
  .map-error-text {
    margin: 0;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 15px;
    color: var(--color-ink-black);
  }
  .map-error-reload {
    padding: 6px 14px;
    background: var(--color-ink-black);
    color: #fff;
    border: none;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
  }

  /* Inline toast (geolocation denied, etc.) — auto-dismisses in 3s. */
  :global(.map-toast) {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 14px;
    background: var(--color-ink-black);
    color: #fff;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    z-index: 15;
    box-shadow: var(--shadow-sm);
  }

  /* Mobile: compact category buttons, full toolbar width. */
  @media (max-width: 640px) {
    .map-toolbar {
      top: 8px;
      left: 8px;
      right: 8px;
      gap: 6px;
    }
    .map-cat {
      padding: 5px 8px;
      font-size: 10px;
      letter-spacing: 0.02em;
    }
    .map-cat-filters {
      flex: 1;
      justify-content: space-between;
    }
    .map-reset {
      font-size: 10px;
      padding: 5px 6px;
    }
  }
</style>

<script>
  import mapboxgl from "mapbox-gl";
  import "mapbox-gl/dist/mapbox-gl.css";

  // Inlined at build time. On Vercel = real production token; localhost
  // with the .env placeholder will 401-fail (caught by the error overlay).
  mapboxgl.accessToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;

  // Four filter chips matching the See/Do/Eat/Stay primary_category
  // groupings. "Eat" covers BOTH /places primary_category=Eat (food
  // markets + cafés) AND /eat source items (Tabelog Hyakumeiten). The
  // Tabelog curation signal stays visible in pin styling (open-ring vs
  // solid-fill) and popup content (year + rank + Hyakumeiten label) —
  // it just doesn't get its own filter button. Splitting curation
  // source from content type in the filter UI confused first-time
  // users; one Eat chip is cleaner.
  const ALL_CATS = ["See", "Do", "Eat", "Stay"];
  let activeCats;
  let allFeatures = null; // fetched once; filter rebuilds source.data
  let map;
  let mapErrored = false;

  /* ---------- URL query state for ?categories= ----------
     Phase A.8: click-to-include semantics. Param lists ACTIVE chips
     only; missing param OR empty value = no chips active = show all.
     Backward-compat: old links from Phase A.6 (?categories=tabelog)
     route to Eat; old links from Phase A.7 with the full 4-chip list
     activate all 4 (which functionally shows all under the new
     default-show-all semantics — visual chip state differs but pin
     set is identical). */
  function readCategoriesFromURL() {
    const p = new URLSearchParams(window.location.search);
    if (!p.has("categories")) return new Set(); // omitted = no filter (show all)
    const raw = p.get("categories");
    if (raw === "") return new Set(); // explicit empty = no filter (show all)
    const cats = raw
      .split(",")
      .map((s) => s.trim().toLowerCase())
      .filter(Boolean)
      .map((s) => (s === "tabelog" ? "eat" : s))
      .map((s) => s.charAt(0).toUpperCase() + s.slice(1))
      .filter((c) => ALL_CATS.includes(c));
    return new Set(cats);
  }

  function syncCategoriesToURL() {
    const p = new URLSearchParams(window.location.search);
    // No active chips = default state = omit param (cleaner URLs).
    if (activeCats.size === 0) {
      p.delete("categories");
    } else {
      p.set(
        "categories",
        Array.from(activeCats).map((c) => c.toLowerCase()).join(","),
      );
    }
    const qs = p.toString();
    const newURL =
      window.location.pathname +
      (qs ? "?" + qs : "") +
      window.location.hash;
    history.replaceState(null, "", newURL);
  }

  /* ---------- UI state sync ----------
     Reset link is visible when ANY chip is active (i.e. not at the
     default "all inactive = show all" state). Empty-state overlay is
     gone — under click-to-include semantics, "no chips active" means
     "show all", which is the desired default, not an empty result. */
  function updateButtonStates() {
    document.querySelectorAll("[data-cat-btn]").forEach((btn) => {
      const c = btn.dataset.catBtn;
      btn.setAttribute("aria-pressed", String(activeCats.has(c)));
    });
    const reset = document.querySelector("[data-reset]");
    if (reset) reset.hidden = activeCats.size === 0;
  }

  /* ---------- Map filtering ----------
     Click-to-include: empty active set = no filter = show every pin
     (default state, matches user intuition). When chips are active,
     features pass iff their category is in the active set. /eat
     (Tabelog) features map to the Eat chip — toggling Eat shows
     both /places food markets/cafés AND /eat Tabelog restaurants. */
  function passesFilter(f) {
    if (activeCats.size === 0) return true;
    if (f.properties.source === "eat") return activeCats.has("Eat");
    return activeCats.has(f.properties.primary_category);
  }
  function applyCategoryFilter() {
    if (!allFeatures || !map || !map.getSource("places")) return;
    const filtered = allFeatures.filter(passesFilter);
    // Re-setting the data triggers Mapbox to re-cluster from scratch, so
    // cluster counts update to reflect the new filter set.
    map.getSource("places").setData({
      type: "FeatureCollection",
      features: filtered,
    });
  }

  /* ---------- Button + reset wiring ---------- */
  function setupCategoryButtons() {
    document.querySelectorAll("[data-cat-btn]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const c = btn.dataset.catBtn;
        if (activeCats.has(c)) activeCats.delete(c);
        else activeCats.add(c);
        updateButtonStates();
        syncCategoriesToURL();
        applyCategoryFilter();
      });
    });
    const reset = document.querySelector("[data-reset]");
    if (reset)
      reset.addEventListener("click", () => {
        // Reset → default state (no active filters = show all).
        activeCats = new Set();
        updateButtonStates();
        syncCategoriesToURL();
        applyCategoryFilter();
      });
    const reload = document.querySelector("[data-reload]");
    if (reload) reload.addEventListener("click", () => window.location.reload());
  }

  /* ---------- Toast helper for transient errors ---------- */
  function showToast(text) {
    let toast = document.querySelector(".map-toast");
    if (!toast) {
      toast = document.createElement("div");
      toast.className = "map-toast";
      document.querySelector(".map-main").appendChild(toast);
    }
    toast.textContent = text;
    toast.hidden = false;
    clearTimeout(toast._dismissTimer);
    toast._dismissTimer = setTimeout(() => {
      toast.hidden = true;
    }, 3000);
  }

  function showErrorOverlay() {
    const err = document.querySelector("[data-error]");
    if (err) err.hidden = false;
    const loading = document.querySelector("[data-loading]");
    if (loading) loading.hidden = true;
  }

  /* ---------- Legend toggle ----------
     Desktop default open; collapse on coarse-pointer (mobile/tablet) so
     it doesn't eat half the map. Click the header bar to expand/collapse. */
  function setupLegend() {
    const toggle = document.querySelector("[data-legend-toggle]");
    const list = document.querySelector("[data-legend-list]");
    if (!toggle || !list) return;
    if (window.matchMedia("(pointer: coarse)").matches) {
      toggle.setAttribute("aria-expanded", "false");
      list.hidden = true;
    }
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      list.hidden = expanded;
    });
  }

  /* ---------- Init ---------- */
  activeCats = readCategoriesFromURL();
  setupCategoryButtons();
  setupLegend();
  updateButtonStates();

  map = new mapboxgl.Map({
    container: "japan-map",
    style: "mapbox://styles/mapbox/light-v11",
    center: [138, 36],
    zoom: 4.5,
    minZoom: 4,
    maxZoom: 18,
    // Mapbox-native URL hash sync. Format: #zoom/lat/lng[/bearing/pitch].
    // Note: user spec said #lng/lat/zoom — Mapbox's native order is
    // zoom/lat/lng. If a custom order is wanted later, replace with custom
    // moveend+zoomend handlers writing window.location.hash.
    hash: true,
  });

  // Mapbox auth/network errors → show the error overlay instead of
  // silent blank-gray. Dedupe so repeated tile failures don't bounce.
  map.on("error", (e) => {
    if (mapErrored) return;
    const err = e && e.error ? e.error : {};
    const status = err.status;
    const msg = err.message || "";
    if (status === 401 || status === 403 || /unauthorized|forbidden|access token/i.test(msg)) {
      mapErrored = true;
      showErrorOverlay();
    }
  });

  // Geolocate control — brand-styled via global CSS overrides above.
  const geolocate = new mapboxgl.GeolocateControl({
    positionOptions: { enableHighAccuracy: true, timeout: 6000 },
    trackUserLocation: false,
    showAccuracyCircle: false,
    showUserLocation: true,
    fitBoundsOptions: { maxZoom: 12 },
  });
  map.addControl(geolocate, "bottom-right");
  geolocate.on("error", () => showToast("Location unavailable"));

  /* Loading-overlay dismiss strategy — three layers of safety so the
     overlay never gets stuck visible:
       1. Primary: 'load' event (fires when the style + initial tiles
          are loaded). This is the canonical trigger.
       2. Backup: 'idle' event (fires whenever the map reaches a stable
          rendered state). 'idle' fires repeatedly, so even if a late
          listener attaches after 'load', the first idle dismisses.
       3. Hard fallback: 5-second timeout. If both events miss for any
          reason, the overlay self-dismisses. The error overlay (see
          map.on('error')) still surfaces auth/tile failures separately. */
  function dismissLoadingOverlay() {
    const loading = document.querySelector("[data-loading]");
    if (loading) loading.hidden = true;
  }
  setTimeout(dismissLoadingOverlay, 5000);
  map.once("idle", dismissLoadingOverlay);

  map.on("load", () => {
    dismissLoadingOverlay();

    fetch("/places.geojson")
      .then((r) => {
        if (!r.ok) throw new Error("geojson fetch failed: " + r.status);
        return r.json();
      })
      .then((data) => {
        allFeatures = data.features;
        initLayers();
      })
      .catch((err) => {
        console.error("places.geojson load failed", err);
        showErrorOverlay();
      });
  });

  /* ---------- Add source + layers (after geojson loads) ---------- */
  function initLayers() {
    const filtered = allFeatures.filter(passesFilter);
    map.addSource("places", {
      type: "geojson",
      data: { type: "FeatureCollection", features: filtered },
      cluster: true,
      clusterMaxZoom: 14,
      clusterRadius: 50,
    });

    // Plain numbered cluster bubbles: Rice White fill, Concrete Gray
    // border, max radius 50. (Donut clusters considered + rejected as
    // over-engineered for an editorial site — category buttons solve
    // cluster-ambiguity better than visual donuts.)
    map.addLayer({
      id: "clusters",
      type: "circle",
      source: "places",
      filter: ["has", "point_count"],
      paint: {
        "circle-color": "#F7F3EA",
        "circle-stroke-color": "#E6E1D8",
        "circle-stroke-width": 1.5,
        "circle-radius": [
          "step",
          ["get", "point_count"],
          20,
          25, 30,
          100, 40,
          250, 50,
        ],
      },
    });
    map.addLayer({
      id: "cluster-count",
      type: "symbol",
      source: "places",
      filter: ["has", "point_count"],
      layout: {
        "text-field": ["get", "point_count_abbreviated"],
        "text-font": ["Open Sans Bold", "Arial Unicode MS Bold"],
        "text-size": 11,
      },
      paint: { "text-color": "#151515" },
    });

    // /places pins: coloured by public_label (sub-category). 13 distinct
    // colours give at-a-glance regional scan-ability ("this area is mostly
    // culture", "lots of workshops here") that the old My Maps had and the
    // primary_category-only colouring lost. Empty public_label (base-tier
    // rows: ~22 places like base towns / stay bases) falls through to
    // Concrete Gray. Keep this expression in sync with SUBCAT_LEGEND in
    // the frontmatter — both render the same color → category mapping.
    map.addLayer({
      id: "unclustered-places",
      type: "circle",
      source: "places",
      filter: [
        "all",
        ["!", ["has", "point_count"]],
        ["==", ["get", "source"], "places"],
      ],
      paint: {
        "circle-color": [
          "match",
          ["get", "public_label"],
          "nature_water", "#176BFF",
          "culture_history", "#FF3B30",
          "animals", "#4D8B57",
          "quirky_museums", "#7B3FA0",
          "anime", "#E91E63",
          "onsen_ryokan", "#9B7EBD",
          "photo_spots", "#FF6B6B",
          "scenic_transport", "#FF9800",
          "theme_parks", "#FFD84D",
          "parks", "#A4C49C",
          "workshops_crafts", "#8B5A2B",
          "food_markets", "#D4A017",
          "cafes", "#D2B48C",
          /* base-tier / no public_label */ "#999999",
        ],
        "circle-radius": 6,
        "circle-stroke-width": 1.5,
        "circle-stroke-color": "#151515",
      },
    });

    // /eat (Tabelog) pins: open-ring style — white fill + thick Tokyo Red
    // stroke. Reads as a "ring" at small map scale, clearly distinct from
    // the solid /places pins. The Tokyo Red echoes the Tabelog filter
    // button's accent so the legend↔pin connection is immediate.
    map.addLayer({
      id: "unclustered-eat",
      type: "circle",
      source: "places",
      filter: [
        "all",
        ["!", ["has", "point_count"]],
        ["==", ["get", "source"], "eat"],
      ],
      paint: {
        "circle-color": "#FFFFFF",
        "circle-radius": 6,
        "circle-stroke-width": 2.5,
        "circle-stroke-color": "#FF3B30",
      },
    });

    // Cluster click: expand the cluster (zoom in until it bursts).
    map.on("click", "clusters", (e) => {
      const f = map.queryRenderedFeatures(e.point, { layers: ["clusters"] })[0];
      const id = f.properties.cluster_id;
      map.getSource("places").getClusterExpansionZoom(id, (err, zoom) => {
        if (err) return;
        map.easeTo({ center: f.geometry.coordinates, zoom });
      });
    });

    // Popup builder — branches on source. Built lazily on click, no
    // pre-rendering of popup templates or eager hero-image fetches.
    function buildPopupHTML(p) {
      const img = p.hero_image
        ? `<img src="${p.hero_image}" alt="" loading="lazy" class="map-popup-img" />`
        : `<div class="map-popup-img" aria-hidden="true"></div>`;
      if (p.source === "eat") {
        const meta = [];
        if (p.cuisine) meta.push(p.cuisine);
        if (p.price_tier) meta.push(p.price_tier);
        const metaLine = meta.join(" · ");
        const provenance = p.list_year
          ? `${p.list_year} Tabelog Hyakumeiten${
              p.is_shokudo ? " (Shokudo)" : ""
            }${p.rank_in_city ? ` · #${p.rank_in_city} in ${p.city || ""}` : ""}`
          : "";
        const nameHTML = p.name_jp
          ? `${p.name} <span class="map-popup-jp">${p.name_jp}</span>`
          : p.name;
        return `
          <div class="map-popup">
            ${img}
            <div class="map-popup-text">
              <h3 class="map-popup-name">${nameHTML}</h3>
              ${metaLine ? `<p class="map-popup-area">${metaLine}</p>` : ""}
              ${provenance ? `<p class="map-popup-area">${provenance}</p>` : ""}
              <a class="map-popup-link" href="/eat">View on /eat →</a>
            </div>
          </div>
        `;
      }
      // /places branch
      const area = p.address_or_area || "";
      return `
        <div class="map-popup">
          ${img}
          <div class="map-popup-text">
            <h3 class="map-popup-name">${p.name || ""}</h3>
            ${area ? `<p class="map-popup-area">${area}</p>` : ""}
            <a class="map-popup-link" href="/places">View on /places →</a>
          </div>
        </div>
      `;
    }

    for (const layer of ["unclustered-places", "unclustered-eat"]) {
      map.on("click", layer, (e) => {
        const f = e.features[0];
        const coords = f.geometry.coordinates.slice();
        new mapboxgl.Popup({ offset: 8 })
          .setLngLat(coords)
          .setHTML(buildPopupHTML(f.properties))
          .addTo(map);
      });
    }

    for (const layer of ["clusters", "unclustered-places", "unclustered-eat"]) {
      map.on("mouseenter", layer, () => {
        map.getCanvas().style.cursor = "pointer";
      });
      map.on("mouseleave", layer, () => {
        map.getCanvas().style.cursor = "";
      });
    }
  }

  /* ---------- Mobile scroll-zoom gating ---------- */
  if (window.matchMedia("(pointer: coarse)").matches) {
    map.scrollZoom.disable();
    map.touchZoomRotate.disable();
    const hint = document.querySelector("[data-hint]");
    if (hint) hint.hidden = false;
    const activate = () => {
      map.scrollZoom.enable();
      map.touchZoomRotate.enable();
      if (hint) hint.hidden = true;
    };
    map.once("click", activate);
  }
</script>
