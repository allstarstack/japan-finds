---
/* /map — standalone Mapbox view of every geocoded place.
   Phase A.8: sub-category pin coloring (13 distinct colors keyed off
   public_label) + bottom-left legend + click-to-include filter chips.

   Data: /places.geojson is generated at build time by
   scripts/generate-geojson.mjs. Filter state is layered:
     - Primary-category filter (4 click-to-include chips; URL ?categories=)
       Default: no chips active = show all pins. Click chip → adds to
       active set. Pins shown iff their primary_category is in the
       active set OR active set is empty.
     - Sub-category pin colour by public_label (independent of filter).
     - URL hash (#zoom/lat/lng) via Mapbox-native hash:true.
     - Lazy popup HTML built on click (not pre-rendered per pin).

   Sub-category palette is the single source of truth for the Mapbox
   paint expression AND the rendered legend — keep both in sync. */
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { existsSync, readFileSync } from "node:fs";

/* Where (/places) sub-category legend — Phase A.9 C3 reordered to
   "top hits first" intent priority (was legacy CSV-import order). Each
   row is a toggle filter; clicking removes its `value` from the active
   set. The `value` is the public_label slug (URL token in ?places=).
   Keep this in sync with the Mapbox paint expression below — both
   render the same color → category mapping. */
const PLACES_LEGEND = [
  { value: "nature_water",     label: "Nature & Water",     color: "#176BFF" },
  { value: "culture_history",  label: "Culture & History",  color: "#FF3B30" },
  { value: "onsen_ryokan",     label: "Onsen & Ryokan",     color: "#9B7EBD" },
  { value: "theme_parks",      label: "Theme Parks",        color: "#FFD84D" },
  { value: "anime",            label: "Anime",              color: "#E91E63" },
  { value: "cafes",            label: "Cafes",              color: "#D2B48C" },
  { value: "food_markets",     label: "Food Markets",       color: "#D4A017" },
  { value: "photo_spots",      label: "Photo Spots",        color: "#FF6B6B" },
  { value: "animals",          label: "Animals",            color: "#4D8B57" },
  { value: "workshops_crafts", label: "Workshops & Crafts", color: "#8B5A2B" },
  { value: "scenic_transport", label: "Scenic Transport",   color: "#FF9800" },
  { value: "parks",            label: "Parks",              color: "#A4C49C" },
  { value: "quirky_museums",   label: "Quirky Museums",     color: "#7B3FA0" },
  /* Base-tier rows carry empty public_label; toggling this hides them
     as a group. The `value` "_base" is a private sentinel — never appears
     in YAML, only in URL params and the in-memory active set. */
  { value: "_base",            label: "Base towns",         color: "#999999" },
];

/* Eat (/eat) cuisine legend — Phase A.9 C3 adds the 13 chip-rail
   cuisines as filter rows on /map. Source of truth: src/data/eat-chips.js
   CUISINE_CHIPS. The swatch on /map is the white-ring style (matches
   the pin paint — solid pin styling is for /eat-map only, where there's
   nothing to differentiate against). Order matches the chip rail. */
const EAT_LEGEND = [
  { value: "sushi",       cuisine: "Sushi",                  label: "Sushi" },
  { value: "tempura",     cuisine: "Tempura",                label: "Tempura" },
  { value: "unagi",       cuisine: "Unagi",                  label: "Unagi" },
  { value: "sukiyaki",    cuisine: "Sukiyaki & Shabu-shabu", label: "Sukiyaki & Shabu-shabu" },
  { value: "yakiniku",    cuisine: "Yakiniku",               label: "Yakiniku" },
  { value: "yakitori",    cuisine: "Yakitori",               label: "Yakitori" },
  { value: "tonkatsu",    cuisine: "Tonkatsu",               label: "Tonkatsu" },
  { value: "ramen",       cuisine: "Ramen",                  label: "Ramen" },
  { value: "soba",        cuisine: "Soba",                   label: "Soba" },
  { value: "udon",        cuisine: "Udon",                   label: "Udon" },
  { value: "izakaya",     cuisine: "Izakaya",                label: "Izakaya" },
  { value: "okonomiyaki", cuisine: "Okonomiyaki",            label: "Okonomiyaki" },
  { value: "shokudo",     cuisine: "Shokudo",                label: "Shokudo" },
];

/* Phase A.9 Stay sub-category legend (PHASE_A9_BUILD_SPEC §2).
   All 9 rows share Aizome Indigo — sub-category is the legend axis;
   colour stays uniform per source. Display label "Capsule & novelty"
   maps to the storage slug `capsule_themed` (slug-stable, label-mutable
   per the spec). Order is the spec's table — by row count, descending. */
const STAY_INDIGO = "#3B4F81";
const STAY_LEGEND = [
  { value: "onsen_ryokan",    label: "Onsen ryokan" },
  { value: "design_hotel",    label: "Design hotel" },
  { value: "machiya_kominka", label: "Machiya & kominka" },
  { value: "glamping",        label: "Glamping" },
  { value: "resort",          label: "Resort" },
  { value: "capsule_themed",  label: "Capsule & novelty" },
  { value: "mountain_lodge",  label: "Mountain lodge" },
  { value: "heritage_hotel",  label: "Heritage hotel" },
  { value: "temple_stay",     label: "Temple stay" },
];

/* Phase A.9 C6 — empty-state for sources with zero placed markers.
   Read at build time from the prebuild-generated geojson. If a source
   has 0 features in the file, its legend section renders a brand-voice
   message above dimmed, non-interactive rows. Generalizable to any
   source — currently triggers only for stays (D7-style lat/lng
   enrichment is the followup workstream).
   countsAvailable: false in dev-server without prebuild → empty state
   is suppressed entirely (no false-positive on a fresh checkout). */
const GEOJSON_PATH = "public/places.geojson";
const PLACED_COUNTS: Record<string, number> = { places: 0, eat: 0, stay: 0 };
let countsAvailable = false;
if (existsSync(GEOJSON_PATH)) {
  try {
    const geojson = JSON.parse(readFileSync(GEOJSON_PATH, "utf-8"));
    for (const f of geojson.features ?? []) {
      const src = f?.properties?.source;
      if (src && src in PLACED_COUNTS) PLACED_COUNTS[src]++;
    }
    countsAvailable = true;
  } catch (e) {
    console.warn("[/map] could not read", GEOJSON_PATH, e);
  }
}
const isSourceEmpty = (src: string) =>
  countsAvailable && PLACED_COUNTS[src] === 0;

// Per-source empty-state copy. Row-count substitutes for the
// "<n> categories" part. Same shape across sources so a future zero-
// placed source picks the matching template without code changes; new
// sources just add an entry here. Brand voice: short, declarative,
// no apology — "curated" signals the work is done, "verified" signals
// what's pending.
const EMPTY_STATE_MESSAGE: Record<string, (n: number) => string> = {
  places: (n) => `${n} place categories curated. Locations being verified — pins appear soon.`,
  eat: (n) => `${n} cuisine categories curated. Locations being verified — pins appear soon.`,
  stay: (n) => `${n} stay categories curated. Locations being verified — pins appear soon.`,
};
// Row count excludes the _base sentinel for /places (Base towns isn't
// a category in the human sense — it's the catchall for unlabeled
// rows). Other sources count all rows.
const PLACES_ROW_COUNT = PLACES_LEGEND.filter((c) => c.value !== "_base").length;
---

<Base
  title="Japan map — Japan Finds"
  description="Interactive map of every place on Japan Finds — nature, food markets, museums, onsen, theme parks, anime pilgrimage sites and more."
>
  <Header />
  <main id="main" class="map-main">
    <div class="map-toolbar">
      <div
        class="map-cat-filters"
        role="group"
        aria-label="Switch map mode"
      >
        {/* Phase A.9 C5 — three mode chips matching the three legend
            sections and the site nav (Where/Eat/Stay). See+Do collapsed
            into Where since both filtered /places. Default state: no
            chip pressed = trip-planner view (all sources visible). */}
        <button type="button" class="map-cat map-cat--where" data-cat-btn="where" aria-pressed="false">Where</button>
        <button type="button" class="map-cat map-cat--eat" data-cat-btn="eat" aria-pressed="false">Eat</button>
        <button type="button" class="map-cat map-cat--stay" data-cat-btn="stay" aria-pressed="false">Stay</button>
      </div>
      <button type="button" class="map-reset" data-reset hidden>Reset</button>
    </div>

    <div id="japan-map" aria-label="Interactive map of Japan Finds places"></div>

    <p class="map-hint" hidden data-hint>Tap the map to enable zoom</p>

    <div class="map-loading" data-loading>
      <span class="map-loading-spinner" aria-hidden="true"></span>
      <span class="map-loading-text">Loading map…</span>
    </div>

    <div class="map-legend" data-legend>
      <button
        type="button"
        class="map-legend-toggle"
        data-legend-toggle
        aria-expanded="true"
        aria-controls="map-legend-list"
      >
        <span class="map-legend-toggle-text">Legend</span>
        <span class="map-legend-chev" aria-hidden="true">▾</span>
      </button>
      {/* Phase A.9 C5 — three grouped sections.
          Group headers (Where / Eat / Stay) are non-interactive labels.
          The whole legend toggles between two layouts via data-mode on
          the list container:
            data-mode=""              all three sections visible (default)
            data-mode="where|eat|stay"  only the matching section visible
          Rows inside a visible section are click-to-focus:
            cluster=null   all rows active (no dim)
            cluster=<slug> only that row active; peers dim+strikethrough
          Clicking a row in any section also enters that section's mode
          (so a single tap on "Ramen" jumps straight to Eat-mode focused
          on Ramen, even if you started in the default trip-planner view). */}
      <div id="map-legend-list" class="map-legend-list" data-legend-list>
        <div
          class="map-legend-section"
          data-legend-section="places"
          data-empty={isSourceEmpty("places") ? "true" : "false"}
        >
          <span class="map-legend-section-title">Where</span>
          {isSourceEmpty("places") && (
            <p class="map-legend-empty">
              {EMPTY_STATE_MESSAGE.places(PLACES_ROW_COUNT)}
            </p>
          )}
          <ul class="map-legend-rows">
            {
              PLACES_LEGEND.map((c) => (
                <li
                  class="map-legend-row"
                  data-legend-row="places"
                  data-value={c.value}
                  data-active="true"
                  role="button"
                  tabindex={isSourceEmpty("places") ? -1 : 0}
                  aria-pressed="false"
                  aria-disabled={isSourceEmpty("places") ? "true" : "false"}
                >
                  <span
                    class="map-legend-swatch"
                    style={`background:${c.color}`}
                    aria-hidden="true"
                  />
                  <span class="map-legend-label">{c.label}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div
          class="map-legend-section"
          data-legend-section="eat"
          data-empty={isSourceEmpty("eat") ? "true" : "false"}
        >
          <span class="map-legend-section-title">Eat</span>
          {isSourceEmpty("eat") && (
            <p class="map-legend-empty">
              {EMPTY_STATE_MESSAGE.eat(EAT_LEGEND.length)}
            </p>
          )}
          <ul class="map-legend-rows">
            {
              EAT_LEGEND.map((c) => (
                <li
                  class="map-legend-row"
                  data-legend-row="eat"
                  data-value={c.value}
                  data-active="true"
                  role="button"
                  tabindex={isSourceEmpty("eat") ? -1 : 0}
                  aria-pressed="false"
                  aria-disabled={isSourceEmpty("eat") ? "true" : "false"}
                >
                  <span
                    class="map-legend-swatch map-legend-swatch--ring"
                    aria-hidden="true"
                  />
                  <span class="map-legend-label">{c.label}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div
          class="map-legend-section"
          data-legend-section="stay"
          data-empty={isSourceEmpty("stay") ? "true" : "false"}
        >
          <span class="map-legend-section-title">Stay</span>
          {isSourceEmpty("stay") && (
            <p class="map-legend-empty">
              {EMPTY_STATE_MESSAGE.stay(STAY_LEGEND.length)}
            </p>
          )}
          <ul class="map-legend-rows">
            {
              STAY_LEGEND.map((s) => (
                <li
                  class="map-legend-row"
                  data-legend-row="stay"
                  data-value={s.value}
                  data-active="true"
                  role="button"
                  tabindex={isSourceEmpty("stay") ? -1 : 0}
                  aria-pressed="false"
                  aria-disabled={isSourceEmpty("stay") ? "true" : "false"}
                >
                  <span
                    class="map-legend-swatch"
                    style={`background:${STAY_INDIGO}`}
                    aria-hidden="true"
                  />
                  <span class="map-legend-label">{s.label}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <div class="map-error" hidden data-error role="alert">
      <div class="map-error-card">
        <p class="map-error-text">Map unavailable — please refresh.</p>
        <button type="button" class="map-error-reload" data-reload>Reload page</button>
      </div>
    </div>
  </main>
  <SiteFooter />
</Base>

<style is:global>
  /* Popup overrides — Mapbox creates these dynamically, so global rules. */
  .mapboxgl-popup-content {
    padding: 0;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }
  .mapboxgl-popup-tip { display: none; }
  .mapboxgl-popup-close-button {
    color: var(--color-ink-black);
    font-size: 18px;
    padding: 2px 8px;
    line-height: 1;
  }
  .map-popup {
    display: flex;
    gap: 10px;
    padding: 10px;
    min-width: 220px;
    max-width: 280px;
  }
  .map-popup-img {
    width: 60px;
    height: 60px;
    object-fit: cover;
    flex-shrink: 0;
    border-radius: var(--radius-sm);
    background: var(--color-concrete-gray);
  }
  .map-popup-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 3px;
    min-width: 0;
    flex: 1;
  }
  .map-popup-name {
    margin: 0;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 14px;
    line-height: 1.2;
    color: var(--color-ink-black);
  }
  .map-popup-area {
    margin: 0;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 11px;
    color: var(--color-ink-60);
    letter-spacing: 0.02em;
  }
  .map-popup-jp {
    margin-left: 4px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    color: var(--color-ink-60);
  }
  .map-popup-link {
    margin-top: 2px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ink-black);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Geolocate control — brand-style the default Mapbox button. */
  .mapboxgl-ctrl-group {
    background: var(--color-rice-white) !important;
    border: 1.5px solid var(--color-ink-black) !important;
    border-radius: var(--radius-sm) !important;
    box-shadow: var(--shadow-sm) !important;
  }
  .mapboxgl-ctrl-group button {
    width: 36px !important;
    height: 36px !important;
  }
  .mapboxgl-ctrl-group button:not(:disabled):hover {
    background: var(--color-rice-tint) !important;
  }
  .mapboxgl-ctrl-attrib {
    background: rgba(247, 243, 234, 0.85) !important;
  }
  /* Mapbox vendor logo defaults to 21px tall, which trips Lighthouse
     a11y "tap targets are sized appropriately" (WCAG 2.2 target-size,
     ≥24×24 CSS px). Bumping the height clears the audit without
     altering the wordmark's aspect ratio — the background-image still
     centers, and the wider element is incidentally easier to hit. */
  .mapboxgl-ctrl-logo {
    height: 24px !important;
    background-size: contain !important;
  }
</style>

<style>
  .map-main {
    position: relative;
    padding: 0;
  }
  #japan-map {
    width: 100%;
    height: 95vh;
    background: var(--color-concrete-gray);
  }

  /* Toolbar floats absolutely so the map keeps its full 95vh. */
  .map-toolbar {
    position: absolute;
    top: 12px;
    left: 12px;
    right: 12px;
    z-index: 12;
    display: flex;
    align-items: center;
    gap: 10px;
    pointer-events: none; /* let the map receive drags through gaps */
  }
  .map-cat-filters {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    pointer-events: auto;
  }
  .map-reset {
    pointer-events: auto;
    padding: 6px 10px;
    background: transparent;
    border: none;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
  }
  .map-reset:hover { color: var(--color-tokyo-red); }

  /* Category filter buttons. Active state shows a 2px inset accent ring
     in the category colour. Inactive state dims via opacity. */
  .map-cat {
    padding: 6px 12px;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    cursor: pointer;
    transition:
      box-shadow 120ms ease-out,
      opacity 120ms ease-out;
    box-shadow: var(--shadow-sm);
  }
  /* Phase A.9 C5 — mode-switching chips. Default inactive (outline-only
     pill). Pressing a chip activates that mode and pops the inset ring
     in the source's brand colour. Click the pressed chip again to clear
     back to the default trip-planner view. Ring width 3px for legibility
     at button size. STAY ring uses Aizome Indigo to match the C2 pin
     colour. */
  .map-cat[aria-pressed="true"].map-cat--where { box-shadow: inset 0 0 0 3px #176bff, var(--shadow-sm); }
  .map-cat[aria-pressed="true"].map-cat--eat   { box-shadow: inset 0 0 0 3px #ffd84d, var(--shadow-sm); }
  .map-cat[aria-pressed="true"].map-cat--stay  { box-shadow: inset 0 0 0 3px #3B4F81, var(--shadow-sm); }

  /* Mobile tap-to-activate hint (revealed by JS on coarse-pointer). */
  .map-hint {
    position: absolute;
    top: 60px;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    padding: 6px 14px;
    background: var(--color-ink-black);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: var(--radius-pill);
    z-index: 11;
    pointer-events: none;
    box-shadow: var(--shadow-sm);
  }

  /* Loading state: visible before Mapbox 'load' event fires. The
     `[hidden]` override is required because the explicit `display:
     inline-flex` rule below outranks the UA `[hidden] { display: none }`
     in CSS specificity — same gotcha as .plc[hidden] / .pchip[hidden]
     elsewhere in the codebase. Without this, setting loading.hidden=true
     in JS sets the attribute but the overlay stays visible. */
  .map-loading {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    z-index: 13;
  }
  .map-loading[hidden] { display: none; }
  .map-loading-spinner {
    width: 14px;
    height: 14px;
    border: 2px solid var(--color-concrete-gray);
    border-top-color: var(--color-ink-black);
    border-radius: 50%;
    animation: map-spin 0.7s linear infinite;
  }
  @keyframes map-spin {
    to { transform: rotate(360deg); }
  }

  /* Legend panel — bottom-left, brand-styled. Desktop default open;
     mobile default collapsed (JS sets aria-expanded=false + list[hidden]
     on coarse-pointer devices). */
  .map-legend {
    position: absolute;
    bottom: 24px;
    left: 12px;
    z-index: 11;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-concrete-gray);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-sm);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ink-black);
    max-width: 220px;
  }
  .map-legend-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: transparent;
    border: none;
    font: inherit;
    color: inherit;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    width: 100%;
    text-align: left;
  }
  .map-legend-toggle-text { flex: 1; }
  .map-legend-chev {
    transition: transform 120ms ease-out;
  }
  .map-legend-toggle[aria-expanded="false"] .map-legend-chev {
    transform: rotate(-90deg);
  }
  .map-legend-list {
    margin: 0;
    padding: 0 12px 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-height: 70vh;
    overflow-y: auto;
  }
  .map-legend-list[hidden] { display: none; }
  .map-legend-rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .map-legend-rows li {
    display: flex;
    align-items: center;
    gap: 8px;
    line-height: 1.3;
    text-transform: none;
    letter-spacing: 0;
  }
  .map-legend-swatch {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1.5px solid var(--color-ink-black);
    flex-shrink: 0;
  }
  /* /eat swatch mirrors the /eat pin styling — white fill, thick red ring.
     All 13 cuisine rows use the same swatch on /map; cuisine identity is
     in the label text + URL slug, not the swatch colour. */
  .map-legend-swatch--ring {
    background: #ffffff;
    border-color: #ff3b30;
    border-width: 2.5px;
  }

  /* Phase A.9 C5 — mode-driven legend section visibility.
     data-mode on the legend list dictates which section(s) render:
       (no attr / data-mode="")        all three sections visible
       data-mode="where"               only Where section
       data-mode="eat"                 only Eat section
       data-mode="stay"                only Stay section
     Sections are hidden via display:none — full hide, not dim — so the
     active mode reads as a single focused panel. Section divider
     borders (`.map-legend-section + .map-legend-section`) naturally
     collapse when peers are display:none. */
  .map-legend-list[data-mode="where"] .map-legend-section:not([data-legend-section="places"]),
  .map-legend-list[data-mode="eat"] .map-legend-section:not([data-legend-section="eat"]),
  .map-legend-list[data-mode="stay"] .map-legend-section:not([data-legend-section="stay"]) {
    display: none;
  }

  /* Phase A.9 C4 — three named legend groups (Where / Eat / Stay).
     Headers are non-interactive labels — source-level filtering lives
     in the toolbar chips (Where/Eat/Stay). Rows are click-to-focus,
     single-select within their section. */
  .map-legend-section + .map-legend-section {
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px dashed var(--color-ink-30);
  }
  .map-legend-section-title {
    display: block;
    width: 100%;
    margin: 0 0 4px;
    padding: 2px 0;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }

  /* Toggle rows. Default state: every row data-active="true" (no dim).
     Focused state: the chosen row stays data-active="true" while peers
     flip to data-active="false" (dim swatch + strikethrough label).
     :has() lets us pick out the focused row in CSS without an extra
     data-attr — "any row in this section is dimmed" implies the
     surviving active row is the focused one. */
  .map-legend-row {
    cursor: pointer;
    user-select: none;
    border-radius: var(--radius-sm);
    padding: 1px 4px;
    margin: 0 -4px;
    transition: background 100ms ease-out;
  }
  .map-legend-row:hover { background: var(--color-rice-tint); }
  .map-legend-row:focus-visible {
    outline: 2px solid var(--color-ink-black);
    outline-offset: 1px;
  }
  .map-legend-row[data-active="false"] .map-legend-swatch {
    opacity: 0.3;
  }
  .map-legend-row[data-active="false"] .map-legend-label {
    text-decoration: line-through;
    text-decoration-thickness: 1px;
    color: var(--color-ink-30);
  }
  /* Focus row — only highlighted when its section has at least one
     dimmed peer (i.e. a focus is set). Light tint + bold label so it
     reads as "this is the active filter". */
  .map-legend-section:has(.map-legend-row[data-active="false"])
    .map-legend-row[data-active="true"] {
    background: var(--color-rice-tint);
  }
  .map-legend-section:has(.map-legend-row[data-active="false"])
    .map-legend-row[data-active="true"] .map-legend-label {
    font-weight: 600;
  }

  /* Phase A.9 C6 — empty-state for sources with zero placed markers.
     Brand-voice inline message above the rows; all rows in the empty
     section dim and become non-interactive (pointer-events disabled,
     out of tab order, aria-disabled). When enrichment lands and the
     section becomes non-empty, this whole block silently drops away
     — data-empty flips to "false" at build time. */
  .map-legend-empty {
    margin: 0 0 6px;
    padding: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    font-style: italic;
    line-height: 1.4;
    color: var(--color-ink-60);
  }
  .map-legend-section[data-empty="true"] .map-legend-row {
    opacity: 0.4;
    pointer-events: none;
    cursor: default;
  }
  .map-legend-section[data-empty="true"] .map-legend-row .map-legend-label {
    color: var(--color-ink-30);
  }
  .map-legend-section[data-empty="true"] .map-legend-row:hover {
    background: transparent;
  }

  /* Error overlay — auth/network failure. Replaces the silent blank gray. */
  .map-error {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 14;
  }
  .map-error-card {
    padding: 16px 20px;
    background: var(--color-rice-white);
    border: 1.5px solid var(--color-tokyo-red);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-md);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
  }
  .map-error-text {
    margin: 0;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 15px;
    color: var(--color-ink-black);
  }
  .map-error-reload {
    padding: 6px 14px;
    background: var(--color-ink-black);
    color: #fff;
    border: none;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
  }

  /* Inline toast (geolocation denied, etc.) — auto-dismisses in 3s. */
  :global(.map-toast) {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 14px;
    background: var(--color-ink-black);
    color: #fff;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    z-index: 15;
    box-shadow: var(--shadow-sm);
  }

  /* Mobile: compact category buttons, full toolbar width. */
  @media (max-width: 640px) {
    .map-toolbar {
      top: 8px;
      left: 8px;
      right: 8px;
      gap: 6px;
    }
    .map-cat {
      padding: 5px 8px;
      font-size: 10px;
      letter-spacing: 0.02em;
    }
    .map-cat-filters {
      flex: 1;
      justify-content: space-between;
    }
    .map-reset {
      font-size: 10px;
      padding: 5px 6px;
    }
  }
</style>

<script>
  import mapboxgl from "mapbox-gl";
  import "mapbox-gl/dist/mapbox-gl.css";

  // Inlined at build time. On Vercel = real production token; localhost
  // with the .env placeholder will 401-fail (caught by the error overlay).
  mapboxgl.accessToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;

  /* Phase A.9 C5 — mode + cluster two-axis filter state.
       mode: null | "where" | "eat" | "stay"
         null  = default trip-planner view; all sources visible, all
                 three legend sections rendered.
         set   = mode-switched view; only that source's markers visible
                 AND only that section's legend rows rendered.
       cluster: null | <slug>
         null  = no sub-cluster focus within the active mode.
         set   = single legend row focused inside the active section;
                 only matching features visible. Meaningful only when
                 mode is also set (mode=null + cluster=X is ignored).
     URL: ?mode=where&cluster=anime. Default omits both. */
  const ALL_MODES = ["where", "eat", "stay"];
  const MODE_TO_SOURCE = { where: "places", eat: "eat", stay: "stay" };
  let mode = null;
  let cluster = null;
  let allFeatures = null; // fetched once; filter rebuilds source.data
  let map;
  let mapErrored = false;

  /* ---------- Phase A.9 C5 — legend slug catalogue ----------
     One Set per mode, used to validate URL ?cluster= values against
     known slugs. Keys are the data-legend-section attribute (i.e. the
     source name, not the mode name) so the existing legend markup
     doesn't need to change. */
  const LEGEND_SLUG_SETS = {
    places: new Set(["nature_water", "culture_history", "animals",
      "quirky_museums", "anime", "onsen_ryokan", "photo_spots",
      "scenic_transport", "theme_parks", "parks", "workshops_crafts",
      "food_markets", "cafes", "_base"]),
    eat: new Set(["sushi", "tempura", "unagi", "sukiyaki", "yakiniku",
      "yakitori", "tonkatsu", "ramen", "soba", "udon", "izakaya",
      "okonomiyaki", "shokudo"]),
    stay: new Set(["onsen_ryokan", "design_hotel", "machiya_kominka",
      "glamping", "resort", "capsule_themed", "mountain_lodge",
      "heritage_hotel", "temple_stay"]),
  };
  // Eat URL slug → restaurants.json cuisine_chip value. Used at filter
  // time so the feature's `cuisine` property can be tested against the
  // lowercase slug set.
  const EAT_SLUG_TO_CUISINE = {
    sushi: "Sushi",
    tempura: "Tempura",
    unagi: "Unagi",
    sukiyaki: "Sukiyaki & Shabu-shabu",
    yakiniku: "Yakiniku",
    yakitori: "Yakitori",
    tonkatsu: "Tonkatsu",
    ramen: "Ramen",
    soba: "Soba",
    udon: "Udon",
    izakaya: "Izakaya",
    okonomiyaki: "Okonomiyaki",
    shokudo: "Shokudo",
  };
  const EAT_CUISINE_TO_SLUG = Object.fromEntries(
    Object.entries(EAT_SLUG_TO_CUISINE).map(([s, c]) => [c, s]),
  );

  /* ---------- URL state — single ?mode= + optional ?cluster= ----------
     Phase A.9 C5: trade C3/C4's three-param scheme for one mode param.
     Migration from older link formats (C3 csv-per-source, C4 single-
     slug-per-source, A.8 ?categories=) is best-effort: pick the first
     valid source token and rewrite the URL on init so the user lands
     in the new scheme without an extra page reload. */
  function readModeFromURL() {
    const p = new URLSearchParams(window.location.search);

    // 1. New-scheme ?mode= (preferred).
    let m = (p.get("mode") || "").trim().toLowerCase();
    let c = (p.get("cluster") || "").trim().toLowerCase();

    // 2. Legacy C4 single-slug-per-source: ?places=, ?eat=, ?stay=.
    //    First matching one wins. cluster value picked from that param.
    if (!m) {
      for (const [src, modeName] of [["places", "where"], ["eat", "eat"], ["stay", "stay"]]) {
        const raw = (p.get(src) || "").trim().toLowerCase();
        if (raw) {
          m = modeName;
          c = raw.split(",")[0]; // C3 csv → take first token
          break;
        }
      }
    }

    // 3. Legacy A.8/C4 ?categories= toolbar-only param. tabelog → eat.
    if (!m) {
      const raw = (p.get("categories") || "").trim().toLowerCase();
      if (raw) {
        const first = raw.split(",")[0];
        if (first === "tabelog" || first === "eat") m = "eat";
        else if (first === "stay") m = "stay";
        else if (first === "see" || first === "do") m = "where";
      }
    }

    if (!ALL_MODES.includes(m)) {
      mode = null;
      cluster = null;
      return;
    }
    mode = m;
    const src = MODE_TO_SOURCE[m];
    cluster = c && LEGEND_SLUG_SETS[src].has(c) ? c : null;
  }

  function syncURL() {
    const p = new URLSearchParams(window.location.search);
    // Strip legacy params on every sync so migrated links self-clean.
    for (const k of ["places", "eat", "stay", "categories"]) p.delete(k);
    if (mode) p.set("mode", mode);
    else p.delete("mode");
    if (mode && cluster) p.set("cluster", cluster);
    else p.delete("cluster");
    const qs = p.toString();
    const newURL =
      window.location.pathname +
      (qs ? "?" + qs : "") +
      window.location.hash;
    history.replaceState(null, "", newURL);
  }

  /* ---------- UI state sync ----------
     Chip aria-pressed reflects the active mode (one of three, or none).
     Legend container's data-mode drives section-visibility CSS.
     Reset surfaces whenever mode OR cluster is non-default. */
  function updateButtonStates() {
    document.querySelectorAll("[data-cat-btn]").forEach((btn) => {
      btn.setAttribute(
        "aria-pressed",
        String(mode !== null && btn.dataset.catBtn === mode),
      );
    });
    const list = document.querySelector("[data-legend-list]");
    if (list) list.dataset.mode = mode || "";
    const reset = document.querySelector("[data-reset]");
    if (reset) reset.hidden = mode === null && cluster === null;
  }

  /* ---------- Map filtering ----------
     Two-axis filter from the C5 model:
       1. Mode (null | "where" | "eat" | "stay") gates the source.
          null = all sources visible (trip-planner default).
       2. Cluster (null | slug) gates within the active mode's source.
          Meaningful only when mode is also set.
     Features pass iff both axes admit them. */
  function passesFilter(f) {
    const src = f.properties.source;
    if (mode !== null && MODE_TO_SOURCE[mode] !== src) return false;
    if (cluster === null) return true;
    if (mode === "where" && src === "places") {
      return (f.properties.public_label || "_base") === cluster;
    }
    if (mode === "eat" && src === "eat") {
      return EAT_CUISINE_TO_SLUG[f.properties.cuisine] === cluster;
    }
    if (mode === "stay" && src === "stay") {
      return f.properties.primary_cat === cluster;
    }
    return true;
  }
  function applyCategoryFilter() {
    if (!allFeatures || !map || !map.getSource("places")) return;
    const filtered = allFeatures.filter(passesFilter);
    // Re-setting the data triggers Mapbox to re-cluster from scratch, so
    // cluster counts update to reflect the new filter set.
    map.getSource("places").setData({
      type: "FeatureCollection",
      features: filtered,
    });
  }

  /* ---------- Chip + reset wiring ----------
     Click a chip → enter that mode (also clears any prior cluster
     focus, since entering a new mode invalidates an old mode's
     cluster slug). Click the active chip again → exit to default.
     Reset clears both axes in one tap. */
  function setupCategoryButtons() {
    document.querySelectorAll("[data-cat-btn]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.dataset.catBtn;
        if (mode === target) {
          mode = null;
          cluster = null;
        } else {
          mode = target;
          cluster = null;
        }
        updateButtonStates();
        paintLegendFromState();
        syncURL();
        applyCategoryFilter();
      });
    });
    const reset = document.querySelector("[data-reset]");
    if (reset)
      reset.addEventListener("click", () => {
        mode = null;
        cluster = null;
        updateButtonStates();
        paintLegendFromState();
        syncURL();
        applyCategoryFilter();
      });
    const reload = document.querySelector("[data-reload]");
    if (reload) reload.addEventListener("click", () => window.location.reload());
  }

  /* ---------- Toast helper for transient errors ---------- */
  function showToast(text) {
    let toast = document.querySelector(".map-toast");
    if (!toast) {
      toast = document.createElement("div");
      toast.className = "map-toast";
      document.querySelector(".map-main").appendChild(toast);
    }
    toast.textContent = text;
    toast.hidden = false;
    clearTimeout(toast._dismissTimer);
    toast._dismissTimer = setTimeout(() => {
      toast.hidden = true;
    }, 3000);
  }

  function showErrorOverlay() {
    const err = document.querySelector("[data-error]");
    if (err) err.hidden = false;
    const loading = document.querySelector("[data-loading]");
    if (loading) loading.hidden = true;
  }

  /* ---------- Legend toggle ----------
     Desktop default open; collapse on coarse-pointer (mobile/tablet) so
     it doesn't eat half the map. Click the header bar to expand/collapse. */
  function setupLegend() {
    const toggle = document.querySelector("[data-legend-toggle]");
    const list = document.querySelector("[data-legend-list]");
    if (!toggle || !list) return;
    if (window.matchMedia("(pointer: coarse)").matches) {
      toggle.setAttribute("aria-expanded", "false");
      list.hidden = true;
    }
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      list.hidden = expanded;
    });
  }

  /* ---------- Legend row focus (Phase A.9 C5) ----------
     Click-to-focus, single-select within the active mode's section.
     Clicking a row in a section whose source doesn't match the active
     mode auto-enters that mode (so clicking "Ramen" inside Eat while
     in Where-mode flips to Eat-mode and focuses Ramen). This keeps
     the row-click as a single-tap action even when the user hasn't
     pre-selected a mode chip — friendlier than ignoring the click.
     Row visual contract: data-active="true" = visible/normal style;
     data-active="false" = dimmed (used when a peer in the same section
     IS focused). aria-pressed mirrors "this row is the current focus". */
  function paintLegendFromState() {
    document.querySelectorAll("[data-legend-row]").forEach((row) => {
      const src = row.dataset.legendRow;
      const slug = row.dataset.value;
      // Cluster is only meaningful when its source matches the mode.
      const sectionHasFocus =
        cluster !== null && mode !== null && MODE_TO_SOURCE[mode] === src;
      const on = sectionHasFocus ? cluster === slug : true;
      row.dataset.active = String(on);
      row.setAttribute("aria-pressed", String(sectionHasFocus && cluster === slug));
    });
  }

  function setupLegendRows() {
    function activate(row) {
      // C6: rows in empty sections are decorative only — pointer-events
      // already blocks clicks, but keyboard activation also gates here.
      if (row.getAttribute("aria-disabled") === "true") return;
      const src = row.dataset.legendRow;
      const slug = row.dataset.value;
      const targetMode = Object.entries(MODE_TO_SOURCE)
        .find(([, s]) => s === src)[0];
      if (mode === targetMode && cluster === slug) {
        // Clicking the focused row in the active mode clears the cluster
        // but stays in the mode — consistent with chip behaviour where
        // re-clicking exits one layer at a time.
        cluster = null;
      } else {
        mode = targetMode;
        cluster = slug;
      }
      updateButtonStates();
      paintLegendFromState();
      syncURL();
      applyCategoryFilter();
    }
    document.querySelectorAll("[data-legend-row]").forEach((row) => {
      row.addEventListener("click", () => activate(row));
      row.addEventListener("keydown", (e) => {
        if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          activate(row);
        }
      });
    });
  }

  /* ---------- Init ---------- */
  readModeFromURL();
  setupCategoryButtons();
  setupLegend();
  setupLegendRows();
  updateButtonStates();
  paintLegendFromState();
  // Self-clean any legacy ?places=/?eat=/?stay=/?categories= params
  // that readModeFromURL migrated into mode/cluster.
  syncURL();

  map = new mapboxgl.Map({
    container: "japan-map",
    style: "mapbox://styles/mapbox/light-v11",
    center: [138, 36],
    zoom: 4.5,
    minZoom: 4,
    maxZoom: 18,
    // Mapbox-native URL hash sync. Format: #zoom/lat/lng[/bearing/pitch].
    // Note: user spec said #lng/lat/zoom — Mapbox's native order is
    // zoom/lat/lng. If a custom order is wanted later, replace with custom
    // moveend+zoomend handlers writing window.location.hash.
    hash: true,
  });

  // Mapbox auth/network errors → show the error overlay instead of
  // silent blank-gray. Dedupe so repeated tile failures don't bounce.
  map.on("error", (e) => {
    if (mapErrored) return;
    const err = e && e.error ? e.error : {};
    const status = err.status;
    const msg = err.message || "";
    if (status === 401 || status === 403 || /unauthorized|forbidden|access token/i.test(msg)) {
      mapErrored = true;
      showErrorOverlay();
    }
  });

  // Geolocate control — brand-styled via global CSS overrides above.
  const geolocate = new mapboxgl.GeolocateControl({
    positionOptions: { enableHighAccuracy: true, timeout: 6000 },
    trackUserLocation: false,
    showAccuracyCircle: false,
    showUserLocation: true,
    fitBoundsOptions: { maxZoom: 12 },
  });
  map.addControl(geolocate, "bottom-right");
  geolocate.on("error", () => showToast("Location unavailable"));

  /* Loading-overlay dismiss strategy — three layers of safety so the
     overlay never gets stuck visible:
       1. Primary: 'load' event (fires when the style + initial tiles
          are loaded). This is the canonical trigger.
       2. Backup: 'idle' event (fires whenever the map reaches a stable
          rendered state). 'idle' fires repeatedly, so even if a late
          listener attaches after 'load', the first idle dismisses.
       3. Hard fallback: 5-second timeout. If both events miss for any
          reason, the overlay self-dismisses. The error overlay (see
          map.on('error')) still surfaces auth/tile failures separately. */
  function dismissLoadingOverlay() {
    const loading = document.querySelector("[data-loading]");
    if (loading) loading.hidden = true;
  }
  setTimeout(dismissLoadingOverlay, 5000);
  map.once("idle", dismissLoadingOverlay);

  map.on("load", () => {
    dismissLoadingOverlay();

    fetch("/places.geojson")
      .then((r) => {
        if (!r.ok) throw new Error("geojson fetch failed: " + r.status);
        return r.json();
      })
      .then((data) => {
        allFeatures = data.features;
        initLayers();
      })
      .catch((err) => {
        console.error("places.geojson load failed", err);
        showErrorOverlay();
      });
  });

  /* ---------- Add source + layers (after geojson loads) ---------- */
  function initLayers() {
    const filtered = allFeatures.filter(passesFilter);
    map.addSource("places", {
      type: "geojson",
      data: { type: "FeatureCollection", features: filtered },
      cluster: true,
      clusterMaxZoom: 14,
      clusterRadius: 50,
    });

    // Plain numbered cluster bubbles: Rice White fill, Concrete Gray
    // border, max radius 50. (Donut clusters considered + rejected as
    // over-engineered for an editorial site — category buttons solve
    // cluster-ambiguity better than visual donuts.)
    map.addLayer({
      id: "clusters",
      type: "circle",
      source: "places",
      filter: ["has", "point_count"],
      paint: {
        "circle-color": "#F7F3EA",
        "circle-stroke-color": "#E6E1D8",
        "circle-stroke-width": 1.5,
        "circle-radius": [
          "step",
          ["get", "point_count"],
          20,
          25, 30,
          100, 40,
          250, 50,
        ],
      },
    });
    map.addLayer({
      id: "cluster-count",
      type: "symbol",
      source: "places",
      filter: ["has", "point_count"],
      layout: {
        "text-field": ["get", "point_count_abbreviated"],
        "text-font": ["Open Sans Bold", "Arial Unicode MS Bold"],
        "text-size": 11,
      },
      paint: { "text-color": "#151515" },
    });

    // /places pins: coloured by public_label (sub-category). 13 distinct
    // colours give at-a-glance regional scan-ability ("this area is mostly
    // culture", "lots of workshops here") that the old My Maps had and the
    // primary_category-only colouring lost. Empty public_label (base-tier
    // rows: ~22 places like base towns / stay bases) falls through to
    // Concrete Gray. Keep this expression in sync with SUBCAT_LEGEND in
    // the frontmatter — both render the same color → category mapping.
    map.addLayer({
      id: "unclustered-places",
      type: "circle",
      source: "places",
      filter: [
        "all",
        ["!", ["has", "point_count"]],
        ["==", ["get", "source"], "places"],
      ],
      paint: {
        "circle-color": [
          "match",
          ["get", "public_label"],
          "nature_water", "#176BFF",
          "culture_history", "#FF3B30",
          "animals", "#4D8B57",
          "quirky_museums", "#7B3FA0",
          "anime", "#E91E63",
          "onsen_ryokan", "#9B7EBD",
          "photo_spots", "#FF6B6B",
          "scenic_transport", "#FF9800",
          "theme_parks", "#FFD84D",
          "parks", "#A4C49C",
          "workshops_crafts", "#8B5A2B",
          "food_markets", "#D4A017",
          "cafes", "#D2B48C",
          /* base-tier / no public_label */ "#999999",
        ],
        "circle-radius": 6,
        "circle-stroke-width": 1.5,
        "circle-stroke-color": "#151515",
      },
    });

    // /eat (Tabelog) pins: open-ring style — white fill + thick Tokyo Red
    // stroke. Reads as a "ring" at small map scale, clearly distinct from
    // the solid /places pins. The Tokyo Red echoes the Tabelog filter
    // button's accent so the legend↔pin connection is immediate.
    map.addLayer({
      id: "unclustered-eat",
      type: "circle",
      source: "places",
      filter: [
        "all",
        ["!", ["has", "point_count"]],
        ["==", ["get", "source"], "eat"],
      ],
      paint: {
        "circle-color": "#FFFFFF",
        "circle-radius": 6,
        "circle-stroke-width": 2.5,
        "circle-stroke-color": "#FF3B30",
      },
    });

    // Phase A.9 stay pins: solid Aizome Indigo fill, ink stroke. Distinct
    // from /places (different hue, not in the 13-cluster palette) and from
    // /eat (solid fill, not the open ring). The 9 sub-cats share one fill —
    // legend rows are the filter axis (wired in C3), colour stays per-source.
    // The seed currently has no lat/lng, so this layer renders zero markers
    // until the D7-style enrichment pass populates coordinates.
    map.addLayer({
      id: "unclustered-stays",
      type: "circle",
      source: "places",
      filter: [
        "all",
        ["!", ["has", "point_count"]],
        ["==", ["get", "source"], "stay"],
      ],
      paint: {
        "circle-color": "#3B4F81",
        "circle-radius": 6,
        "circle-stroke-width": 1.5,
        "circle-stroke-color": "#151515",
      },
    });

    // Cluster click: expand the cluster (zoom in until it bursts).
    map.on("click", "clusters", (e) => {
      const f = map.queryRenderedFeatures(e.point, { layers: ["clusters"] })[0];
      const id = f.properties.cluster_id;
      map.getSource("places").getClusterExpansionZoom(id, (err, zoom) => {
        if (err) return;
        map.easeTo({ center: f.geometry.coordinates, zoom });
      });
    });

    // Popup builder — branches on source. Built lazily on click, no
    // pre-rendering of popup templates or eager hero-image fetches.
    function buildPopupHTML(p) {
      const img = p.hero_image
        ? `<img src="${p.hero_image}" alt="" loading="lazy" class="map-popup-img" />`
        : `<div class="map-popup-img" aria-hidden="true"></div>`;
      if (p.source === "eat") {
        const meta = [];
        if (p.cuisine) meta.push(p.cuisine);
        if (p.price_tier) meta.push(p.price_tier);
        const metaLine = meta.join(" · ");
        const provenance = p.list_year
          ? `${p.list_year} Tabelog Hyakumeiten${
              p.is_shokudo ? " (Shokudo)" : ""
            }${p.rank_in_city ? ` · #${p.rank_in_city} in ${p.city || ""}` : ""}`
          : "";
        const nameHTML = p.name_jp
          ? `${p.name} <span class="map-popup-jp">${p.name_jp}</span>`
          : p.name;
        // Anchor-link CTA: /eat#<slug> lands on the matching card, which
        // self-highlights for 2s via the :target rule in RestaurantCard.
        const href = p.slug ? `/eat#${p.slug}` : "/eat";
        return `
          <div class="map-popup">
            ${img}
            <div class="map-popup-text">
              <h3 class="map-popup-name">${nameHTML}</h3>
              ${metaLine ? `<p class="map-popup-area">${metaLine}</p>` : ""}
              ${provenance ? `<p class="map-popup-area">${provenance}</p>` : ""}
              <a class="map-popup-link" href="${href}">More about this restaurant →</a>
            </div>
          </div>
        `;
      }
      if (p.source === "stay") {
        // No /stay route this phase, so the CTA is the official source
        // URL (hotel site). Slug → display label is duplicated here from
        // STAY_LEGEND in the frontmatter; if you change either keep both
        // in sync (one map, both sides of the JS↔Astro boundary).
        const STAY_CAT_LABEL = {
          onsen_ryokan: "Onsen ryokan",
          design_hotel: "Design hotel",
          machiya_kominka: "Machiya & kominka",
          glamping: "Glamping",
          resort: "Resort",
          capsule_themed: "Capsule & novelty",
          mountain_lodge: "Mountain lodge",
          heritage_hotel: "Heritage hotel",
          temple_stay: "Temple stay",
        };
        const where = [p.city, p.prefecture].filter(Boolean).join(", ");
        const meta = [STAY_CAT_LABEL[p.primary_cat] || p.primary_cat, p.price_tier]
          .filter(Boolean)
          .join(" · ");
        const nameHTML = p.name_jp
          ? `${p.name} <span class="map-popup-jp">${p.name_jp}</span>`
          : p.name;
        const externalLink = p.source_url
          ? `<a class="map-popup-link" href="${p.source_url}" target="_blank" rel="noopener">Visit hotel site →</a>`
          : "";
        return `
          <div class="map-popup">
            ${img}
            <div class="map-popup-text">
              <h3 class="map-popup-name">${nameHTML}</h3>
              ${where ? `<p class="map-popup-area">${where}</p>` : ""}
              ${meta ? `<p class="map-popup-area">${meta}</p>` : ""}
              ${externalLink}
            </div>
          </div>
        `;
      }
      // /places branch
      const area = p.address_or_area || "";
      // Anchor-link CTA: /places#<slug> lands on the matching card,
      // which self-highlights for 2s via the :target rule in PlaceCard.
      const href = p.slug ? `/places#${p.slug}` : "/places";
      return `
        <div class="map-popup">
          ${img}
          <div class="map-popup-text">
            <h3 class="map-popup-name">${p.name || ""}</h3>
            ${area ? `<p class="map-popup-area">${area}</p>` : ""}
            <a class="map-popup-link" href="${href}">More about this place →</a>
          </div>
        </div>
      `;
    }

    for (const layer of ["unclustered-places", "unclustered-eat", "unclustered-stays"]) {
      map.on("click", layer, (e) => {
        const f = e.features[0];
        const coords = f.geometry.coordinates.slice();
        new mapboxgl.Popup({ offset: 8 })
          .setLngLat(coords)
          .setHTML(buildPopupHTML(f.properties))
          .addTo(map);
      });
    }

    for (const layer of [
      "clusters",
      "unclustered-places",
      "unclustered-eat",
      "unclustered-stays",
    ]) {
      map.on("mouseenter", layer, () => {
        map.getCanvas().style.cursor = "pointer";
      });
      map.on("mouseleave", layer, () => {
        map.getCanvas().style.cursor = "";
      });
    }
  }

  /* ---------- Mobile scroll-zoom gating ---------- */
  if (window.matchMedia("(pointer: coarse)").matches) {
    map.scrollZoom.disable();
    map.touchZoomRotate.disable();
    const hint = document.querySelector("[data-hint]");
    if (hint) hint.hidden = false;
    const activate = () => {
      map.scrollZoom.enable();
      map.touchZoomRotate.enable();
      if (hint) hint.hidden = true;
    };
    map.once("click", activate);
  }
</script>
