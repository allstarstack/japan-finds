---
/* /eat — Phase C Tabelog Hyakumeiten restaurants ("Eat" in the nav).
   Hero + Restaurants Map CTA, sticky two-tier chip rail, and the full
   282-restaurant grid. Mirrors /places architecture.

   Sort is fixed (BUILD_SPEC "Out of scope" — no sort controls): cuisine
   chip order, then rank_in_city ascending within each cuisine. Data is
   read at build time from restaurants.json — no client-side fetch. */
import restaurants from "../data/restaurants.json";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ChipRow from "../components/eat/ChipRow.astro";
import LocationChipRow from "../components/v2/LocationChipRow.astro";
import MapView from "../components/v2/MapView.astro";
import RestaurantCard from "../components/eat/RestaurantCard.astro";
import MethodologyFooter from "../components/eat/MethodologyFooter.astro";
import {
  CITY_CHIPS,
  CUISINE_CHIPS,
  FLAG_CHIPS,
  cuisineSlug,
  restaurantCity,
  restaurantFlags,
} from "../data/eat-chips.js";

/* Fixed sort: cuisine chip order, then rank_in_city ascending. */
const cuisineOrder = new Map(CUISINE_CHIPS.map((c, i) => [c.value, i]));
const sorted = [...restaurants].sort((a, b) => {
  const o =
    (cuisineOrder.get(a.cuisine_chip) ?? 999) -
    (cuisineOrder.get(b.cuisine_chip) ?? 999);
  return o !== 0 ? o : a.rank_in_city - b.rank_in_city;
});
const total = sorted.length;

/* Per-chip counts (keyed by slug) for the rail. */
const cuisineCounts: Record<string, number> = {};
for (const c of CUISINE_CHIPS) cuisineCounts[c.slug] = 0;
for (const r of sorted) {
  const s = cuisineSlug(r.cuisine_chip);
  if (s) cuisineCounts[s]++;
}
const flagCounts: Record<string, number> = {};
for (const f of FLAG_CHIPS) flagCounts[f.slug] = 0;
for (const r of sorted)
  for (const f of restaurantFlags(r)) flagCounts[f]++;

/* Phase D D6 — per-city counts for the LocationChipRow. Same convention as
   cuisineCounts: count every visible row. Chips with a zero count drop out
   (defensive — all 5 buckets currently have rows). */
const cityCounts: Record<string, number> = {};
for (const c of CITY_CHIPS) cityCounts[c.slug] = 0;
for (const r of sorted) cityCounts[restaurantCity(r)]++;

const cityChips = CITY_CHIPS
  .map((c) => ({
    slug: c.slug,
    label: c.label,
    count: cityCounts[c.slug],
    isRollup: c.isRollup,
  }))
  .filter((c) => c.count > 0);
---

<Base
  title="Where to eat in Japan — Japan Finds"
  description="282 restaurants from Tabelog's Hyakumeiten lists — sushi, ramen, yakitori and the shokudo picks. Filter by cuisine, price tier and reservation status, then take the map with you."
>
  <Header />
  <main id="main">
    <section class="ehero">
      <div class="wrap">
        <h1>Where to eat in Japan, ranked by people who live there.</h1>
        <p class="ehero-sub">
          Tabelog Hyakumeiten — 282 restaurants across 13 categories. The
          specialty kind (sushi, tempura, sukiyaki) and the everyday kind
          (ramen, soba, the shokudo lists). Steven isn't a foodie. These are
          the picks because the locals voted, not because he ate there.
        </p>
      </div>
    </section>

    <div class="rail-sticky">
      <div class="view-toggle-row">
        <div
          class="view-toggle"
          role="group"
          aria-label="Toggle list or map view"
          data-view-toggle
        >
          <button type="button" data-view-btn="list" aria-pressed="true">List</button>
          <button type="button" data-view-btn="map" aria-pressed="false">Map</button>
        </div>
      </div>
      <LocationChipRow chips={cityChips} hintLabel="cities" />
      <ChipRow cuisineCounts={cuisineCounts} flagCounts={flagCounts} />
    </div>

    <section class="eresults" data-list-section>
      <div class="wrap">
        <div class="eresults-bar">
          <h2 class="eresults-count" data-count>Showing {total} of {total}</h2>
          <button type="button" class="eclear" data-clear hidden>
            Clear filters
          </button>
        </div>
        <p class="xlink">Looking for places to go? <a href="/places">See → /places</a></p>
        <div class="grid" data-grid>
          {sorted.map((r) => <RestaurantCard restaurant={r} />)}
        </div>
        <p class="eresults-empty" data-empty hidden>
          Nothing here yet. Back when there is.
        </p>
      </div>
    </section>

    <section class="eresults-map" data-map-section hidden>
      <MapView
        containerId="eat-map"
        sourceFilter="eat"
        filterEventName="eat:filter-changed"
        height="78vh"
        showLegend={true}
        legendKind="eat"
      />
    </section>

    <MethodologyFooter />
  </main>
  <SiteFooter />
</Base>

<style>
  .wrap {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 var(--gutter-mobile);
  }

  /* Phase D D6 — sticky wrapper that holds the location row and the
     cuisine/flag rail as a single unit. The inner rails are no longer
     sticky themselves; this wrapper owns the sticky and the ink border
     under the whole chip block. */
  .rail-sticky {
    position: sticky;
    top: 0;
    z-index: 20;
    background: var(--color-white);
    border-bottom: var(--border-ink);
  }

  /* Hero — text on the body background, no image (BUILD_SPEC §1). */
  .ehero {
    padding: 30px 0 24px;
  }
  .ehero h1 {
    margin: 0;
    max-width: 22ch;
    font-family: var(--font-head);
    font-size: 36px;
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.03em;
  }
  .ehero-sub {
    margin: 14px 0 0;
    max-width: 52ch;
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-ink-60);
  }

  /* Restaurants Map CTA — single button (BUILD_SPEC §2). */
  .emap {
    padding: 0 0 26px;
  }

  /* Results sit on white so the rice-white cards read. */
  .eresults {
    background: var(--color-white);
    padding: 18px 0 8px;
  }
  .eresults-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 6px 14px;
    margin-bottom: 14px;
  }
  /* Wayfinding aside — sits between the results bar and the grid as a
     low-key cross-link to /places. Sub-CTA weight, mono to read as
     inline copy rather than a button. */
  .xlink {
    margin: -4px 0 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-ink-60);
  }
  .xlink a {
    color: var(--color-ink-black);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  /* h2 for document outline (h1 hero -> h2 count -> h3 card names);
     the class overrides the heading defaults so it reads as a label. */
  .eresults-count {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }
  .eclear {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 0;
    background: none;
    border: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .eclear[hidden] {
    display: none;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  /* Native lazy-render: the browser skips layout/paint for off-screen
     cards, so all 282 stay in the DOM (instant filtering) without the
     cost of painting every card up front. */
  .grid :global(.rc) {
    content-visibility: auto;
    contain-intrinsic-size: auto 380px;
  }
  .eresults-empty {
    padding: 48px 0;
    font-family: var(--font-head);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .wrap {
      padding: 0 var(--gutter-desktop);
    }
    .ehero {
      padding: 52px 0 32px;
    }
    .ehero h1 {
      font-size: 60px;
      letter-spacing: -0.035em;
    }
    .ehero-sub {
      font-size: 18px;
    }
    .emap {
      padding: 0 0 36px;
    }
    .eresults {
      padding: 22px 0 8px;
    }
    .grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
  }

  /* View toggle — mirrors /places. Same segmented control styling. */
  .view-toggle-row {
    display: flex;
    justify-content: flex-end;
    padding: 8px var(--gutter-mobile);
  }
  .view-toggle {
    display: inline-flex;
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-pill);
    overflow: hidden;
    background: var(--color-rice-white);
    box-shadow: var(--shadow-sm);
  }
  .view-toggle button {
    padding: 6px 14px;
    background: transparent;
    border: none;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    cursor: pointer;
  }
  .view-toggle button[aria-pressed="true"] {
    background: var(--color-ink-black);
    color: #fff;
  }
  .eresults[hidden],
  .eresults-map[hidden] { display: none; }

  @media (max-width: 640px) {
    .view-toggle-row { justify-content: stretch; }
    .view-toggle { width: 100%; }
    .view-toggle button { flex: 1; }
  }
  @media (min-width: 1024px) {
    .view-toggle-row { padding: 8px var(--gutter-desktop); }
  }
</style>

<script>
  /* View toggle (Phase B) — same logic as /places.astro. */
  const toggle = document.querySelector("[data-view-toggle]");
  const listSec = document.querySelector("[data-list-section]");
  const mapSec = document.querySelector("[data-map-section]");

  function setView(view, { writeURL = true } = {}) {
    const isMap = view === "map";
    if (listSec) listSec.hidden = isMap;
    if (mapSec) mapSec.hidden = !isMap;
    if (toggle) {
      for (const btn of toggle.querySelectorAll("[data-view-btn]")) {
        btn.setAttribute(
          "aria-pressed",
          String(btn.dataset.viewBtn === view),
        );
      }
    }
    if (writeURL) {
      const p = new URLSearchParams(window.location.search);
      if (isMap) p.set("view", "map");
      else p.delete("view");
      const qs = p.toString();
      history.replaceState(
        null,
        "",
        window.location.pathname + (qs ? "?" + qs : "") + window.location.hash,
      );
    }
    if (isMap) {
      window.dispatchEvent(new CustomEvent("mapview:show"));
    }
  }

  const params = new URLSearchParams(window.location.search);
  setView(params.get("view") === "map" ? "map" : "list", { writeURL: false });

  if (toggle) {
    for (const btn of toggle.querySelectorAll("[data-view-btn]")) {
      btn.addEventListener("click", () => {
        setView(btn.dataset.viewBtn);
      });
    }
  }

  window.addEventListener("popstate", () => {
    const params = new URLSearchParams(window.location.search);
    setView(params.get("view") === "map" ? "map" : "list", { writeURL: false });
  });
</script>
