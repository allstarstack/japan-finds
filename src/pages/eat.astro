---
/* /eat — Phase C Tabelog Hyakumeiten restaurants ("Eat" in the nav).
   Hero + Restaurants Map CTA, sticky two-tier chip rail, and the full
   282-restaurant grid. Mirrors /places architecture.

   Sort is fixed (BUILD_SPEC "Out of scope" — no sort controls): cuisine
   chip order, then rank_in_city ascending within each cuisine. Data is
   read at build time from restaurants.json — no client-side fetch. */
import restaurants from "../data/restaurants.json";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";
import ChipRow from "../components/eat/ChipRow.astro";
import LocationChipRow from "../components/v2/LocationChipRow.astro";
import SearchBox from "../components/v2/SearchBox.astro";
import MapView from "../components/v2/MapView.astro";
import RestaurantCard from "../components/eat/RestaurantCard.astro";
import MethodologyFooter from "../components/eat/MethodologyFooter.astro";
import {
  CITY_CHIPS,
  CUISINE_CHIPS,
  FLAG_CHIPS,
  cuisineSlug,
  restaurantCity,
  restaurantFlags,
} from "../data/eat-chips.js";

/* Fixed sort: cuisine chip order, then rank_in_city ascending. */
const cuisineOrder = new Map(CUISINE_CHIPS.map((c, i) => [c.value, i]));
const sorted = [...restaurants].sort((a, b) => {
  const o =
    (cuisineOrder.get(a.cuisine_chip) ?? 999) -
    (cuisineOrder.get(b.cuisine_chip) ?? 999);
  return o !== 0 ? o : a.rank_in_city - b.rank_in_city;
});
const total = sorted.length;

/* Per-chip counts (keyed by slug) for the rail. */
const cuisineCounts: Record<string, number> = {};
for (const c of CUISINE_CHIPS) cuisineCounts[c.slug] = 0;
for (const r of sorted) {
  const s = cuisineSlug(r.cuisine_chip);
  if (s) cuisineCounts[s]++;
}
const flagCounts: Record<string, number> = {};
for (const f of FLAG_CHIPS) flagCounts[f.slug] = 0;
for (const r of sorted)
  for (const f of restaurantFlags(r)) flagCounts[f]++;

/* Phase D D6 — per-city counts for the LocationChipRow. Same convention as
   cuisineCounts: count every visible row. Chips with a zero count drop out
   (defensive — all 5 buckets currently have rows). */
const cityCounts: Record<string, number> = {};
for (const c of CITY_CHIPS) cityCounts[c.slug] = 0;
for (const r of sorted) cityCounts[restaurantCity(r)]++;

const cityChips = CITY_CHIPS
  .map((c) => ({
    slug: c.slug,
    label: c.label,
    count: cityCounts[c.slug],
    isRollup: c.isRollup,
  }))
  .filter((c) => c.count > 0);
---

<Base
  title="Where to eat in Japan — Japan Finds"
  description="282 restaurants from Tabelog's Hyakumeiten lists — sushi, ramen, yakitori and the shokudo picks. Filter by cuisine, price tier and reservation status, then take the map with you."
>
  <Header />
  <main id="main">
    <section class="ehero">
      <div class="wrap">
        <p class="eyebrow">JAPAN FINDS · WHERE TO EAT</p>
        <h1>Where to eat in Japan, ranked by people who live there.</h1>
        <p class="ehero-sub">
          Tabelog Hyakumeiten — 282 restaurants across 13 categories. The
          specialty kind (sushi, tempura, sukiyaki) and the everyday kind
          (ramen, soba, the shokudo lists). Steven isn't a foodie. These are
          the picks because the locals voted, not because he ate there.
        </p>
        <a
          class="ehero-cite"
          href="https://award.tabelog.com/hyakumeiten"
          target="_blank"
          rel="noopener"
        >See the Hyakumeiten lists on Tabelog&nbsp;→</a>
      </div>
    </section>

    <div class="rail-sticky">
      <SearchBox placeholder={`Search ${total} restaurants`} />
      <LocationChipRow chips={cityChips} hintLabel="cities" />
      <ChipRow cuisineCounts={cuisineCounts} flagCounts={flagCounts} />
    </div>

    <section class="eresults">
      <div class="wrap">
        <div class="eresults-bar">
          <h2 class="eresults-count" data-count>Showing {total} of {total}</h2>
          <button type="button" class="eclear" data-clear hidden>
            Clear filters
          </button>
          <div
            class="view-toggle"
            role="group"
            aria-label="Toggle list or map view"
            data-view-toggle
          >
            <button type="button" data-view-btn="list" aria-pressed="true">List</button>
            <button type="button" data-view-btn="map" aria-pressed="false">Map</button>
          </div>
        </div>
        <p class="xlink">Looking for places to go? <a href="/places">See → /places</a></p>
        <div data-list-section>
          <div class="grid" data-grid>
            {sorted.map((r) => <RestaurantCard restaurant={r} />)}
          </div>
          <p class="eresults-empty" data-empty hidden>
            Nothing here yet. Back when there is.
          </p>
        </div>
      </div>
    </section>

    <section class="eresults-map" data-map-section hidden>
      <MapView
        containerId="eat-map"
        sourceFilter="eat"
        filterEventName="eat:filter-changed"
        height="78vh"
        showLegend={true}
        legendKind="eat"
      />
    </section>

    <MethodologyFooter />
  </main>
  <SiteFooter />
</Base>

<style>
  .wrap {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 var(--gutter-mobile);
  }

  /* Filter block wrapper — holds the view toggle, search, and the
     location + cuisine/flag rails as a single unit. Scrolls with the
     page (was previously sticky; the always-pinned footprint starved
     the card grid on mobile). The white surface + ink hairline remain
     as the visual separator between filters and the grid. */
  .rail-sticky {
    background: var(--color-white);
    border-bottom: var(--border-ink);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }

  /* Hero — text on the body background, no image (BUILD_SPEC §1). */
  .ehero {
    padding: 30px 0 24px;
  }
  .ehero h1 {
    margin: 10px 0 0;
    max-width: 22ch;
    font-family: var(--font-head);
    font-size: 36px;
    font-weight: 700;
    line-height: 1.02;
    letter-spacing: -0.03em;
  }
  .ehero-sub {
    margin: 14px 0 0;
    max-width: 52ch;
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-ink-60);
  }
  /* Single source-of-truth link to the master Hyakumeiten hub. Replaces
     the per-card "Tabelog list" link that pointed at per-category award
     pages (21 distinct cuisine/region permutations). Mono small-caps to
     match the .rc-link voice. */
  .ehero-cite {
    display: inline-block;
    margin: 12px 0 0;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ink-black);
    text-decoration: none;
  }
  .ehero-cite:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Restaurants Map CTA — single button (BUILD_SPEC §2). */
  .emap {
    padding: 0 0 26px;
  }

  /* Results sit on white so the rice-white cards read. Bottom padding
     lives on [data-list-section] (not the always-visible .eresults wrap)
     so map view doesn't carry the grid's vertical reserve as a dead
     band between the controls row and the map.

     flow-root establishes a new block formatting context so the xlink's
     margin-bottom stays inside the white section. Without it, the margin
     collapses out the bottom (no padding/border to block it) and the
     body's rice-white shows through as a beige strip between the
     controls and the map in map view. */
  .eresults {
    background: var(--color-white);
    padding: 18px 0 0;
    display: flow-root;
  }
  [data-list-section] {
    padding-bottom: 8px;
  }
  /* Count + clear + view-toggle bar. align-items: center (was baseline)
     so the segmented control sits flush with the count text. The toggle
     is pushed to the right via margin-left: auto; flex-wrap lets it
     drop below on the narrowest mobile widths. */
  .eresults-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px 14px;
    margin-bottom: 14px;
  }
  .eresults-bar .view-toggle {
    margin-left: auto;
  }
  /* Wayfinding aside — sits between the results bar and the grid as a
     low-key cross-link to /places. Sub-CTA weight, mono to read as
     inline copy rather than a button. */
  .xlink {
    margin: -4px 0 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-ink-60);
  }
  .xlink a {
    color: var(--color-ink-black);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  /* h2 for document outline (h1 hero -> h2 count -> h3 card names);
     the class overrides the heading defaults so it reads as a label. */
  .eresults-count {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-60);
  }
  .eclear {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 0;
    background: none;
    border: 0;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .eclear[hidden] {
    display: none;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  /* Native lazy-render: the browser skips layout/paint for off-screen
     cards, so all 282 stay in the DOM (instant filtering) without the
     cost of painting every card up front. */
  .grid :global(.rc) {
    content-visibility: auto;
    contain-intrinsic-size: auto 380px;
  }
  .eresults-empty {
    padding: 48px 0;
    font-family: var(--font-head);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-align: center;
  }

  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .wrap {
      padding: 0 var(--gutter-desktop);
    }
    .ehero {
      padding: 52px 0 32px;
    }
    .ehero h1 {
      font-size: 60px;
      letter-spacing: -0.035em;
    }
    .ehero-sub {
      font-size: 18px;
    }
    .emap {
      padding: 0 0 36px;
    }
    .eresults {
      padding: 22px 0 0;
    }
    .grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
    }
  }

  /* View toggle — segmented control. Lives on the .eresults-bar above;
     mirrors /places. */
  .view-toggle {
    display: inline-flex;
    border: 1.5px solid var(--color-ink-black);
    border-radius: var(--radius-pill);
    overflow: hidden;
    background: var(--color-rice-white);
    box-shadow: var(--shadow-sm);
  }
  .view-toggle button {
    padding: 6px 14px;
    background: transparent;
    border: none;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-black);
    cursor: pointer;
  }
  .view-toggle button[aria-pressed="true"] {
    background: var(--color-ink-black);
    color: #fff;
  }
  /* Override the global red focus ring on toggle segments. The 2px red
     outline at +2px offset bled past the active button's right edge into
     the seam between List/Map, reading as a red divider. An inset ink
     hairline keeps the focus affordance neutral and stays inside the
     segment so adjacent buttons don't overlap it. */
  .view-toggle button:focus-visible {
    outline: 1.5px solid var(--color-ink-black);
    outline-offset: -1.5px;
  }
  .eresults-map[hidden] { display: none; }
</style>

<script>
  /* View toggle (Phase B) — same logic as /places.astro. */
  const toggle = document.querySelector("[data-view-toggle]");
  const listSec = document.querySelector("[data-list-section]");
  const mapSec = document.querySelector("[data-map-section]");

  function setView(view, { writeURL = true } = {}) {
    const isMap = view === "map";
    if (listSec) listSec.hidden = isMap;
    if (mapSec) mapSec.hidden = !isMap;
    if (toggle) {
      for (const btn of toggle.querySelectorAll("[data-view-btn]")) {
        btn.setAttribute(
          "aria-pressed",
          String(btn.dataset.viewBtn === view),
        );
      }
    }
    if (writeURL) {
      const p = new URLSearchParams(window.location.search);
      if (isMap) p.set("view", "map");
      else p.delete("view");
      const qs = p.toString();
      history.replaceState(
        null,
        "",
        window.location.pathname + (qs ? "?" + qs : "") + window.location.hash,
      );
    }
    if (isMap) {
      window.dispatchEvent(new CustomEvent("mapview:show"));
    }
  }

  const params = new URLSearchParams(window.location.search);
  setView(params.get("view") === "map" ? "map" : "list", { writeURL: false });

  if (toggle) {
    for (const btn of toggle.querySelectorAll("[data-view-btn]")) {
      btn.addEventListener("click", () => {
        setView(btn.dataset.viewBtn);
      });
    }
  }

  window.addEventListener("popstate", () => {
    const params = new URLSearchParams(window.location.search);
    setView(params.get("view") === "map" ? "map" : "list", { writeURL: false });
  });

  /* Re-scroll to the hash target after layout settles. Cards use
     `content-visibility: auto` for perf — the browser's initial scroll
     can land on the placeholder's intrinsic size instead of the painted
     card's true position, which previously made popup-CTA deep links
     look like they had landed at the top of the page. Two RAFs let the
     filter rail init and content-visibility activation finish, then we
     re-scroll with the card's scroll-margin honored. */
  if (window.location.hash) {
    const id = decodeURIComponent(window.location.hash.slice(1));
    if (id) {
      requestAnimationFrame(() => requestAnimationFrame(() => {
        const el = document.getElementById(id);
        if (el) el.scrollIntoView({ block: "start" });
      }));
    }
  }
</script>
